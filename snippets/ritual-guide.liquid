{%- assign ritual_title = title | default: 'The Ritual Guide' -%}
{%- assign ritual_text = text | default: 'Warm slightly. Massage into roots. Leave for 30 - 60mins. Use two to three times a week.' -%}

{%- if ritual_title != blank or ritual_text != blank -%}
  <div class="theme-hero-ritual-guide">
    <div class="theme-hero-ritual-guide__card">
      <div class="theme-hero-ritual-guide__inner">
        <span class="theme-hero-ritual-guide__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
          </svg>
        </span>
        <div class="theme-hero-ritual-guide__copy">
          {%- if ritual_title != blank -%}
            <div class="theme-hero-ritual-guide__title">{{ ritual_title }}</div>
          {%- endif -%}
          {%- if ritual_text != blank -%}
            <p class="theme-hero-ritual-guide__text">{{ ritual_text }}</p>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
{%- endif -%}
