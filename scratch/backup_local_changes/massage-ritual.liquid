<section class="theme-massage-ritual">
  {{ 'section-massage-ritual.css' | asset_url | stylesheet_tag }}

  <div class="theme-massage-ritual__hero">
    {%- if section.settings.mobile_hero_image != blank or section.settings.desktop_hero_image != blank -%}
      <picture>
        {%- if section.settings.mobile_hero_image != blank -%}
          <source media="(max-width: 989px)" srcset="{{ section.settings.mobile_hero_image | image_url: width: 900 }}">
        {%- endif -%}
        {%- if section.settings.desktop_hero_image != blank -%}
          <source media="(min-width: 990px)" srcset="{{ section.settings.desktop_hero_image | image_url: width: 1400 }}">
          {{ section.settings.desktop_hero_image | image_url: width: 1400 | image_tag: class: 'theme-massage-ritual__hero-image', loading: 'lazy', alt: section.settings.hero_alt }}
        {%- elsif section.settings.mobile_hero_image != blank -%}
          {{ section.settings.mobile_hero_image | image_url: width: 1400 | image_tag: class: 'theme-massage-ritual__hero-image', loading: 'lazy', alt: section.settings.hero_alt }}
        {%- endif -%}
      </picture>
    {%- endif -%}
  </div>

  <div class="theme-massage-ritual__container">
    <div class="theme-massage-ritual__steps-box">
      <div class="theme-massage-ritual__mobile-grid">
        <div class="theme-massage-ritual__mobile-step">
          <div class="theme-massage-ritual__mobile-number-wrap">
            <div class="theme-massage-ritual__mobile-number">1</div>
            <div class="theme-massage-ritual__mobile-label">{{ section.settings.mobile_step_1_title }}</div>
          </div>
          <div class="theme-massage-ritual__mobile-content">
            <p class="theme-massage-ritual__mobile-desc">{{ section.settings.mobile_step_1_text }}</p>
          </div>
        </div>
        <div class="theme-massage-ritual__mobile-step">
          <div class="theme-massage-ritual__mobile-number-wrap">
            <div class="theme-massage-ritual__mobile-number">2</div>
            <div class="theme-massage-ritual__mobile-label">{{ section.settings.mobile_step_2_title }}</div>
          </div>
          <div class="theme-massage-ritual__mobile-content">
            <p class="theme-massage-ritual__mobile-desc">{{ section.settings.mobile_step_2_text }}</p>
          </div>
        </div>
        <div class="theme-massage-ritual__mobile-step theme-massage-ritual__mobile-step--last">
          <div class="theme-massage-ritual__mobile-number-wrap">
            <div class="theme-massage-ritual__mobile-number">3</div>
            <div class="theme-massage-ritual__mobile-label">{{ section.settings.mobile_step_3_title }}</div>
          </div>
          <div class="theme-massage-ritual__mobile-content">
            <p class="theme-massage-ritual__mobile-desc">{{ section.settings.mobile_step_3_text }}</p>
          </div>
        </div>
      </div>

      <div class="theme-massage-ritual__desktop-grid">
        <div class="theme-massage-ritual__desktop-step theme-massage-ritual__desktop-step--bordered">
          <div class="theme-massage-ritual__desktop-number">1</div>
          <div class="theme-massage-ritual__desktop-label">{{ section.settings.desktop_step_1_title }}</div>
          <p class="theme-massage-ritual__desktop-desc">{{ section.settings.desktop_step_1_text }}</p>
        </div>
        <div class="theme-massage-ritual__desktop-step theme-massage-ritual__desktop-step--bordered">
          <div class="theme-massage-ritual__desktop-number">2</div>
          <div class="theme-massage-ritual__desktop-label">{{ section.settings.desktop_step_2_title }}</div>
          <p class="theme-massage-ritual__desktop-desc">{{ section.settings.desktop_step_2_text }}</p>
        </div>
        <div class="theme-massage-ritual__desktop-step">
          <div class="theme-massage-ritual__desktop-number">3</div>
          <div class="theme-massage-ritual__desktop-label">{{ section.settings.desktop_step_3_title }}</div>
          <p class="theme-massage-ritual__desktop-desc">{{ section.settings.desktop_step_3_text }}</p>
        </div>
      </div>

      {%- assign pt_button_label = section.settings.patch_test_button_label | strip -%}
      {%- assign pt_popup_text = section.settings.patch_test_popup_text | strip -%}
      {%- if pt_button_label != blank or pt_popup_text != blank -%}
        <div class="theme-massage-ritual__patch-divider"></div>
        <div class="theme-massage-ritual__patch-test-wrap">
          <details class="theme-massage-ritual__patch-test">
            <summary class="theme-massage-ritual__patch-trigger">
              <svg class="theme-massage-ritual__patch-icon" width="14" height="14" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="color: currentColor; flex-shrink: 0;">
                <path d="M6 3.5V6.5M6 8.5H6.005M11 6C11 8.76142 8.76142 11 6 11C3.23858 11 1 8.76142 1 6C1 3.23858 3.23858 1 6 1C8.76142 1 11 3.23858 11 6Z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {%- if pt_button_label != blank -%}
                <span>{{ pt_button_label }}</span>
              {%- endif -%}
            </summary>
            {%- if pt_popup_text != blank -%}
              <div class="theme-massage-ritual__patch-popup" role="status" aria-live="polite">
                <p class="theme-massage-ritual__patch-popup-text">{{ pt_popup_text }}</p>
              </div>
            {%- endif -%}
          </details>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Massage ritual",
  "settings": [
    { "type": "image_picker", "id": "desktop_hero_image", "label": "Desktop hero image" },
    { "type": "image_picker", "id": "mobile_hero_image", "label": "Mobile hero image" },
    { "type": "text", "id": "hero_alt", "label": "Hero image alt text", "default": "Your Easy Massage Ritual" },
    { "type": "text", "id": "desktop_step_1_title", "label": "Desktop step 1 title", "default": "WARM" },
    { "type": "textarea", "id": "desktop_step_1_text", "label": "Desktop step 1 text", "default": "Warm oil penetrates - cold oil sits on the surface." },
    { "type": "text", "id": "desktop_step_2_title", "label": "Desktop step 2 title", "default": "APPLY" },
    { "type": "textarea", "id": "desktop_step_2_text", "label": "Desktop step 2 text", "default": "Apply adequate amount gently onto the scalp and hair." },
    { "type": "text", "id": "desktop_step_3_title", "label": "Desktop step 3 title", "default": "MASSAGE" },
    { "type": "textarea", "id": "desktop_step_3_text", "label": "Desktop step 3 text", "default": "Circular motion, 5 minutes. Fingertips, not nails." },
    { "type": "text", "id": "mobile_step_1_title", "label": "Mobile step 1 title", "default": "WARM" },
    { "type": "textarea", "id": "mobile_step_1_text", "label": "Mobile step 1 text", "default": "Warm oil penetrates - cold oil sits on the surface." },
    { "type": "text", "id": "mobile_step_2_title", "label": "Mobile step 2 title", "default": "APPLY" },
    { "type": "textarea", "id": "mobile_step_2_text", "label": "Mobile step 2 text", "default": "Apply adequate amount gently onto the scalp and hair." },
    { "type": "text", "id": "mobile_step_3_title", "label": "Mobile step 3 title", "default": "MASSAGE" },
    { "type": "textarea", "id": "mobile_step_3_text", "label": "Mobile step 3 text", "default": "Circular motion, 5 minutes. Fingertips, not nails." },
    { "type": "header", "content": "Patch test" },
    { "type": "text", "id": "patch_test_button_label", "label": "Button label", "default": "Always patch test first" },
    {
      "type": "textarea",
      "id": "patch_test_popup_text",
      "label": "Popup text",
      "default": "Apply a small amount behind the ear or on the inner elbow. Wait 24-48 hours. If no redness or irritation appears, proceed with regular use"
    }
  ],
  "presets": [{ "name": "Massage ritual" }]
}
{% endschema %}

