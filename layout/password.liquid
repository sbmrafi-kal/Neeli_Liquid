<!doctype html>
<html class="js full-height" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>{{ shop.name }}</title>

    <meta name="description" content="{{ page_description | escape }}">

    {% render 'meta-tags' %}

    {{ content_for_header }}

    {% style %}
      @font-face {
        font-family: "Avenir";
        src: url("{{ 'Avenir.ttc' | asset_url }}") format("truetype-collection");
        font-style: normal;
        font-weight: 400 700;
        font-display: swap;
      }

      @font-face {
        font-family: "Amstir";
        src: url("{{ 'Amstir-Regular.otf' | asset_url }}") format("opentype");
        font-style: normal;
        font-weight: 400;
        font-display: swap;
      }

      :root {
        --font-body-family: "Avenir", sans-serif;
        --font-heading-family: "Amstir", "Avenir", serif;
        --theme-forest: #17372d;
        --theme-gold: #f3b324;
      }

      body {
        margin: 0;
        font-family: var(--font-body-family);
        color: var(--theme-forest);
        background: #f7f3e9;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        box-sizing: border-box;
      }
    {% endstyle %}

    {{ 'base.css' | asset_url | stylesheet_tag }}
  </head>

  <body class="password gradient">
    <main id="MainContent" style="width: 100%; max-width: 480px; text-align: center; background: #fff; padding: 3rem 2rem; border-radius: 16px; border: 1px solid rgba(23, 55, 45, 0.08); box-shadow: 0 4px 20px rgba(23, 55, 45, 0.04);">
      {{ content_for_layout }}
    </main>
  </body>
</html>
