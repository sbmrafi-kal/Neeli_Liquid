<article class="theme-container theme-container--medium theme-page-spacing theme-article-page">
  <header class="article-header theme-text-center">
    <span class="theme-page-kicker">
      {{ article.published_at | time_tag: format: 'date' }}
    </span>
    <h1 class="theme-page-title theme-page-title--xl">
      {{ article.title | escape }}
    </h1>
    {%- if article.author -%}
      <span class="theme-page-subtitle">By {{ article.author }}</span>
    {%- endif -%}
  </header>

  {%- if article.image != blank -%}
    <div class="theme-card theme-card--surface theme-media-frame theme-media-frame--wide">
      <img
        src="{{ article.image | image_url: width: 1100 }}"
        alt="{{ article.image.alt | escape }}"
        class="theme-media-fill"
        loading="lazy"
      >
    </div>
  {%- endif -%}

  <div class="theme-page-content rte">
    {{ article.content }}
  </div>
</article>

{% schema %}
{
  "name": "Article Page",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
