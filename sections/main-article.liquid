<article class="theme-container theme-container--narrow theme-page-spacing" style="max-width: 720px; margin: 0 auto;">
  <header class="article-header text-center" style="margin-bottom: 3rem;">
    <span style="font-size: 0.8125rem; text-transform: uppercase; color: #8f4f36; letter-spacing: 0.08em; font-weight: 500;">
      {{ article.published_at | time_tag: format: 'date' }}
    </span>
    <h1 class="theme-page-title" style="font-family: var(--font-heading-family); font-size: 2.75rem; color: var(--theme-forest); margin: 0.75rem 0 1rem; line-height: 1.1; font-weight: 400;">
      {{ article.title | escape }}
    </h1>
    {%- if article.author -%}
      <span style="font-size: 0.875rem; color: rgba(23, 55, 45, 0.54);">By {{ article.author }}</span>
    {%- endif -%}
  </header>

  {%- if article.image != blank -%}
    <div style="border-radius: 12px; overflow: hidden; margin-bottom: 3.5rem; border: 1px solid rgba(23, 55, 45, 0.08);">
      <img
        src="{{ article.image | image_url: width: 1100 }}"
        alt="{{ article.image.alt | escape }}"
        style="width: 100%; height: auto; display: block;"
        loading="lazy"
      >
    </div>
  {%- endif -%}

  <div class="theme-page-content rte" style="font-size: 1.0625rem; color: rgba(23, 55, 45, 0.82); line-height: 1.6; display: grid; gap: 1.5rem;">
    {{ article.content }}
  </div>
</article>

{% schema %}
{
  "name": "Article Page",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
