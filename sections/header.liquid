{{ 'section-theme-product-page.css' | asset_url | stylesheet_tag }}
{{ 'section-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'header.js' | asset_url }}" defer="defer"></script>

{%- assign main_menu = linklists[section.settings.menu_handle] -%}
{%- assign nav_links = main_menu.links -%}

<header class="theme-header" role="banner">
  <div class="theme-header__primary-bar">
    <div class="theme-header__inner">
      <div class="theme-header__left">
        <button class="theme-header__menu-btn" type="button" aria-label="Open menu">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
          </svg>
        </button>

        <nav class="theme-header__nav" aria-label="Primary">
          {%- assign nav_1_title = section.settings.nav_1_title | default: 'Shop All' -%}
          {%- assign nav_2_title = section.settings.nav_2_title | default: 'Clinics' -%}
          {%- assign nav_3_title = section.settings.nav_3_title | default: 'Resorts' -%}
          {%- assign nav_4_title = section.settings.nav_4_title | default: 'Hospitals' -%}
          {%- assign nav_5_title = section.settings.nav_5_title | default: 'Academy' -%}

          {%- assign nav_1_url = section.settings.nav_1_url | default: routes.root_url -%}
          {%- assign nav_2_url = section.settings.nav_2_url | default: routes.root_url -%}
          {%- assign nav_3_url = section.settings.nav_3_url | default: routes.root_url -%}
          {%- assign nav_4_url = section.settings.nav_4_url | default: routes.root_url -%}
          {%- assign nav_5_url = section.settings.nav_5_url | default: routes.root_url -%}

          <a class="theme-header__nav-link theme-header__nav-link--soft" href="{{ nav_1_url }}">{{ nav_1_title }}</a>
          <a class="theme-header__nav-link theme-header__nav-link--soft" href="{{ nav_2_url }}">{{ nav_2_title }}</a>
          <a class="theme-header__nav-link theme-header__nav-link--soft" href="{{ nav_3_url }}">{{ nav_3_title }}</a>
          <a class="theme-header__nav-link theme-header__nav-link--soft" href="{{ nav_4_url }}">{{ nav_4_title }}</a>
          <a class="theme-header__nav-link theme-header__nav-link--soft" href="{{ nav_5_url }}">{{ nav_5_title }}</a>
        </nav>
      </div>

      <div class="theme-header__center">
        <a class="theme-header__brand" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
          {%- if section.settings.logo_image != blank -%}
            {{ section.settings.logo_image | image_url: width: 600 | image_tag: class: 'theme-header__brand-image', loading: 'eager', alt: section.settings.logo_alt }}
          {%- else -%}
            <span class="theme-header__brand-text">{{ section.settings.logo_text | default: shop.name }}</span>
          {%- endif -%}
        </a>
      </div>

      <div class="theme-header__right">
        <button class="theme-header__action-btn" type="button" aria-label="Search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="7"/>
            <path d="m21 21-4.35-4.35"/>
          </svg>
        </button>
        <button class="theme-header__action-btn theme-header__action-btn--account" type="button" aria-label="Account">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="8" r="5"/>
            <path d="M20 21a8 8 0 0 0-16 0"/>
          </svg>
        </button>

        <a class="theme-header__action-btn" href="{{ routes.cart_url }}" aria-label="Cart">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="8" cy="21" r="1"/>
            <circle cx="19" cy="21" r="1"/>
            <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="theme-header__subnav">
    <div class="theme-header__subnav-inner">
      <div class="theme-header__breadcrumbs">
        <a href="{{ routes.root_url }}">Home</a>
        {%- assign breadcrumb_label = blank -%}
        {%- if request.page_type == 'product' and product != blank -%}
          {%- assign breadcrumb_label = product.title -%}
        {%- elsif request.page_type == 'collection' and collection != blank -%}
          {%- assign breadcrumb_label = collection.title -%}
        {%- elsif request.page_type == 'page' and page != blank -%}
          {%- assign breadcrumb_label = page.title -%}
        {%- elsif request.page_type == 'article' and article != blank -%}
          {%- assign breadcrumb_label = article.title -%}
        {%- endif -%}
        {%- if breadcrumb_label != blank -%}
          <span class="theme-header__breadcrumb-sep">›</span>
          <span class="theme-header__breadcrumb-current">{{ breadcrumb_label }}</span>
        {%- endif -%}
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "header",
  "tag": "section",
  "class": "section theme-header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu_handle",
      "label": "Main menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "nav_1_title",
      "label": "Nav item 1 label",
      "default": "Shop All"
    },
    {
      "type": "url",
      "id": "nav_1_url",
      "label": "Nav item 1 link"
    },
    {
      "type": "text",
      "id": "nav_2_title",
      "label": "Nav item 2 label",
      "default": "Clinics"
    },
    {
      "type": "url",
      "id": "nav_2_url",
      "label": "Nav item 2 link"
    },
    {
      "type": "text",
      "id": "nav_3_title",
      "label": "Nav item 3 label",
      "default": "Resorts"
    },
    {
      "type": "url",
      "id": "nav_3_url",
      "label": "Nav item 3 link"
    },
    {
      "type": "text",
      "id": "nav_4_title",
      "label": "Nav item 4 label",
      "default": "Hospitals"
    },
    {
      "type": "url",
      "id": "nav_4_url",
      "label": "Nav item 4 link"
    },
    {
      "type": "text",
      "id": "nav_5_title",
      "label": "Nav item 5 label",
      "default": "Academy"
    },
    {
      "type": "url",
      "id": "nav_5_url",
      "label": "Nav item 5 link"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "logo_alt",
      "label": "Logo alt text",
      "default": "Kerala Ayurveda"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo fallback text",
      "default": "Kerala Ayurveda"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 0,
      "step": 1,
      "default": 0,
      "label": "Top padding"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 0,
      "step": 1,
      "default": 0,
      "label": "Bottom padding"
    }
  ],
  "presets": [
    {
      "name": "header"
    }
  ]
}
{% endschema %}
