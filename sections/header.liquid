{{ 'section-theme-product-page.css' | asset_url | stylesheet_tag }}
{{ 'section-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'header.js' | asset_url }}" defer="defer"></script>

{%- assign main_menu = linklists[section.settings.menu_handle] -%}
{%- assign nav_links = main_menu.links -%}

<header class="theme-header" role="banner">
  <div class="theme-header__primary-bar">
    <div class="theme-header__inner">
      <div class="theme-header__left">
        <button class="theme-header__menu-btn" type="button" aria-label="Open menu">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
          </svg>
        </button>

        <nav class="theme-header__nav" aria-label="Primary">
          <a class="theme-header__nav-link theme-header__nav-link--soft" href="{{ nav_links[0].url | default: routes.root_url }}">Shop All</a>
          <a class="theme-header__nav-link theme-header__nav-link--soft" href="{{ nav_links[1].url | default: routes.root_url }}">Clinics</a>
          <a class="theme-header__nav-link theme-header__nav-link--soft" href="{{ nav_links[2].url | default: routes.root_url }}">Resorts</a>
          <a class="theme-header__nav-link theme-header__nav-link--soft" href="{{ nav_links[3].url | default: routes.root_url }}">Hospitals</a>
          <a class="theme-header__nav-link theme-header__nav-link--soft" href="{{ nav_links[4].url | default: routes.root_url }}">Academy</a>
        </nav>
      </div>

      <div class="theme-header__center">
        <a class="theme-header__brand" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
          <img src="{{ 'logo-kerala.png' | asset_url }}" class="theme-header__brand-image" width="4167" height="4167" alt="{{ shop.name | escape }}" loading="eager">
        </a>
      </div>

      <div class="theme-header__right">
        <button class="theme-header__action-btn" type="button" aria-label="Search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="7"/>
            <path d="m21 21-4.35-4.35"/>
          </svg>
        </button>
        <button class="theme-header__action-btn" type="button" aria-label="Account">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="8" r="5"/>
            <path d="M20 21a8 8 0 0 0-16 0"/>
          </svg>
        </button>

        <a class="theme-header__action-btn" href="{{ routes.cart_url }}" aria-label="Cart">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="8" cy="21" r="1"/>
            <circle cx="19" cy="21" r="1"/>
            <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="theme-header__subnav">
    <div class="theme-header__subnav-inner">
      <div class="theme-header__breadcrumbs">
        <a href="{{ routes.root_url }}">Home</a>
        <span class="theme-header__breadcrumb-sep">›</span>
        <span class="theme-header__breadcrumb-current">Neelibhringadi Keram</span>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "header",
  "tag": "section",
  "class": "section theme-header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu_handle",
      "label": "Main menu",
      "default": "main-menu"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 0,
      "step": 1,
      "default": 0,
      "label": "Top padding"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 0,
      "step": 1,
      "default": 0,
      "label": "Bottom padding"
    }
  ],
  "presets": [
    {
      "name": "header"
    }
  ]
}
{% endschema %}
