<div class="theme-container theme-container--narrow theme-page-spacing text-center">
  <p class="theme-section-heading__kicker" style="color: #8f4f36; font-size: 0.875rem; letter-spacing: 0.12em; text-transform: uppercase;">404 Error</p>
  <h1 class="theme-page-title" style="font-family: var(--font-heading-family); font-size: 3rem; color: var(--theme-forest); margin-top: 1rem; line-height: 1;">Page Not Found</h1>
  <p class="theme-page-subtitle" style="font-size: 1.125rem; color: rgba(23, 55, 45, 0.72); max-width: 480px; margin: 1.5rem auto 2.5rem;">
    The page you are looking for does not exist or has been moved to a new address. Let's get you back to complete hair recovery.
  </p>
  <a href="{{ routes.all_products_collection_url }}" class="theme-review-button" style="display: inline-flex; text-decoration: none;">
    Shop All Products
  </a>
</div>

{% schema %}
{
  "name": "404 Content",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
