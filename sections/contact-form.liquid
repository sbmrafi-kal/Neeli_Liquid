<div class="theme-container theme-container--narrow theme-page-spacing" style="max-width: 580px; margin: 0 auto;">
  <h2 class="text-center" style="font-family: var(--font-heading-family); font-size: 2.25rem; color: var(--theme-forest); margin-bottom: 2.5rem;">Send Us a Message</h2>

  {%- form 'contact', id: 'ContactForm', class: 'contact-form' -%}
    {%- if form.posted_successfully? -%}
      <div style="background: #ecf8ee; border: 1px solid #38a55b; color: #1d201d; border-radius: 8px; padding: 1rem 1.25rem; margin-bottom: 2rem; font-size: 0.9375rem;">
        Thanks for reaching out! We'll respond as soon as possible.
      </div>
    {%- elsif form.errors -%}
      <div style="background: #fdf3f2; border: 1px solid #f44336; color: #1d201d; border-radius: 8px; padding: 1rem 1.25rem; margin-bottom: 2rem; font-size: 0.9375rem;">
        Please correct the errors in the form and try again.
      </div>
    {%- endif -%}

    <div style="display: grid; gap: 1.5rem;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div>
          <label for="ContactForm-name" style="display: block; font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; color: rgba(23, 55, 45, 0.62); margin-bottom: 0.375rem; letter-spacing: 0.05em;">Name</label>
          <input
            type="text"
            name="contact[name]"
            id="ContactForm-name"
            placeholder="Your name"
            style="width: 100%; border: 1px solid rgba(23, 55, 45, 0.2); border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.9375rem; outline: none; background: #fff;"
          >
        </div>
        <div>
          <label for="ContactForm-email" style="display: block; font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; color: rgba(23, 55, 45, 0.62); margin-bottom: 0.375rem; letter-spacing: 0.05em;">Email</label>
          <input
            type="email"
            name="contact[email]"
            id="ContactForm-email"
            placeholder="Your email"
            style="width: 100%; border: 1px solid rgba(23, 55, 45, 0.2); border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.9375rem; outline: none; background: #fff;"
            required
          >
        </div>
      </div>

      <div>
        <label for="ContactForm-body" style="display: block; font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; color: rgba(23, 55, 45, 0.62); margin-bottom: 0.375rem; letter-spacing: 0.05em;">Message</label>
        <textarea
          rows="6"
          name="contact[body]"
          id="ContactForm-body"
          placeholder="How can we help you?"
          style="width: 100%; border: 1px solid rgba(23, 55, 45, 0.2); border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.9375rem; outline: none; background: #fff; resize: vertical;"
          required
        ></textarea>
      </div>

      <button type="submit" class="theme-review-button" style="display: inline-flex; width: 100%; justify-content: center; background: #8f4f36; border-color: #8f4f36; color: #fff; cursor: pointer; padding: 1rem 2rem;">
        Send Message
      </button>
    </div>
  {%- endform -%}
</div>

{% schema %}
{
  "name": "Contact Form",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
