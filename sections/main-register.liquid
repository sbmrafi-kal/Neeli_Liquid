<div class="neeli-container neeli-page-spacing" style="max-width: 440px; margin: 0 auto;">
  <h2 style="font-family: var(--font-heading-family); font-size: 2.5rem; color: var(--neeli-forest); text-align: center; margin-bottom: 2rem; font-weight: 400;">Create Account</h2>

  {%- form 'create_customer' -%}
    {%- if form.errors -%}
      <div style="background: #fdf3f2; border: 1px solid #f44336; color: #1d201d; border-radius: 8px; padding: 0.75rem 1rem; margin-bottom: 1.5rem; font-size: 0.875rem;">
        {{ form.errors | default_errors }}
      </div>
    {%- endif -%}

    <div style="display: grid; gap: 1.25rem; margin-bottom: 1.75rem;">
      <div>
        <label for="Register-FirstName" style="display: block; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; color: rgba(23, 55, 45, 0.62); margin-bottom: 0.5rem; letter-spacing: 0.05em;">First Name</label>
        <input
          type="text"
          name="customer[first_name]"
          id="Register-FirstName"
          placeholder="First name"
          style="width: 100%; border: 1px solid rgba(23, 55, 45, 0.2); border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.9375rem; outline: none; background: #fff;"
        >
      </div>

      <div>
        <label for="Register-LastName" style="display: block; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; color: rgba(23, 55, 45, 0.62); margin-bottom: 0.5rem; letter-spacing: 0.05em;">Last Name</label>
        <input
          type="text"
          name="customer[last_name]"
          id="Register-LastName"
          placeholder="Last name"
          style="width: 100%; border: 1px solid rgba(23, 55, 45, 0.2); border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.9375rem; outline: none; background: #fff;"
        >
      </div>

      <div>
        <label for="Register-Email" style="display: block; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; color: rgba(23, 55, 45, 0.62); margin-bottom: 0.5rem; letter-spacing: 0.05em;">Email</label>
        <input
          type="email"
          name="customer[email]"
          id="Register-Email"
          placeholder="Email"
          style="width: 100%; border: 1px solid rgba(23, 55, 45, 0.2); border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.9375rem; outline: none; background: #fff;"
          required
        >
      </div>

      <div>
        <label for="Register-Password" style="display: block; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; color: rgba(23, 55, 45, 0.62); margin-bottom: 0.5rem; letter-spacing: 0.05em;">Password</label>
        <input
          type="password"
          name="customer[password]"
          id="Register-Password"
          placeholder="Password"
          style="width: 100%; border: 1px solid rgba(23, 55, 45, 0.2); border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.9375rem; outline: none; background: #fff;"
          required
        >
      </div>
    </div>

    <button type="submit" class="neeli-review-button" style="display: inline-flex; width: 100%; justify-content: center; background: #8f4f36; border-color: #8f4f36; color: #fff; cursor: pointer; padding: 1rem 2rem;">
      Create Account
    </button>

    <div style="text-align: center; margin-top: 2rem; font-size: 0.9375rem; color: rgba(23, 55, 45, 0.72);">
      Already have an account? <a href="{{ routes.account_login_url }}" style="color: var(--neeli-forest); font-weight: 600; text-decoration: underline;">Log in</a>
    </div>
  {%- endform -%}
</div>

{% schema %}
{
  "name": "Register Page",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
