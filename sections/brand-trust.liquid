{{ 'section-theme-product-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }
{%- endstyle -%}

<section class="theme-product-page__section theme-product-page__section--forest theme-reveal section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="theme-product-page__wrap">
    <div class="theme-trust-band">
      <div class="theme-trust-band__image-wrap">
        <img src="{{ 'Flower.png' | asset_url }}" class="theme-trust-band__image image-zoom" loading="lazy" width="1024" height="1024" alt="{{ section.settings.heading | escape }}">
      </div>

      <div class="theme-trust-band__content">
        {%- if section.settings.kicker != blank -%}
          <p class="theme-trust-band__eyebrow">{{ section.settings.kicker }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="theme-trust-band__title theme-trust-band__title--full-spectrum">{{ section.settings.heading }}</h2>
        {%- endif -%}
        <div class="theme-trust-band__text rte">
          {{ section.settings.text }}
        </div>

        <div class="theme-trust-band__divider"></div>

        {%- if section.settings.patents_kicker != blank -%}
          <p class="theme-trust-band__patents-eyebrow">{{ section.settings.patents_kicker }}</p>
        {%- endif -%}
        <h2 class="theme-trust-band__title theme-trust-band__title--secondary">{{ section.settings.patents_heading }}</h2>
        <div class="theme-trust-band__text rte">{{ section.settings.patents_text }}</div>

        <div class="theme-trust-band__patents">
          <div class="theme-trust-band__patent-card motion-panel">
            <img src="{{ 'US_Flag.png' | asset_url }}" class="theme-trust-band__flag" loading="lazy" width="1432" height="954" alt="{{ section.settings.us_title | escape }}">
            <div class="theme-trust-band__patent-title">{{ section.settings.us_title }}</div>
            {%- if section.settings.us_text != blank -%}
              <div class="theme-trust-band__patent-text rte">{{ section.settings.us_text }}</div>
            {%- endif -%}
          </div>
          <div class="theme-trust-band__patent-card motion-panel">
            <img src="{{ 'Japan_Flag.png' | asset_url }}" class="theme-trust-band__flag" loading="lazy" width="1270" height="844" alt="{{ section.settings.japan_title | escape }}">
            <div class="theme-trust-band__patent-title">{{ section.settings.japan_title }}</div>
            {%- if section.settings.japan_text != blank -%}
              <div class="theme-trust-band__patent-text rte">{{ section.settings.japan_text }}</div>
            {%- endif -%}
          </div>
        </div>
      </div>

      <div class="theme-trust-band__mark">
        <!-- Mobile layout: grid with image left, vertical text right -->
        <div class="theme-trust-band__mark-mobile lg:hidden">
          <div class="theme-trust-band__mark-mobile-logo">
            <img src="{{ 'ka-mark.png' | asset_url }}" class="theme-trust-band__mark-image" loading="lazy" width="238" height="328" alt="{{ section.settings.mark_heading | escape }}">
          </div>
          <div class="theme-trust-band__mark-mobile-text-wrap">
            <p class="theme-trust-band__mark-mobile-text">
              {{ section.settings.mark_kicker }}<br>{{ section.settings.mark_heading }}
            </p>
            {%- if section.settings.mark_text != blank -%}
              <div class="theme-trust-band__mark-mobile-copy rte">{{ section.settings.mark_text }}</div>
            {%- endif -%}
          </div>
        </div>

        <!-- Desktop layout: image top, text bottom -->
        <div class="theme-trust-band__mark-desktop hidden lg:flex">
          <img src="{{ 'ka-mark.png' | asset_url }}" class="theme-trust-band__mark-image" loading="lazy" width="238" height="328" alt="{{ section.settings.mark_heading | escape }}">
          <p class="theme-trust-band__mark-desktop-text">
            <span class="block">{{ section.settings.mark_kicker }}</span>
            <span class="block whitespace-nowrap">{{ section.settings.mark_heading }}</span>
          </p>
          {%- if section.settings.mark_text != blank -%}
            <div class="theme-trust-band__mark-desktop-copy rte">{{ section.settings.mark_text }}</div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "brand trust",
  "tag": "section",
  "class": "section theme-brand-trust",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-3" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Full spectrum" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Classical and Proprietary Ayurvedic Products (350+ SKUs)" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Therapies and Ayurvedic Retreats | Academy and Education Initiatives | Pioneering Ayurvedic R&D</p>" },
    { "type": "text", "id": "patents_kicker", "label": "Patents kicker", "default": "Internationally recognized" },
    { "type": "text", "id": "patents_heading", "label": "Patents heading", "default": "Patented formulations" },
    { "type": "richtext", "id": "patents_text", "label": "Patents text", "default": "<p>Kerala Ayurveda has carried forward classical wisdom for modern wellness rituals.</p>" },
    { "type": "text", "id": "us_title", "label": "US title", "default": "US patent" },
    { "type": "richtext", "id": "us_text", "label": "US text", "default": "<p>Protected formulation details and process knowledge.</p>" },
    { "type": "text", "id": "japan_title", "label": "Japan title", "default": "Japan patent" },
    { "type": "richtext", "id": "japan_text", "label": "Japan text", "default": "<p>Recognition of the proprietary process and method.</p>" },
    { "type": "text", "id": "mark_kicker", "label": "Mark kicker", "default": "Rooted in authenticity" },
    { "type": "text", "id": "mark_heading", "label": "Mark heading", "default": "Authentic Ayurveda." },
    { "type": "richtext", "id": "mark_text", "label": "Mark text", "default": "<p>Bring the same trust cues from the Neeli landing page into Shopify.</p>" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "default": 36, "label": "Top padding" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "default": 36, "label": "Bottom padding" }
  ],
  "presets": [
    {
      "name": "brand trust"
    }
  ]
}
{% endschema %}
