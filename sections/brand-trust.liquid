{{ 'section-brand-trust.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign desktop_image = section.settings.desktop_image
  assign mobile_image = section.settings.mobile_image | default: desktop_image
  assign desktop_title = section.settings.desktop_title | strip
  assign mobile_title = section.settings.mobile_title | strip | default: desktop_title
  assign desktop_description = section.settings.desktop_description
  assign mobile_description = section.settings.mobile_description | default: desktop_description
  assign desktop_description_plain = desktop_description | strip_html | strip
  assign mobile_description_plain = mobile_description | strip_html | strip
  assign desktop_kicker = section.settings.desktop_kicker | strip
  assign mobile_kicker = section.settings.mobile_kicker | strip | default: desktop_kicker
  assign desktop_title_2 = section.settings.desktop_title_2 | strip
  assign mobile_title_2 = section.settings.mobile_title_2 | strip | default: desktop_title_2
  assign desktop_description_2 = section.settings.desktop_description_2
  assign mobile_description_2 = section.settings.mobile_description_2 | default: desktop_description_2
  assign desktop_description_2_plain = desktop_description_2 | strip_html | strip
  assign mobile_description_2_plain = mobile_description_2 | strip_html | strip
  assign seal_image = section.settings.seal_image
  assign seal_kicker = section.settings.mark_kicker | strip
  assign seal_title = section.settings.mark_heading | strip
  assign seal_text = section.settings.mark_text
  assign seal_text_plain = seal_text | strip_html | strip
  assign has_content = false
  if desktop_image != blank
    assign has_content = true
  elsif mobile_image != blank
    assign has_content = true
  elsif desktop_title != blank
    assign has_content = true
  elsif desktop_description_plain != blank
    assign has_content = true
  elsif desktop_title_2 != blank
    assign has_content = true
  elsif desktop_description_2_plain != blank
    assign has_content = true
  elsif seal_image != blank
    assign has_content = true
  elsif seal_title != blank
    assign has_content = true
  elsif seal_text_plain != blank
    assign has_content = true
  endif
-%}

{%- if has_content -%}
  <section class="theme-brand-trust-section theme-reveal" aria-label="{{ desktop_title | default: 'Brand trust' }}">
    <div class="theme-brand-trust__mobile lg:hidden">
      <div class="theme-brand-trust__mobile-hero">
        {%- if mobile_image != blank -%}
          {{
            mobile_image
            | image_url: width: 900
            | image_tag:
              class: 'theme-brand-trust__mobile-image',
              loading: 'lazy',
              widths: '480, 640, 900',
              alt: desktop_title
          }}
        {%- else -%}
          <div class="theme-brand-trust__placeholder" aria-hidden="true">
            {{ 'image' | placeholder_svg_tag: 'theme-brand-trust__placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

      <div class="theme-brand-trust__mobile-panel">
        {%- if mobile_title != blank or mobile_description_plain != blank -%}
          <div class="theme-brand-trust__mobile-copy">
            {%- if mobile_title != blank -%}
              <h2 class="theme-brand-trust__mobile-title">{{ mobile_title }}</h2>
            {%- endif -%}
            {%- if mobile_description_plain != blank -%}
              <div class="theme-brand-trust__mobile-desc rte">{{ mobile_description }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if mobile_title_2 != blank or mobile_description_2_plain != blank -%}
          <div class="theme-brand-trust__mobile-divider"></div>
          <div class="theme-brand-trust__mobile-copy">
            {%- if mobile_kicker != blank -%}
              <div class="theme-brand-trust__mobile-kicker">{{ mobile_kicker }}</div>
            {%- endif -%}
            {%- if mobile_title_2 != blank -%}
              <h3 class="theme-brand-trust__mobile-secondary-title">{{ mobile_title_2 }}</h3>
            {%- endif -%}
            {%- if mobile_description_2_plain != blank -%}
              <div class="theme-brand-trust__mobile-desc rte">{{ mobile_description_2 }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if seal_image != blank or seal_title != blank or seal_text != blank -%}
          <div class="theme-brand-trust__mobile-seal">
            {%- if seal_image != blank -%}
              {{
                seal_image
                | image_url: width: 320
                | image_tag:
                  class: 'theme-brand-trust__mobile-seal-image',
                  loading: 'lazy',
                  widths: '160, 240, 320',
                  alt: seal_title
              }}
            {%- endif -%}
            {%- if seal_kicker != blank -%}
              <div class="theme-brand-trust__mobile-seal-kicker">{{ seal_kicker }}</div>
            {%- endif -%}
            {%- if seal_title != blank -%}
              <div class="theme-brand-trust__mobile-seal-title">{{ seal_title }}</div>
            {%- endif -%}
            {%- if seal_text != blank -%}
              <div class="theme-brand-trust__mobile-seal-text rte">{{ seal_text }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="container-narrow theme-brand-trust__desktop hidden lg:grid">
      <div class="theme-brand-trust__desktop-media">
        {%- if desktop_image != blank -%}
          {{
            desktop_image
            | image_url: width: 1600
            | image_tag:
              class: 'theme-brand-trust__desktop-image',
              loading: 'lazy',
              widths: '720, 960, 1200, 1600',
              alt: desktop_title
          }}
        {%- else -%}
          <div class="theme-brand-trust__placeholder" aria-hidden="true">
            {{ 'image' | placeholder_svg_tag: 'theme-brand-trust__placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

      <div class="theme-brand-trust__desktop-content">
        {%- if desktop_title != blank or desktop_description_plain != blank -%}
          <div class="theme-brand-trust__desktop-copy">
            {%- if desktop_title != blank -%}
              <h2 class="theme-brand-trust__desktop-title">{{ desktop_title }}</h2>
            {%- endif -%}
            {%- if desktop_description_plain != blank -%}
              <div class="theme-brand-trust__desktop-desc rte">{{ desktop_description }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if desktop_title_2 != blank or desktop_description_2_plain != blank -%}
          <div class="theme-brand-trust__desktop-divider"></div>
          <div class="theme-brand-trust__desktop-copy">
            {%- if desktop_kicker != blank -%}
              <div class="theme-brand-trust__desktop-kicker">{{ desktop_kicker }}</div>
            {%- endif -%}
            {%- if desktop_title_2 != blank -%}
              <h3 class="theme-brand-trust__desktop-secondary-title">{{ desktop_title_2 }}</h3>
            {%- endif -%}
            {%- if desktop_description_2_plain != blank -%}
              <div class="theme-brand-trust__desktop-desc rte">{{ desktop_description_2 }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- if seal_image != blank or seal_title != blank or seal_text_plain != blank -%}
        <div class="theme-brand-trust__desktop-seal">
          {%- if seal_image != blank -%}
            {{
              seal_image
              | image_url: width: 320
              | image_tag:
                class: 'theme-brand-trust__desktop-seal-image',
                loading: 'lazy',
                widths: '160, 240, 320',
                alt: seal_title
            }}
          {%- endif -%}
          {%- if seal_kicker != blank -%}
            <div class="theme-brand-trust__desktop-seal-kicker">{{ seal_kicker }}</div>
          {%- endif -%}
          {%- if seal_title != blank -%}
            <div class="theme-brand-trust__desktop-seal-title">{{ seal_title }}</div>
          {%- endif -%}
          {%- if seal_text_plain != blank -%}
            <div class="theme-brand-trust__desktop-seal-text rte">{{ seal_text }}</div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "brand trust",
  "tag": "section",
  "class": "section theme-brand-trust",
  "settings": [
    { "type": "image_picker", "id": "desktop_image", "label": "Desktop image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    { "type": "text", "id": "desktop_title", "label": "Desktop title", "default": "Our Credentials" },
    { "type": "text", "id": "mobile_title", "label": "Mobile title", "default": "Our Credentials" },
    { "type": "richtext", "id": "desktop_description", "label": "Desktop description", "default": "<p>Kerala Ayurveda has carried forward classical Ayurvedic wisdom for modern wellness rituals.</p>" },
    { "type": "richtext", "id": "mobile_description", "label": "Mobile description", "default": "<p>Kerala Ayurveda has carried forward classical Ayurvedic wisdom for modern wellness rituals.</p>" },
    { "type": "text", "id": "desktop_kicker", "label": "Desktop kicker", "default": "Globally Recognized" },
    { "type": "text", "id": "mobile_kicker", "label": "Mobile kicker", "default": "Globally Recognized" },
    { "type": "text", "id": "desktop_title_2", "label": "Desktop secondary title", "default": "Patented Formulations" },
    { "type": "text", "id": "mobile_title_2", "label": "Mobile secondary title", "default": "Patented Formulations" },
    { "type": "richtext", "id": "desktop_description_2", "label": "Desktop secondary description", "default": "<p>Kerala Ayurveda has carried forward classical Ayurvedic wisdom for modern wellness rituals.</p>" },
    { "type": "richtext", "id": "mobile_description_2", "label": "Mobile secondary description", "default": "<p>Kerala Ayurveda has carried forward classical Ayurvedic wisdom for modern wellness rituals.</p>" },
    { "type": "text", "id": "mark_kicker", "label": "Mark kicker", "default": "Certified" },
    { "type": "text", "id": "mark_heading", "label": "Mark heading", "default": "ka" },
    { "type": "richtext", "id": "mark_text", "label": "Mark text", "default": "<p>Rooted in Authentic Ayurveda.</p>" },
    { "type": "image_picker", "id": "seal_image", "label": "Seal image" }
  ],
  "presets": [{ "name": "brand trust" }]
}
{% endschema %}
