{{ 'section-brand-trust.css' | asset_url | stylesheet_tag }}

{%- assign desktop_title = section.settings.heading
  | default: section.settings.desktop_title
  | default: 'Full Spectrum'
-%}
{%- assign mobile_title = section.settings.heading
  | default: section.settings.mobile_title
  | default: 'Full Spectrum'
-%}
{%- assign desktop_description = section.settings.text
  | default: '<p>Classical and Proprietary Ayurvedic Products (350+ SKUs) | Therapies and Ayurvedic Retreats | Academy and Education Initiatives | Pioneering Ayurvedic R&amp;D</p>'
-%}
{%- assign mobile_description = section.settings.text
  | default: '<p>Classical and Proprietary Ayurvedic Products (350+ SKUs) | Therapies and Ayurvedic Retreats | Academy and Education Initiatives | Pioneering Ayurvedic R&amp;D</p>'
-%}
{%- assign desktop_kicker = section.settings.patents_kicker | default: 'Globally Recognized' -%}
{%- assign mobile_kicker = section.settings.mobile_kicker | default: 'Globally Recognized' -%}
{%- assign desktop_title_2 = section.settings.patents_heading | default: 'PATENTED FORMULATIONS' -%}
{%- assign mobile_title_2 = section.settings.mobile_title_2 | default: 'PATENTED FORMULATIONS' -%}
{%- assign desktop_description_2 = section.settings.patents_text
  | default: '<p>Kerala Ayurveda has carried forward classical Ayurvedic wisdom for modern wellness rituals.</p>'
-%}
{%- assign mobile_description_2 = section.settings.mobile_description_2
  | default: '<p>Kerala Ayurveda has carried forward classical Ayurvedic wisdom for modern wellness rituals.</p>'
-%}
{%- comment -%} Patents removed per Figma — do not render patent images/text here {%- endcomment -%}
{%- assign seal_kicker = section.settings.mark_kicker -%}
{%- assign seal_title = section.settings.mark_heading
  | default: section.settings.seal_text
  | default: 'Rooted in Authentic Ayurveda.'
-%}
{%- assign seal_text = section.settings.mark_text | default: '<p>Rooted in<br>Authentic Ayurveda.</p>' -%}
{%- assign desktop_image = section.settings.desktop_image -%}
{%- assign mobile_image = section.settings.mobile_image -%}
{%- assign seal_image = section.settings.seal_image -%}
{%- assign show_brand_trust = true -%}

{%- if show_brand_trust -%}
  <section class="theme-brand-trust-section theme-reveal">
    <!-- MOBILE VIEW (lg:hidden) -->
    <div class="theme-brand-trust__mobile lg:hidden">
      {%- if mobile_image != blank -%}
        <div class="theme-brand-trust__mobile-img-wrap">
          {{
            mobile_image
            | image_url: width: 900
            | image_tag: class: 'theme-brand-trust__mobile-img', loading: 'lazy', alt: mobile_title
          }}
        </div>
      {%- else -%}
        <div class="theme-brand-trust__mobile-img-wrap">
          <img
            src="{{ 'Flower.png' | asset_url }}"
            class="theme-brand-trust__mobile-img"
            width="1024"
            height="1024"
            loading="lazy"
            alt="{{ mobile_title | escape }}"
          >
        </div>
      {%- endif -%}

      <div class="theme-brand-trust__mobile-content">
        {%- if mobile_title != blank -%}
          <div class="theme-brand-trust__mobile-title">{{ mobile_title }}</div>
        {%- endif -%}
        {%- if mobile_description != blank -%}
          <div class="theme-brand-trust__mobile-desc">{{ mobile_description }}</div>
        {%- endif -%}

        {%- if mobile_title_2 != blank or mobile_description_2 != blank -%}
          <div class="theme-brand-trust__mobile-divider"></div>
        {%- endif -%}

        {%- if mobile_kicker != blank -%}
          <div class="theme-brand-trust__mobile-kicker">{{ mobile_kicker }}</div>
        {%- endif -%}
        {%- if mobile_title_2 != blank -%}
          <div class="theme-brand-trust__mobile-title theme-brand-trust__mobile-patents-title">
            {{ mobile_title_2 }}
          </div>
        {%- endif -%}
        {%- if mobile_description_2 != blank -%}
          <div class="theme-brand-trust__mobile-desc">{{ mobile_description_2 }}</div>
        {%- endif -%}

        {%- comment -%} Patents removed. No patent cards rendered for mobile. {%- endcomment -%}

        {%- if section.settings.seal_image != blank
          or seal_kicker != blank
          or seal_title != blank
          or seal_text != blank
        -%}
          <div class="theme-brand-trust__mobile-seal-container">
            {%- if section.settings.seal_image != blank -%}
              <div class="theme-brand-trust__mobile-seal-img-wrap">
                {%- if seal_image != blank -%}
                  {{
                    seal_image
                    | image_url: width: 240
                    | image_tag: class: 'theme-brand-trust__mobile-seal-img', loading: 'lazy', alt: seal_title
                  }}
                {%- else -%}
                  <img
                    src="{{ 'ka-mark.png' | asset_url }}"
                    class="theme-brand-trust__mobile-seal-img"
                    width="238"
                    height="328"
                    loading="lazy"
                    alt="{{ seal_title | escape }}"
                  >
                {%- endif -%}
              </div>
            {%- endif -%}
            {%- if seal_kicker != blank -%}
              <div class="theme-brand-trust__mobile-seal-kicker">{{ seal_kicker }}</div>
            {%- endif -%}
            {%- if seal_title != blank -%}
              <div class="theme-brand-trust__mobile-seal-title">{{ seal_title }}</div>
            {%- endif -%}
            {%- if seal_text != blank -%}
              <div class="theme-brand-trust__mobile-seal-text-wrap">
                <div class="theme-brand-trust__mobile-seal-text">{{ seal_text }}</div>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    <!-- DESKTOP VIEW (hidden lg:grid) -->
    <div class="container-narrow theme-brand-trust__desktop hidden lg:grid">
      {%- if desktop_image != blank -%}
        <div class="theme-brand-trust__desktop-img-wrap">
          {{
            desktop_image
            | image_url: width: 1200
            | image_tag: class: 'theme-brand-trust__desktop-img', loading: 'lazy', alt: desktop_title
          }}
        </div>
      {%- else -%}
        <div class="theme-brand-trust__desktop-img-wrap">
          <img
            src="{{ 'Flower.png' | asset_url }}"
            class="theme-brand-trust__desktop-img"
            width="1024"
            height="1024"
            loading="lazy"
            alt="{{ desktop_title | escape }}"
          >
        </div>
      {%- endif -%}

      <div class="theme-brand-trust__desktop-content">
        {%- if desktop_title != blank -%}
          <div class="theme-brand-trust__desktop-title">{{ desktop_title }}</div>
        {%- endif -%}
        {%- if desktop_description != blank -%}
          <div class="theme-brand-trust__desktop-desc">{{ desktop_description }}</div>
        {%- endif -%}

        {%- if desktop_title_2 != blank or desktop_description_2 != blank -%}
          <div class="theme-brand-trust__desktop-divider"></div>
        {%- endif -%}

        {%- if desktop_kicker != blank -%}
          <div class="theme-brand-trust__desktop-kicker">{{ desktop_kicker }}</div>
        {%- endif -%}
        {%- if desktop_title_2 != blank -%}
          <div class="theme-brand-trust__desktop-title">{{ desktop_title_2 }}</div>
        {%- endif -%}
        {%- if desktop_description_2 != blank -%}
          <div class="theme-brand-trust__desktop-desc">{{ desktop_description_2 }}</div>
        {%- endif -%}

        {%- comment -%} Patents removed. No patent cards rendered for desktop. {%- endcomment -%}
      </div>

      {%- if section.settings.seal_image != blank
        or seal_kicker != blank
        or seal_title != blank
        or seal_text != blank
      -%}
        <div class="theme-brand-trust__desktop-seal-container">
          {%- if seal_image != blank -%}
            {{
              seal_image
              | image_url: width: 220
              | image_tag: class: 'theme-brand-trust__desktop-seal-img', loading: 'lazy', alt: seal_title
            }}
          {%- else -%}
            <img
              src="{{ 'ka-mark.png' | asset_url }}"
              class="theme-brand-trust__desktop-seal-img"
              width="238"
              height="328"
              loading="lazy"
              alt="{{ seal_title | escape }}"
            >
          {%- endif -%}
          {%- if seal_kicker != blank -%}
            <div class="theme-brand-trust__desktop-seal-kicker">{{ seal_kicker }}</div>
          {%- endif -%}
          {%- if seal_title != blank -%}
            <div class="theme-brand-trust__desktop-seal-title">{{ seal_title }}</div>
          {%- endif -%}
          {%- if seal_text != blank -%}
            <div class="theme-brand-trust__desktop-seal-text">{{ seal_text }}</div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "brand trust",
  "tag": "section",
  "class": "section theme-brand-trust",
  "settings": [
    { "type": "image_picker", "id": "desktop_image", "label": "Desktop image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    { "type": "text", "id": "desktop_title", "label": "Desktop title", "default": "Brand trust" },
    { "type": "text", "id": "mobile_title", "label": "Mobile title", "default": "Brand trust" },
    { "type": "richtext", "id": "desktop_description", "label": "Desktop description", "default": "<p></p>" },
    { "type": "richtext", "id": "mobile_description", "label": "Mobile description", "default": "<p></p>" },
    { "type": "text", "id": "desktop_kicker", "label": "Desktop kicker", "default": "Trusted by experts" },
    { "type": "text", "id": "mobile_kicker", "label": "Mobile kicker", "default": "Trusted" },
    { "type": "text", "id": "desktop_title_2", "label": "Desktop secondary title", "default": "Patents & Recognition" },
    { "type": "text", "id": "mobile_title_2", "label": "Mobile secondary title", "default": "Patents" },
    {
      "type": "richtext",
      "id": "desktop_description_2",
      "label": "Desktop secondary description",
      "default": "<p></p>"
    },
    { "type": "richtext", "id": "mobile_description_2", "label": "Mobile secondary description", "default": "<p></p>" },
    { "type": "text", "id": "heading", "label": "Main heading", "default": "Our credentials" },
    { "type": "richtext", "id": "text", "label": "Main text", "default": "<p></p>" },
    { "type": "text", "id": "mark_kicker", "label": "Mark kicker", "default": "Certified" },
    { "type": "text", "id": "mark_heading", "label": "Mark heading", "default": "Quality seal" },
    { "type": "richtext", "id": "mark_text", "label": "Mark text", "default": "<p></p>" },
    { "type": "image_picker", "id": "seal_image", "label": "Seal image" },
    { "type": "text", "id": "seal_text", "label": "Seal text", "default": "Rooted in\nAuthentic Ayurveda." }
  ],
  "presets": [
    {
      "name": "brand trust"
    }
  ]
}
{% endschema %}
