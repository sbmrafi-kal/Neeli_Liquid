{{ 'section-theme-product-page.css' | asset_url | stylesheet_tag }}
{{ 'section-brand-trust.css' | asset_url | stylesheet_tag }}

<section class="theme-brand-trust-section theme-reveal">

  <!-- MOBILE VIEW (lg:hidden) -->
  <div class="theme-brand-trust__mobile lg:hidden">
    <div class="theme-brand-trust__mobile-img-wrap">
      <img src="{{ 'Flower.png' | asset_url }}" alt="Bringaraj herb" class="theme-brand-trust__mobile-img" loading="lazy">
    </div>

    <div class="theme-brand-trust__mobile-content">
      <div class="theme-brand-trust__mobile-title">Full Spectrum</div>
      <p class="theme-brand-trust__mobile-desc">
        Classical and Proprietary Ayurvedic Products (350+ SKUs) | Therapies and Ayurvedic Retreats | Academy and Education Initiatives | Pioneering Ayurvedic R&amp;D
      </p>

      <div class="theme-brand-trust__mobile-divider"></div>

      <div class="theme-brand-trust__mobile-kicker">Internationally Recognized</div>
      <div class="theme-brand-trust__mobile-title theme-brand-trust__mobile-patents-title">Patented Formulations</div>
      <p class="theme-brand-trust__mobile-desc">
        Kerala Ayurveda has carried forward classical Ayurvedic wisdom for modern wellness rituals.
      </p>

      <div class="theme-brand-trust__mobile-patent-container">
        <div class="motion-panel theme-brand-trust__mobile-patent-card">
          <img src="{{ 'US_Flag.png' | asset_url }}" alt="US Patent" class="theme-brand-trust__mobile-flag" loading="lazy">
          <div class="theme-brand-trust__mobile-patent-title">US PATENT</div>
        </div>
        <div class="motion-panel theme-brand-trust__mobile-patent-card">
          <img src="{{ 'Japan_Flag.png' | asset_url }}" alt="Japan Patent" class="theme-brand-trust__mobile-flag" loading="lazy">
          <div class="theme-brand-trust__mobile-patent-title">JAPAN PATENT</div>
        </div>
      </div>

      <div class="theme-brand-trust__mobile-seal-container">
        <div class="theme-brand-trust__mobile-seal-img-wrap">
          <img src="{{ 'ka-mark.png' | asset_url }}" alt="Kerala Ayurveda mark" class="theme-brand-trust__mobile-seal-img" loading="lazy">
        </div>
        <div class="theme-brand-trust__mobile-seal-text-wrap">
          <p class="theme-brand-trust__mobile-seal-text">
            Rooted in<br>Authentic Ayurveda.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- DESKTOP VIEW (hidden lg:grid) -->
  <div class="container-narrow theme-brand-trust__desktop hidden lg:grid">
    <div class="theme-brand-trust__desktop-img-wrap">
      <img src="{{ 'Flower.png' | asset_url }}" alt="Bringaraj herb" class="theme-brand-trust__desktop-img" loading="lazy">
    </div>

    <div class="theme-brand-trust__desktop-content">
      <div class="theme-brand-trust__desktop-title">Full Spectrum</div>
      <p class="theme-brand-trust__desktop-desc">
        Classical and Proprietary Ayurvedic Products (350+ SKUs) | Therapies and Ayurvedic Retreats | Academy and Education Initiatives | Pioneering Ayurvedic R&amp;D
      </p>

      <div class="theme-brand-trust__desktop-divider"></div>

      <div class="theme-brand-trust__desktop-title">Patented Formulations</div>
      <p class="theme-brand-trust__desktop-desc">
        Kerala Ayurveda has carried forward classical Ayurvedic wisdom for modern wellness rituals.
      </p>

      <div class="theme-brand-trust__desktop-patent-container">
        <div class="motion-panel theme-brand-trust__desktop-patent-card">
          <img src="{{ 'US_Flag.png' | asset_url }}" alt="US Patent" class="theme-brand-trust__desktop-flag" loading="lazy">
          <div class="theme-brand-trust__desktop-patent-title">US PATENT</div>
        </div>
        <div class="motion-panel theme-brand-trust__desktop-patent-card">
          <img src="{{ 'Japan_Flag.png' | asset_url }}" alt="Japan Patent" class="theme-brand-trust__desktop-flag" loading="lazy">
          <div class="theme-brand-trust__desktop-patent-title">JAPAN PATENT</div>
        </div>
      </div>
    </div>

    <div class="theme-brand-trust__desktop-seal-container">
      <img src="{{ 'ka-mark.png' | asset_url }}" alt="Kerala Ayurveda mark" class="theme-brand-trust__desktop-seal-img" loading="lazy">
      <p class="theme-brand-trust__desktop-seal-text">
        Rooted in<br>Authentic Ayurveda.
      </p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "brand trust",
  "tag": "section",
  "class": "section theme-brand-trust",
  "settings": [],
  "presets": [
    {
      "name": "brand trust"
    }
  ]
}
{% endschema %}
