{{ 'section-theme-product-page.css' | asset_url | stylesheet_tag }}
{{ 'section-brand-trust.css' | asset_url | stylesheet_tag }}

{%- assign show_brand_trust = section.settings.mobile_title != blank
  or section.settings.desktop_title != blank
  or section.settings.mobile_image != blank
  or section.settings.desktop_image != blank
-%}

{%- if show_brand_trust -%}
<section class="theme-brand-trust-section theme-reveal">
  <!-- MOBILE VIEW (lg:hidden) -->
  <div class="theme-brand-trust__mobile lg:hidden">
    {%- if section.settings.mobile_image != blank -%}
      <div class="theme-brand-trust__mobile-img-wrap">
        {{ section.settings.mobile_image | image_url: width: 900 | image_tag: class: 'theme-brand-trust__mobile-img', loading: 'lazy', alt: section.settings.mobile_title }}
      </div>
    {%- endif -%}

    <div class="theme-brand-trust__mobile-content">
      {%- if section.settings.mobile_title != blank -%}
        <div class="theme-brand-trust__mobile-title">{{ section.settings.mobile_title }}</div>
      {%- endif -%}
      {%- if section.settings.mobile_description != blank -%}
        <div class="theme-brand-trust__mobile-desc">{{ section.settings.mobile_description }}</div>
      {%- endif -%}

      {%- if section.settings.mobile_title_2 != blank or section.settings.mobile_description_2 != blank or section.settings.patent_1_image != blank or section.settings.patent_2_image != blank -%}
        <div class="theme-brand-trust__mobile-divider"></div>
      {%- endif -%}

      {%- if section.settings.mobile_kicker != blank -%}
        <div class="theme-brand-trust__mobile-kicker">{{ section.settings.mobile_kicker }}</div>
      {%- endif -%}
      {%- if section.settings.mobile_title_2 != blank -%}
        <div class="theme-brand-trust__mobile-title theme-brand-trust__mobile-patents-title">{{ section.settings.mobile_title_2 }}</div>
      {%- endif -%}
      {%- if section.settings.mobile_description_2 != blank -%}
        <div class="theme-brand-trust__mobile-desc">{{ section.settings.mobile_description_2 }}</div>
      {%- endif -%}

      {%- if section.settings.patent_1_image != blank or section.settings.patent_2_image != blank -%}
        <div class="theme-brand-trust__mobile-patent-container">
          {%- if section.settings.patent_1_image != blank -%}
            <div class="motion-panel theme-brand-trust__mobile-patent-card">
              {{ section.settings.patent_1_image | image_url: width: 120 | image_tag: class: 'theme-brand-trust__mobile-flag', loading: 'lazy', alt: section.settings.patent_1_title }}
              {%- if section.settings.patent_1_title != blank -%}
                <div class="theme-brand-trust__mobile-patent-title">{{ section.settings.patent_1_title }}</div>
              {%- endif -%}
            </div>
          {%- endif -%}
          {%- if section.settings.patent_2_image != blank -%}
            <div class="motion-panel theme-brand-trust__mobile-patent-card">
              {{ section.settings.patent_2_image | image_url: width: 120 | image_tag: class: 'theme-brand-trust__mobile-flag', loading: 'lazy', alt: section.settings.patent_2_title }}
              {%- if section.settings.patent_2_title != blank -%}
                <div class="theme-brand-trust__mobile-patent-title">{{ section.settings.patent_2_title }}</div>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.seal_image != blank or section.settings.seal_text != blank -%}
        <div class="theme-brand-trust__mobile-seal-container">
          {%- if section.settings.seal_image != blank -%}
            <div class="theme-brand-trust__mobile-seal-img-wrap">
              {{ section.settings.seal_image | image_url: width: 240 | image_tag: class: 'theme-brand-trust__mobile-seal-img', loading: 'lazy', alt: section.settings.seal_text }}
            </div>
          {%- endif -%}
          {%- if section.settings.seal_text != blank -%}
            <div class="theme-brand-trust__mobile-seal-text-wrap">
              <p class="theme-brand-trust__mobile-seal-text">{{ section.settings.seal_text | newline_to_br }}</p>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>

  <!-- DESKTOP VIEW (hidden lg:grid) -->
  <div class="container-narrow theme-brand-trust__desktop hidden lg:grid">
    {%- if section.settings.desktop_image != blank -%}
      <div class="theme-brand-trust__desktop-img-wrap">
        {{ section.settings.desktop_image | image_url: width: 1200 | image_tag: class: 'theme-brand-trust__desktop-img', loading: 'lazy', alt: section.settings.desktop_title }}
      </div>
    {%- endif -%}

    <div class="theme-brand-trust__desktop-content">
      {%- if section.settings.desktop_title != blank -%}
        <div class="theme-brand-trust__desktop-title">{{ section.settings.desktop_title }}</div>
      {%- endif -%}
      {%- if section.settings.desktop_description != blank -%}
        <div class="theme-brand-trust__desktop-desc">{{ section.settings.desktop_description }}</div>
      {%- endif -%}

      {%- if section.settings.desktop_title_2 != blank or section.settings.desktop_description_2 != blank or section.settings.patent_1_image != blank or section.settings.patent_2_image != blank -%}
        <div class="theme-brand-trust__desktop-divider"></div>
      {%- endif -%}

      {%- if section.settings.desktop_kicker != blank -%}
        <div class="theme-brand-trust__desktop-kicker">{{ section.settings.desktop_kicker }}</div>
      {%- endif -%}
      {%- if section.settings.desktop_title_2 != blank -%}
        <div class="theme-brand-trust__desktop-title">{{ section.settings.desktop_title_2 }}</div>
      {%- endif -%}
      {%- if section.settings.desktop_description_2 != blank -%}
        <div class="theme-brand-trust__desktop-desc">{{ section.settings.desktop_description_2 }}</div>
      {%- endif -%}

      {%- if section.settings.patent_1_image != blank or section.settings.patent_2_image != blank -%}
        <div class="theme-brand-trust__desktop-patent-container">
          {%- if section.settings.patent_1_image != blank -%}
            <div class="motion-panel theme-brand-trust__desktop-patent-card">
              {{ section.settings.patent_1_image | image_url: width: 160 | image_tag: class: 'theme-brand-trust__desktop-flag', loading: 'lazy', alt: section.settings.patent_1_title }}
              {%- if section.settings.patent_1_title != blank -%}
                <div class="theme-brand-trust__desktop-patent-title">{{ section.settings.patent_1_title }}</div>
              {%- endif -%}
            </div>
          {%- endif -%}
          {%- if section.settings.patent_2_image != blank -%}
            <div class="motion-panel theme-brand-trust__desktop-patent-card">
              {{ section.settings.patent_2_image | image_url: width: 160 | image_tag: class: 'theme-brand-trust__desktop-flag', loading: 'lazy', alt: section.settings.patent_2_title }}
              {%- if section.settings.patent_2_title != blank -%}
                <div class="theme-brand-trust__desktop-patent-title">{{ section.settings.patent_2_title }}</div>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.seal_image != blank or section.settings.seal_text != blank -%}
      <div class="theme-brand-trust__desktop-seal-container">
        {%- if section.settings.seal_image != blank -%}
          {{ section.settings.seal_image | image_url: width: 220 | image_tag: class: 'theme-brand-trust__desktop-seal-img', loading: 'lazy', alt: section.settings.seal_text }}
        {%- endif -%}
        {%- if section.settings.seal_text != blank -%}
          <p class="theme-brand-trust__desktop-seal-text">{{ section.settings.seal_text | newline_to_br }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "brand trust",
  "tag": "section",
  "class": "section theme-brand-trust",
  "settings": [
    { "type": "image_picker", "id": "desktop_image", "label": "Desktop image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    { "type": "text", "id": "desktop_title", "label": "Desktop title", "default": "Full Spectrum" },
    { "type": "text", "id": "mobile_title", "label": "Mobile title", "default": "Full Spectrum" },
    { "type": "richtext", "id": "desktop_description", "label": "Desktop description", "default": "<p>Classical and proprietary Ayurvedic products, therapies, education, and R&amp;D.</p>" },
    { "type": "richtext", "id": "mobile_description", "label": "Mobile description", "default": "<p>Classical and proprietary Ayurvedic products, therapies, education, and R&amp;D.</p>" },
    { "type": "text", "id": "desktop_kicker", "label": "Desktop kicker", "default": "Globally Recognized" },
    { "type": "text", "id": "mobile_kicker", "label": "Mobile kicker", "default": "Globally Recognized" },
    { "type": "text", "id": "desktop_title_2", "label": "Desktop secondary title", "default": "Patented Formulations" },
    { "type": "text", "id": "mobile_title_2", "label": "Mobile secondary title", "default": "Patented Formulations" },
    { "type": "richtext", "id": "desktop_description_2", "label": "Desktop secondary description", "default": "<p>Kerala Ayurveda has carried forward classical Ayurvedic wisdom for modern wellness rituals.</p>" },
    { "type": "richtext", "id": "mobile_description_2", "label": "Mobile secondary description", "default": "<p>Kerala Ayurveda has carried forward classical Ayurvedic wisdom for modern wellness rituals.</p>" },
    { "type": "image_picker", "id": "patent_1_image", "label": "Patent image 1" },
    { "type": "text", "id": "patent_1_title", "label": "Patent title 1", "default": "US PATENT" },
    { "type": "image_picker", "id": "patent_2_image", "label": "Patent image 2" },
    { "type": "text", "id": "patent_2_title", "label": "Patent title 2", "default": "JAPAN PATENT" },
    { "type": "image_picker", "id": "seal_image", "label": "Seal image" },
    { "type": "text", "id": "seal_text", "label": "Seal text", "default": "Rooted in\nAuthentic Ayurveda." }
  ],
  "presets": [
    {
      "name": "brand trust"
    }
  ]
}
{% endschema %}
