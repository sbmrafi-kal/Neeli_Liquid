{{ 'section-footer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'footer.js' | asset_url }}" defer="defer"></script>

<footer class="theme-product-page__section theme-reveal section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="theme-product-page__wrap">
    {%- assign brand_block = section.blocks | where: 'type', 'brand' | first -%}
    {%- assign link_blocks = section.blocks | where: 'type', 'link_column' -%}
    {%- assign social_block = section.blocks | where: 'type', 'social' | first -%}
    {%- assign social_link_blocks = section.blocks | where: 'type', 'social_link' -%}
    {%- assign tagline_block = section.blocks | where: 'type', 'tagline' | first -%}

    <div class="theme-footer-grid">
      <!-- Brand column (block preferred, fallback to section setting) -->
      <div class="theme-footer-brand">
        {%- if brand_block != null and brand_block.settings.logo != blank -%}
          {{
            brand_block.settings.logo
            | image_url: width: 800
            | image_tag: class: 'theme-footer-brand__logo', loading: 'lazy', alt: brand_block.settings.logo.alt
          }}
        {%- elsif section.settings.logo_image != blank -%}
          {{
            section.settings.logo_image
            | image_url: width: 800
            | image_tag: class: 'theme-footer-brand__logo', loading: 'lazy', alt: section.settings.logo_alt
          }}
        {%- else -%}
          <span class="theme-footer-brand__text">{{ shop.name }}</span>
        {%- endif -%}
      </div>

      <!-- Link columns (render blocks if present, otherwise show sensible defaults) -->
      {%- for block in link_blocks -%}
        <div class="theme-footer-column" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h2 class="theme-footer-column__title">{{ block.settings.heading }}</h2>
          {%- endif -%}
          <ul class="theme-footer-list">
            {%- for item_index in (1..9) -%}
              {%- capture item_title_key -%}item_{{ item_index }}_title{%- endcapture -%}
              {%- capture item_link_key -%}item_{{ item_index }}_link{%- endcapture -%}
              {%- assign item_title = block.settings[item_title_key] -%}
              {%- assign item_link = block.settings[item_link_key] -%}
              {%- if item_title != blank -%}
                <li>
                  {%- if item_link != blank -%}
                    <a href="{{ item_link }}">{{ item_title }}</a>
                  {%- else -%}
                    <span>{{ item_title }}</span>
                  {%- endif -%}
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
      {%- endfor -%}
    </div>

    <!-- Social + Tagline (prefer add/remove social blocks, fallback to legacy social block) -->
    {%- assign has_social_icons = false -%}
    {%- if social_link_blocks.size > 0 -%}
      {%- assign has_social_icons = true -%}
    {%- elsif social_block != null -%}
      {%- if social_block.settings.facebook_link != blank
        or social_block.settings.twitter_link != blank
        or social_block.settings.instagram_link != blank
        or social_block.settings.youtube_link != blank
        or social_block.settings.linkedin_link != blank
      -%}
        {%- assign has_social_icons = true -%}
      {%- endif -%}
    {%- endif -%}

    <hr class="theme-footer-divider" style="margin: 32px 0 24px 0; border: 0; border-top: 1px solid rgba(31, 77, 61, 0.12); width: 100%;">

    {%- if has_social_icons -%}
      <div class="theme-footer-social-wrapper">
        <div class="theme-footer-social-empty"></div>
        <div class="theme-footer-social-content">
          {%- if social_link_blocks.size == 0 and social_block != null and social_block.settings.label != blank -%}
            {%- assign social_label = social_block.settings.label -%}
          {%- else -%}
            {%- assign social_label = section.settings.social_label -%}
          {%- endif -%}
          {%- if social_label != blank -%}
            <div class="theme-footer-social__label">{{ social_label }}</div>
          {%- endif -%}
          <div class="theme-footer-social__icons">
            {%- if social_link_blocks.size > 0 -%}
              {%- for block in social_link_blocks -%}
                {%- assign social_platform_label = 'Social link' -%}
                {%- case block.settings.platform -%}
                  {%- when 'facebook' -%}
                    {%- assign social_platform_label = 'Facebook' -%}
                  {%- when 'instagram' -%}
                    {%- assign social_platform_label = 'Instagram' -%}
                  {%- when 'youtube' -%}
                    {%- assign social_platform_label = 'YouTube' -%}
                  {%- when 'linkedin' -%}
                    {%- assign social_platform_label = 'LinkedIn' -%}
                  {%- when 'x' -%}
                    {%- assign social_platform_label = 'X / Twitter' -%}
                  {%- when 'twitter' -%}
                    {%- assign social_platform_label = 'X / Twitter' -%}
                {%- endcase -%}
                {%- if block.settings.link != blank -%}
                  <a
                    href="{{ block.settings.link }}"
                    aria-label="{{ social_platform_label }}"
                    class="theme-footer-social__icon footer-social"
                    target="_blank"
                    rel="noopener"
                    {{ block.shopify_attributes }}
                  >
                    {%- render 'social-icon', platform: block.settings.platform -%}
                  </a>
                {%- else -%}
                  <span
                    aria-label="{{ social_platform_label }}"
                    class="theme-footer-social__icon footer-social theme-footer-social__icon--static"
                    {{ block.shopify_attributes }}
                  >
                    {%- render 'social-icon', platform: block.settings.platform -%}
                  </span>
                {%- endif -%}
              {%- endfor -%}
            {%- elsif social_block != null -%}
              {%- if social_block.settings.facebook_link != blank -%}
                <a
                  href="{{ social_block.settings.facebook_link }}"
                  aria-label="Facebook"
                  class="theme-footer-social__icon footer-social"
                  target="_blank"
                  rel="noopener"
                >
                  {%- render 'social-icon', platform: 'facebook' -%}
                </a>
              {%- endif -%}
              {%- if social_block.settings.twitter_link != blank -%}
                <a
                  href="{{ social_block.settings.twitter_link }}"
                  aria-label="X"
                  class="theme-footer-social__icon footer-social"
                  target="_blank"
                  rel="noopener"
                >
                  {%- render 'social-icon', platform: 'x' -%}
                </a>
              {%- endif -%}
              {%- if social_block.settings.instagram_link != blank -%}
                <a
                  href="{{ social_block.settings.instagram_link }}"
                  aria-label="Instagram"
                  class="theme-footer-social__icon footer-social"
                  target="_blank"
                  rel="noopener"
                >
                  {%- render 'social-icon', platform: 'instagram' -%}
                </a>
              {%- endif -%}
              {%- if social_block.settings.youtube_link != blank -%}
                <a
                  href="{{ social_block.settings.youtube_link }}"
                  aria-label="YouTube"
                  class="theme-footer-social__icon footer-social"
                  target="_blank"
                  rel="noopener"
                >
                  {%- render 'social-icon', platform: 'youtube' -%}
                </a>
              {%- endif -%}
              {%- if social_block.settings.linkedin_link != blank -%}
                <a
                  href="{{ social_block.settings.linkedin_link }}"
                  aria-label="LinkedIn"
                  class="theme-footer-social__icon footer-social"
                  target="_blank"
                  rel="noopener"
                >
                  {%- render 'social-icon', platform: 'linkedin' -%}
                </a>
              {%- endif -%}
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endif -%}

    {%- if tagline_block != null and tagline_block.settings.text != blank -%}
      <div class="theme-footer-tagline-wrapper" {{ tagline_block.shopify_attributes }}>
        <div class="theme-footer-tagline-empty"></div>
        <div class="theme-footer-tagline-content">
          <p class="theme-footer-tagline-p">{{ tagline_block.settings.text | newline_to_br }}</p>
        </div>
      </div>
    {%- elsif section.settings.tagline != blank -%}
      <div class="theme-footer-tagline-wrapper">
        <div class="theme-footer-tagline-empty"></div>
        <div class="theme-footer-tagline-content">
          <p class="theme-footer-tagline-p">{{ section.settings.tagline | newline_to_br }}</p>
        </div>
      </div>
    {%- endif -%}

    <div class="theme-footer-decoration" aria-hidden="true">
      <img
        src="{{ 'footer-decoration.svg' | asset_url }}"
        class="theme-footer-decoration__svg"
        loading="lazy"
        alt=""
        width="1440"
        height="107"
      >
  </div>
</footer>

{% schema %}
{
  "name": "footer",
  "tag": "section",
  "class": "section theme-footer",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "text", "id": "social_label", "label": "Social label", "default": "Follow Us" },
    { "type": "image_picker", "id": "logo_image", "label": "Logo image" },
    { "type": "text", "id": "logo_alt", "label": "Logo alt text", "default": "Kerala Ayurveda" },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "The Proprietary Kerala Ayurveda Formulation.\nThis Is One Of Them."
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "default": 40, "label": "Top padding" },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "label": "Bottom padding"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [{ "type": "image_picker", "id": "logo", "label": "Logo" }]
    },
    {
      "type": "link_column",
      "name": "Link column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Quick Links" },
        { "type": "text", "id": "item_1_title", "label": "Item 1 title", "default": "About Kerala Ayurveda" },
        { "type": "url", "id": "item_1_link", "label": "Item 1 link" },
        { "type": "text", "id": "item_2_title", "label": "Item 2 title", "default": "Clinics" },
        { "type": "url", "id": "item_2_link", "label": "Item 2 link" },
        { "type": "text", "id": "item_3_title", "label": "Item 3 title", "default": "Ayurveda Academy" },
        { "type": "url", "id": "item_3_link", "label": "Item 3 link" },
        { "type": "text", "id": "item_4_title", "label": "Item 4 title", "default": "Investors" },
        { "type": "url", "id": "item_4_link", "label": "Item 4 link" },
        { "type": "text", "id": "item_5_title", "label": "Item 5 title", "default": "Research & Development" },
        { "type": "url", "id": "item_5_link", "label": "Item 5 link" },
        { "type": "text", "id": "item_6_title", "label": "Item 6 title", "default": "Careers" },
        { "type": "url", "id": "item_6_link", "label": "Item 6 link" },
        { "type": "text", "id": "item_7_title", "label": "Item 7 title", "default": "Blogs" },
        { "type": "url", "id": "item_7_link", "label": "Item 7 link" },
        { "type": "text", "id": "item_8_title", "label": "Item 8 title", "default": "Our Editorial Team" },
        { "type": "url", "id": "item_8_link", "label": "Item 8 link" },
        { "type": "text", "id": "item_9_title", "label": "Item 9 title" },
        { "type": "url", "id": "item_9_link", "label": "Item 9 link" }
      ]
    },
    {
      "type": "social",
      "name": "Legacy social links",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Follow Us" },
        { "type": "url", "id": "facebook_link", "label": "Facebook link" },
        { "type": "url", "id": "twitter_link", "label": "Twitter link" },
        { "type": "url", "id": "instagram_link", "label": "Instagram link" },
        { "type": "url", "id": "youtube_link", "label": "YouTube link" },
        { "type": "url", "id": "linkedin_link", "label": "LinkedIn link" }
      ]
    },
    {
      "type": "social_link",
      "name": "Social link",
      "settings": [
        {
          "type": "select",
          "id": "platform",
          "label": "Platform",
          "default": "facebook",
          "options": [
            { "value": "facebook", "label": "Facebook" },
            { "value": "instagram", "label": "Instagram" },
            { "value": "youtube", "label": "YouTube" },
            { "value": "linkedin", "label": "LinkedIn" },
            { "value": "x", "label": "X / Twitter" }
          ]
        },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    },
    {
      "type": "tagline",
      "name": "Tagline",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "The Proprietary Kerala Ayurveda Formulation.\nThis Is One Of Them."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "footer",
      "blocks": [
        { "type": "brand" },
        { "type": "link_column" },
        { "type": "link_column" },
        { "type": "link_column" },
        { "type": "social" },
        { "type": "tagline" }
      ]
    }
  ]
}
{% endschema %}
