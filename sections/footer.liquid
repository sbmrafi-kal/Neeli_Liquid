{{ 'section-theme-product-page.css' | asset_url | stylesheet_tag }}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'footer.js' | asset_url }}" defer="defer"></script>

<footer class="theme-product-page__section theme-reveal section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="theme-product-page__wrap">
    {%- if section.blocks.size > 0 -%}
      <div class="theme-footer-grid">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'brand' -%}
              <div class="theme-footer-brand" {{ block.shopify_attributes }}>
                {%- if block.settings.logo != blank -%}
                  {{
                    block.settings.logo
                    | image_url: width: 800
                    | image_tag: class: 'theme-footer-brand__logo', loading: 'lazy', alt: block.settings.logo.alt
                    | default: shop.name
                  }}
                {%- endif -%}
              </div>
            {%- when 'link_column' -%}
              <div class="theme-footer-column" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h2 class="theme-footer-column__title">{{ block.settings.heading }}</h2>
                {%- endif -%}
                <ul class="theme-footer-list">
                  {%- if block.settings.item_1_title != blank -%}
                    <li>
                      {%- if block.settings.item_1_link != blank -%}
                        <a href="{{ block.settings.item_1_link }}">{{ block.settings.item_1_title }}</a>
                      {%- else -%}
                        <span>{{ block.settings.item_1_title }}</span>
                      {%- endif -%}
                    </li>
                  {%- endif -%}
                  {%- if block.settings.item_2_title != blank -%}
                    <li>
                      {%- if block.settings.item_2_link != blank -%}
                        <a href="{{ block.settings.item_2_link }}">{{ block.settings.item_2_title }}</a>
                      {%- else -%}
                        <span>{{ block.settings.item_2_title }}</span>
                      {%- endif -%}
                    </li>
                  {%- endif -%}
                  {%- if block.settings.item_3_title != blank -%}
                    <li>
                      {%- if block.settings.item_3_link != blank -%}
                        <a href="{{ block.settings.item_3_link }}">{{ block.settings.item_3_title }}</a>
                      {%- else -%}
                        <span>{{ block.settings.item_3_title }}</span>
                      {%- endif -%}
                    </li>
                  {%- endif -%}
                  {%- if block.settings.item_4_title != blank -%}
                    <li>
                      {%- if block.settings.item_4_link != blank -%}
                        <a href="{{ block.settings.item_4_link }}">{{ block.settings.item_4_title }}</a>
                      {%- else -%}
                        <span>{{ block.settings.item_4_title }}</span>
                      {%- endif -%}
                    </li>
                  {%- endif -%}
                  {%- if block.settings.item_5_title != blank -%}
                    <li>
                      {%- if block.settings.item_5_link != blank -%}
                        <a href="{{ block.settings.item_5_link }}">{{ block.settings.item_5_title }}</a>
                      {%- else -%}
                        <span>{{ block.settings.item_5_title }}</span>
                      {%- endif -%}
                    </li>
                  {%- endif -%}
                  {%- if block.settings.item_6_title != blank -%}
                    <li>
                      {%- if block.settings.item_6_link != blank -%}
                        <a href="{{ block.settings.item_6_link }}">{{ block.settings.item_6_title }}</a>
                      {%- else -%}
                        <span>{{ block.settings.item_6_title }}</span>
                      {%- endif -%}
                    </li>
                  {%- endif -%}
                  {%- if block.settings.item_7_title != blank -%}
                    <li>
                      {%- if block.settings.item_7_link != blank -%}
                        <a href="{{ block.settings.item_7_link }}">{{ block.settings.item_7_title }}</a>
                      {%- else -%}
                        <span>{{ block.settings.item_7_title }}</span>
                      {%- endif -%}
                    </li>
                  {%- endif -%}
                  {%- if block.settings.item_8_title != blank -%}
                    <li>
                      {%- if block.settings.item_8_link != blank -%}
                        <a href="{{ block.settings.item_8_link }}">{{ block.settings.item_8_title }}</a>
                      {%- else -%}
                        <span>{{ block.settings.item_8_title }}</span>
                      {%- endif -%}
                    </li>
                  {%- endif -%}
                </ul>
              </div>
            {%- when 'social' -%}
              <div class="theme-footer-social-wrapper" {{ block.shopify_attributes }}>
                <div class="theme-footer-social-empty"></div>
                <div class="theme-footer-social-content">
                  {%- if block.settings.label != blank -%}
                    <div class="theme-footer-social__label">{{ block.settings.label }}</div>
                  {%- endif -%}
                  <div class="theme-footer-social__icons">
                    {%- assign facebook_link = block.settings.facebook_link
                      | default: section.settings.facebook_link
                      | default: settings.social_facebook_link
                    -%}
                    {%- assign twitter_link = block.settings.twitter_link
                      | default: section.settings.twitter_link
                      | default: settings.social_twitter_link
                    -%}
                    {%- assign instagram_link = block.settings.instagram_link
                      | default: section.settings.instagram_link
                      | default: settings.social_instagram_link
                    -%}
                    {%- assign youtube_link = block.settings.youtube_link
                      | default: section.settings.youtube_link
                      | default: settings.social_youtube_link
                    -%}
                    {%- assign linkedin_link = block.settings.linkedin_link
                      | default: section.settings.linkedin_link
                      | default: settings.social_linkedin_link
                    -%}

                    {%- if facebook_link != blank -%}
                      <a
                        href="{{ facebook_link }}"
                        aria-label="Facebook"
                        class="theme-footer-social__icon footer-social"
                        target="_blank"
                        rel="noopener"
                      >
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                          <path d="M14 8h3V4h-3c-3 0-5 2-5 5v3H6v4h3v4h4v-4h3l1-4h-4V9c0-.6.4-1 1-1Z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      </a>
                    {%- endif -%}
                    {%- if twitter_link != blank -%}
                      <a
                        href="{{ twitter_link }}"
                        aria-label="X"
                        class="theme-footer-social__icon footer-social"
                        target="_blank"
                        rel="noopener"
                      >
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                          <path d="M5 4l14 16M19 4 5 20" stroke-width="1.5" stroke-linecap="round" />
                        </svg>
                      </a>
                    {%- endif -%}
                    {%- if instagram_link != blank -%}
                      <a
                        href="{{ instagram_link }}"
                        aria-label="Instagram"
                        class="theme-footer-social__icon footer-social"
                        target="_blank"
                        rel="noopener"
                      >
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                          <rect x="4" y="4" width="16" height="16" rx="4" stroke-width="1.5" /><circle cx="12" cy="12" r="3.5" stroke-width="1.5" /><circle cx="17.4" cy="6.6" r="0.8" fill="currentColor" stroke="none" />
                        </svg>
                      </a>
                    {%- endif -%}
                    {%- if youtube_link != blank -%}
                      <a
                        href="{{ youtube_link }}"
                        aria-label="YouTube"
                        class="theme-footer-social__icon footer-social"
                        target="_blank"
                        rel="noopener"
                      >
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                          <rect x="3.5" y="6.5" width="17" height="11" rx="3" stroke-width="1.5" /><path d="M10 9.5 15 12l-5 2.5v-5Z" fill="currentColor" stroke="none" />
                        </svg>
                      </a>
                    {%- endif -%}
                    {%- if linkedin_link != blank -%}
                      <a
                        href="{{ linkedin_link }}"
                        aria-label="LinkedIn"
                        class="theme-footer-social__icon footer-social"
                        target="_blank"
                        rel="noopener"
                      >
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                          <path d="M6.5 9.5v8M6.5 6.5h.01M11 17.5v-5.2c0-1.4 1.1-2.5 2.5-2.5S16 10.9 16 12.3v5.2M11 11V9.5M6 9.5h1M16 17.5h1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /><rect x="4" y="4" width="16" height="16" rx="2.5" stroke-width="1.5" />
                        </svg>
                      </a>
                    {%- endif -%}
                  </div>
                </div>
              </div>
            {%- when 'tagline' -%}
              {%- if block.settings.text != blank -%}
                <div class="theme-footer-tagline-wrapper" {{ block.shopify_attributes }}>
                  <div class="theme-footer-tagline-empty"></div>
                  <div class="theme-footer-tagline-content">
                    <p class="theme-footer-tagline-p">{{ block.settings.text | newline_to_br }}</p>
                  </div>
                </div>
              {%- endif -%}
          {%- endcase -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="theme-footer-grid">
        <div class="theme-footer-brand">
          {%- if section.settings.logo_image != blank -%}
            {{
              section.settings.logo_image
              | image_url: width: 800
              | image_tag: class: 'theme-footer-brand__logo', loading: 'lazy', alt: section.settings.logo_alt
            }}
          {%- endif -%}
        </div>
      </div>

      <div class="theme-footer-social-wrapper">
        <div class="theme-footer-social-empty"></div>
        <div class="theme-footer-social-content">
          <div class="theme-footer-social__label">{{ section.settings.social_label }}</div>
          <div class="theme-footer-social__icons">
            {%- assign facebook_link = section.settings.facebook_link | default: settings.social_facebook_link -%}
            {%- assign twitter_link = section.settings.twitter_link | default: settings.social_twitter_link -%}
            {%- assign instagram_link = section.settings.instagram_link | default: settings.social_instagram_link -%}
            {%- assign youtube_link = section.settings.youtube_link | default: settings.social_youtube_link -%}
            {%- assign linkedin_link = section.settings.linkedin_link | default: settings.social_linkedin_link -%}
            {%- if facebook_link != blank -%}
              <a
                href="{{ facebook_link }}"
                aria-label="Facebook"
                class="theme-footer-social__icon footer-social"
                target="_blank"
                rel="noopener"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                  <path d="M14 8h3V4h-3c-3 0-5 2-5 5v3H6v4h3v4h4v-4h3l1-4h-4V9c0-.6.4-1 1-1Z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            {%- endif -%}
            {%- if twitter_link != blank -%}
              <a
                href="{{ twitter_link }}"
                aria-label="X"
                class="theme-footer-social__icon footer-social"
                target="_blank"
                rel="noopener"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                  <path d="M5 4l14 16M19 4 5 20" stroke-width="1.5" stroke-linecap="round" />
                </svg>
              </a>
            {%- endif -%}
            {%- if instagram_link != blank -%}
              <a
                href="{{ instagram_link }}"
                aria-label="Instagram"
                class="theme-footer-social__icon footer-social"
                target="_blank"
                rel="noopener"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                  <rect x="4" y="4" width="16" height="16" rx="4" stroke-width="1.5" /><circle cx="12" cy="12" r="3.5" stroke-width="1.5" /><circle cx="17.4" cy="6.6" r="0.8" fill="currentColor" stroke="none" />
                </svg>
              </a>
            {%- endif -%}
            {%- if youtube_link != blank -%}
              <a
                href="{{ youtube_link }}"
                aria-label="YouTube"
                class="theme-footer-social__icon footer-social"
                target="_blank"
                rel="noopener"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                  <rect x="3.5" y="6.5" width="17" height="11" rx="3" stroke-width="1.5" /><path d="M10 9.5 15 12l-5 2.5v-5Z" fill="currentColor" stroke="none" />
                </svg>
              </a>
            {%- endif -%}
            {%- if linkedin_link != blank -%}
              <a
                href="{{ linkedin_link }}"
                aria-label="LinkedIn"
                class="theme-footer-social__icon footer-social"
                target="_blank"
                rel="noopener"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                  <path d="M6.5 9.5v8M6.5 6.5h.01M11 17.5v-5.2c0-1.4 1.1-2.5 2.5-2.5S16 10.9 16 12.3v5.2M11 11V9.5M6 9.5h1M16 17.5h1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /><rect x="4" y="4" width="16" height="16" rx="2.5" stroke-width="1.5" />
                </svg>
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>

      {%- if section.settings.tagline != blank -%}
        <div class="theme-footer-tagline-wrapper">
          <div class="theme-footer-tagline-empty"></div>
          <div class="theme-footer-tagline-content">
            <p class="theme-footer-tagline-p">{{ section.settings.tagline | newline_to_br }}</p>
          </div>
        </div>
      {%- endif -%}

      <div class="theme-footer-decoration" aria-hidden="true">
        <svg class="theme-footer-decoration__svg" viewBox="0 0 1440 108" preserveAspectRatio="none" role="presentation" focusable="false">
          <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 82c18-18 33-30 51-39M50 100c18-12 32-26 44-41M91 78c13-18 27-32 44-43M130 96c9-19 21-35 39-49M170 83c16-16 30-28 49-39M214 99c16-14 29-30 42-46M255 76c12-17 25-31 41-43M294 92c11-18 22-33 39-48M336 79c16-15 31-27 48-38M379 98c16-13 31-28 43-45M420 80c14-17 28-31 44-42M462 94c10-18 22-34 40-47M506 81c15-16 29-28 48-39M551 96c15-14 29-30 43-46M594 78c12-17 26-31 42-43M636 92c11-18 22-34 40-48M679 80c15-16 29-28 47-39M724 95c15-14 28-30 43-45M766 78c12-17 25-31 42-43M808 92c11-18 23-34 40-47M852 80c15-16 29-28 47-39M897 95c15-14 29-30 43-46M940 78c12-17 25-31 42-43M982 92c11-18 22-34 40-48M1026 80c15-16 29-28 47-39M1071 95c15-14 29-30 43-46M1114 78c12-17 25-31 42-43M1156 92c11-18 22-34 40-48M1200 80c15-16 29-28 47-39M1245 95c15-14 29-30 43-46M1288 78c12-17 25-31 42-43M1330 92c11-18 23-34 40-47M1374 80c15-16 29-28 47-39" stroke-width="1.2"/>
            <path d="M32 74c4-10 9-18 18-26M74 92c4-10 10-19 18-26M113 66c4-10 10-18 18-26M154 88c4-10 10-19 18-26M194 73c4-10 10-18 18-26M235 91c4-10 10-19 18-26M275 67c4-10 10-18 18-26M317 86c4-10 10-19 18-26M358 72c4-10 10-18 18-26M398 90c4-10 10-19 18-26M439 66c4-10 10-18 18-26M481 85c4-10 10-19 18-26M522 71c4-10 10-18 18-26M562 89c4-10 10-19 18-26M604 65c4-10 10-18 18-26M646 84c4-10 10-19 18-26M687 70c4-10 10-18 18-26M728 88c4-10 10-19 18-26M769 66c4-10 10-18 18-26M811 85c4-10 10-19 18-26M852 71c4-10 10-18 18-26M893 89c4-10 10-19 18-26M934 65c4-10 10-18 18-26M976 84c4-10 10-19 18-26M1017 70c4-10 10-18 18-26M1058 88c4-10 10-19 18-26M1099 66c4-10 10-18 18-26M1141 85c4-10 10-19 18-26M1182 71c4-10 10-18 18-26M1223 89c4-10 10-19 18-26M1264 65c4-10 10-18 18-26M1306 84c4-10 10-19 18-26M1347 70c4-10 10-18 18-26M1388 88c4-10 10-19 18-26" stroke-width="1" opacity="0.85"/>
            <path d="M19 96c9-2 16-6 20-12 5 7 11 11 20 13M61 96c9-2 16-6 20-12 5 7 11 11 20 13M102 96c9-2 16-6 20-12 5 7 11 11 20 13M143 96c9-2 16-6 20-12 5 7 11 11 20 13M184 96c9-2 16-6 20-12 5 7 11 11 20 13M225 96c9-2 16-6 20-12 5 7 11 11 20 13M266 96c9-2 16-6 20-12 5 7 11 11 20 13M307 96c9-2 16-6 20-12 5 7 11 11 20 13M348 96c9-2 16-6 20-12 5 7 11 11 20 13M389 96c9-2 16-6 20-12 5 7 11 11 20 13M430 96c9-2 16-6 20-12 5 7 11 11 20 13M471 96c9-2 16-6 20-12 5 7 11 11 20 13M512 96c9-2 16-6 20-12 5 7 11 11 20 13M553 96c9-2 16-6 20-12 5 7 11 11 20 13M594 96c9-2 16-6 20-12 5 7 11 11 20 13M635 96c9-2 16-6 20-12 5 7 11 11 20 13M676 96c9-2 16-6 20-12 5 7 11 11 20 13M717 96c9-2 16-6 20-12 5 7 11 11 20 13M758 96c9-2 16-6 20-12 5 7 11 11 20 13M799 96c9-2 16-6 20-12 5 7 11 11 20 13M840 96c9-2 16-6 20-12 5 7 11 11 20 13M881 96c9-2 16-6 20-12 5 7 11 11 20 13M922 96c9-2 16-6 20-12 5 7 11 11 20 13M963 96c9-2 16-6 20-12 5 7 11 11 20 13M1004 96c9-2 16-6 20-12 5 7 11 11 20 13M1045 96c9-2 16-6 20-12 5 7 11 11 20 13M1086 96c9-2 16-6 20-12 5 7 11 11 20 13M1127 96c9-2 16-6 20-12 5 7 11 11 20 13M1168 96c9-2 16-6 20-12 5 7 11 11 20 13M1209 96c9-2 16-6 20-12 5 7 11 11 20 13M1250 96c9-2 16-6 20-12 5 7 11 11 20 13M1291 96c9-2 16-6 20-12 5 7 11 11 20 13M1332 96c9-2 16-6 20-12 5 7 11 11 20 13M1373 96c9-2 16-6 20-12 5 7 11 11 20 13" stroke-width="1.1"/>
          </g>
        </svg>
      </div>
    {%- endif -%}
  </div>
</footer>

{% schema %}
{
  "name": "footer",
  "tag": "section",
  "class": "section theme-footer",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "text", "id": "social_label", "label": "Social label", "default": "Follow Us" },
    { "type": "url", "id": "facebook_link", "label": "Facebook link", "default": "" },
    { "type": "url", "id": "twitter_link", "label": "Twitter link", "default": "" },
    { "type": "url", "id": "instagram_link", "label": "Instagram link", "default": "" },
    { "type": "url", "id": "youtube_link", "label": "YouTube link", "default": "" },
    { "type": "url", "id": "linkedin_link", "label": "LinkedIn link", "default": "" },
    { "type": "image_picker", "id": "logo_image", "label": "Logo image" },
    { "type": "text", "id": "logo_alt", "label": "Logo alt text", "default": "Kerala Ayurveda" },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "The Proprietary Kerala Ayurveda Formulation.\nThis Is One Of Them."
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "default": 40, "label": "Top padding" },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "label": "Bottom padding"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [{ "type": "image_picker", "id": "logo", "label": "Logo" }]
    },
    {
      "type": "link_column",
      "name": "Link column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Quick Links" },
        { "type": "text", "id": "item_1_title", "label": "Item 1 title" },
        { "type": "url", "id": "item_1_link", "label": "Item 1 link" },
        { "type": "text", "id": "item_2_title", "label": "Item 2 title" },
        { "type": "url", "id": "item_2_link", "label": "Item 2 link" },
        { "type": "text", "id": "item_3_title", "label": "Item 3 title" },
        { "type": "url", "id": "item_3_link", "label": "Item 3 link" },
        { "type": "text", "id": "item_4_title", "label": "Item 4 title" },
        { "type": "url", "id": "item_4_link", "label": "Item 4 link" },
        { "type": "text", "id": "item_5_title", "label": "Item 5 title" },
        { "type": "url", "id": "item_5_link", "label": "Item 5 link" },
        { "type": "text", "id": "item_6_title", "label": "Item 6 title" },
        { "type": "url", "id": "item_6_link", "label": "Item 6 link" },
        { "type": "text", "id": "item_7_title", "label": "Item 7 title" },
        { "type": "url", "id": "item_7_link", "label": "Item 7 link" },
        { "type": "text", "id": "item_8_title", "label": "Item 8 title" },
        { "type": "url", "id": "item_8_link", "label": "Item 8 link" }
      ]
    },
    {
      "type": "social",
      "name": "Social",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Follow Us" },
        { "type": "url", "id": "facebook_link", "label": "Facebook link" },
        { "type": "url", "id": "twitter_link", "label": "Twitter link" },
        { "type": "url", "id": "instagram_link", "label": "Instagram link" },
        { "type": "url", "id": "youtube_link", "label": "YouTube link" },
        { "type": "url", "id": "linkedin_link", "label": "LinkedIn link" }
      ]
    },
    {
      "type": "tagline",
      "name": "Tagline",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "The Proprietary Kerala Ayurveda Formulation.\nThis Is One Of Them."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "footer",
      "blocks": [
        { "type": "brand" },
        { "type": "link_column" },
        { "type": "link_column" },
        { "type": "link_column" },
        { "type": "social" },
        { "type": "tagline" }
      ]
    }
  ]
}
{% endschema %}
