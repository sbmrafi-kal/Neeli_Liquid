<div class="theme-container theme-page-spacing theme-list-page">
  <header class="cart-header theme-text-center">
    <h1 class="theme-page-title theme-page-title--xl">Your Hair Recovery Cart</h1>
    <a href="{{ routes.all_products_collection_url }}" class="theme-link-muted">Continue Recovering</a>
  </header>

  {%- if cart.item_count > 0 -%}
    <form action="{{ routes.cart_url }}" method="post" id="cart" class="theme-cart-layout">
      <div class="cart-items theme-card theme-card--surface theme-stack theme-stack--lg">
        {%- for item in cart.items -%}
          <div class="cart-item theme-cart-item">
            <div class="theme-media-frame theme-media-frame--square">
              <img src="{{ item.image | image_url: width: 240 }}" alt="{{ item.title | escape }}" class="theme-media-fill">
            </div>
            <div class="theme-stack theme-stack--sm">
              <div>
                <h3 class="theme-page-title theme-page-title--md">
                  <a href="{{ item.url }}">{{ item.product.title }}</a>
                </h3>
                {%- if item.product.has_only_default_variant == false -%}
                  <p class="theme-page-subtitle">{{ item.variant.title }}</p>
                {%- endif -%}
              </div>
              <div class="theme-cart-item__meta">
                <div>
                  {{ item.final_line_price | money }}
                </div>
                <div>
                  Quantity: {{ item.quantity }}
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      <div class="cart-summary theme-card theme-card--soft theme-stack theme-stack--lg">
        <h2 class="theme-page-title theme-page-title--md">Summary</h2>
        <div class="theme-account-page__summary-row">
          <span>Subtotal</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <p class="theme-page-subtitle">Taxes and shipping calculated at checkout</p>
        <button type="submit" name="checkout" class="theme-review-button">
          Proceed to Checkout
        </button>
      </div>
    </form>
  {%- else -%}
    <div class="theme-text-center theme-stack theme-stack--lg">
      <p class="theme-page-subtitle">Your recovery cart is currently empty.</p>
      <a href="{{ routes.all_products_collection_url }}" class="theme-review-button">
        Find Your Solution
      </a>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Cart Page",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
