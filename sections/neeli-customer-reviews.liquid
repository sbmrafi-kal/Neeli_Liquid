{{ 'section-neeli-product-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="neeli-product-page__section neeli-reveal section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient {% if section.settings.soft_background %}neeli-product-page__section--soft{% endif %}">
  <div class="neeli-product-page__wrap">
    {% render 'neeli-section-heading',
      kicker: section.settings.kicker,
      title: section.settings.heading,
      text: section.settings.text,
      align: 'center',
      heading_tag: 'h2'
    %}

    <div class="neeli-review-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
          {% render 'neeli-review-card',
            name: block.settings.name,
            meta: block.settings.meta,
            badge: block.settings.badge,
            quote: block.settings.body
          %}
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <div style="margin-top: 1.5rem; display: flex; justify-content: center;">
        {%- if section.settings.button_link != blank -%}
          <a class="button button--secondary" href="{{ section.settings.button_link }}">
            {{ section.settings.button_label }}
          </a>
        {%- else -%}
          <span class="button button--secondary" role="presentation">{{ section.settings.button_label }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Neeli customer reviews",
  "tag": "section",
  "class": "section neeli-customer-reviews",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "checkbox", "id": "soft_background", "label": "Soft background", "default": false },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Feedback" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Customer reviews" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Real customer language, carried into the Shopify theme.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Read all reviews" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "default": 36, "label": "Top padding" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "default": 36, "label": "Bottom padding" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "ANJALI K." },
        { "type": "text", "id": "meta", "label": "Meta", "default": "Verified purchase" },
        { "type": "text", "id": "badge", "label": "Badge", "default": "Postpartum hair fall" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Within a month the amount of hair on my brush was noticeably less." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Neeli customer reviews",
      "blocks": [
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
