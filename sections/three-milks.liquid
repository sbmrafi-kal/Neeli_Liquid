{{ 'three-milks.css' | asset_url | stylesheet_tag }}



<section class="theme-three-milks">
  <div class="container-narrow theme-three-milks__container">
    <div class="theme-section-heading theme-section-heading--center">
      <div class="theme-section-heading__kicker theme-three-milks__kicker">{{ section.settings.kicker }}</div>
      <h2 class="theme-section-heading__title theme-three-milks__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.text != blank -%}
        <div class="theme-section-heading__text theme-three-milks__text">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <!-- Mobile View (Stacked flow) -->
    <div class="theme-three-milks__mobile-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'milk' -%}
          {%- unless forloop.first -%}
            <div class="theme-three-milks__connector" aria-hidden="true"></div>
          {%- endunless -%}
          {%- assign is_even = forloop.index | modulo: 2 -%}
          <article class="theme-three-milks__mobile-card theme-three-milks__mobile-card--{{ forloop.index }}{% if is_even == 0 %} theme-three-milks__mobile-card--reverse{% endif %} motion-panel" {{ block.shopify_attributes }}>
            <div class="theme-three-milks__mobile-image-wrap">
              {%- assign milk_mobile_image = block.settings.mobile_image | default: block.settings.image -%}
              {%- if block.settings.image != blank -%}
                <picture>
                  {%- if milk_mobile_image != blank -%}
                    <source media="(max-width: 989px)" srcset="{{ milk_mobile_image | image_url: width: 240 }}">
                  {%- endif -%}
                  {{
                    block.settings.image
                    | image_url: width: 320
                    | image_tag:
                      class: 'theme-three-milks__mobile-image',
                      loading: 'lazy',
                      widths: '124, 180, 240, 320',
                      alt: block.settings.title
                  }}
                </picture>
              {%- endif -%}
            </div>
            <div class="theme-three-milks__mobile-content">
              <h3 class="theme-three-milks__mobile-title">{{ block.settings.title }}</h3>
              {%- if block.settings.text != blank -%}
                <div class="theme-three-milks__mobile-desc">{{ block.settings.text }}</div>
              {%- endif -%}
            </div>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Desktop View (Side by side cards) -->
    <div class="theme-three-milks__desktop-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'milk' -%}
          <article class="theme-three-milks__card motion-panel" {{ block.shopify_attributes }}>
            <div class="theme-three-milks__image-wrap">
              {%- if block.settings.image != blank -%}
                <picture>
                  {%- if block.settings.mobile_image != blank -%}
                    <source media="(max-width: 989px)" srcset="{{ block.settings.mobile_image | image_url: width: 240 }}">
                  {%- endif -%}
                  {{
                    block.settings.image
                    | image_url: width: 400
                    | image_tag:
                      class: 'theme-three-milks__image',
                      loading: 'lazy',
                      widths: '188, 240, 320, 400',
                      alt: block.settings.title
                  }}
                </picture>
              {%- endif -%}
            </div>
            <h3 class="theme-three-milks__card-title">{{ block.settings.title }}</h3>
            {%- if block.settings.text != blank -%}
              <div class="theme-three-milks__card-desc">{{ block.settings.text }}</div>
            {%- endif -%}
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Three milks base",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "THE SECRET BASE" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Three milks. One complete formula." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Three nourishing milks work together for a healthier scalp and stronger, smoother hair.</p>" }
  ],
  "blocks": [
    {
      "type": "milk",
      "name": "Milk",
      "limit": 3,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Coconut milk" },
        { "type": "richtext", "id": "text", "label": "Description", "default": "<p>Nourishes and moisturizes the scalp.</p>" }
      ]
    }
  ],
  "presets": [{ "name": "Three milks base" }]
}
{% endschema %}
