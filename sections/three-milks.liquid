<section class="theme-three-milks bg-white pb-10 lg:pb-12">
  <div class="container-narrow text-center">
    <div class="section-kicker !text-[#8f4f36]">The secret base</div>
    <h2 class="mt-3 font-serif text-[36px] font-normal leading-none text-brand-forest lg:text-[44px]">Three milks. One complete formula.</h2>
    <p class="mx-auto mt-3 max-w-[820px] text-[15px] leading-[1.35] text-brand-forest/72 lg:text-[17px]">Three nourishing milks work together for a healthier scalp and stronger, smoother hair.</p>

    <!-- Mobile View -->
    <div class="mx-auto mt-7 grid max-w-[420px] gap-4 text-left lg:hidden">
      <article class="motion-panel flex items-center gap-4 rounded-[18px] bg-[#f7f3e9] px-5 py-4">
        <div class="shrink-0 rounded-full border border-[#17372d] bg-[#17372d] p-[1px]">
          <img src="{{ 'Coconut_milk.png' | asset_url }}" alt="Coconut milk" class="h-[62px] w-[62px] rounded-full object-cover" width="62" height="62" />
        </div>
        <div>
          <h3 class="text-[14px] font-medium uppercase leading-none text-[#1d201d]">Coconut milk</h3>
          <p class="mt-2 max-w-[220px] text-[14px] leading-[1.35] text-brand-forest/72">Nourishes and moisturizes the scalp.</p>
        </div>
      </article>
      <article class="motion-panel flex items-center gap-4 rounded-[18px] bg-[#f7f3e9] px-5 py-4">
        <div class="shrink-0 rounded-full border border-[#17372d] bg-[#17372d] p-[1px]">
          <img src="{{ 'Goat_milk.png' | asset_url }}" alt="Goat milk" class="h-[62px] w-[62px] rounded-full object-cover" width="62" height="62" />
        </div>
        <div>
          <h3 class="text-[14px] font-medium uppercase leading-none text-[#1d201d]">Goat milk</h3>
          <p class="mt-2 max-w-[220px] text-[14px] leading-[1.35] text-brand-forest/72">Addresses dandruff and improves hair texture.</p>
        </div>
      </article>
      <article class="motion-panel flex items-center gap-4 rounded-[18px] bg-[#f7f3e9] px-5 py-4">
        <div class="shrink-0 rounded-full border border-[#17372d] bg-[#17372d] p-[1px]">
          <img src="{{ 'Cow_milk.png' | asset_url }}" alt="Cow milk" class="h-[62px] w-[62px] rounded-full object-cover" width="62" height="62" />
        </div>
        <div>
          <h3 class="text-[14px] font-medium uppercase leading-none text-[#1d201d]">Cow milk</h3>
          <p class="mt-2 max-w-[220px] text-[14px] leading-[1.35] text-brand-forest/72">Controls hair fall and promotes hair growth.</p>
        </div>
      </article>
    </div>

    <!-- Desktop View -->
    <div class="mx-auto mt-10 hidden max-w-[1100px] gap-6 lg:grid lg:grid-cols-3 lg:gap-8">
      <article class="motion-panel rounded-[20px] bg-[#f7f3e9] px-6 pb-7 pt-6 sm:px-8 sm:pb-8 sm:pt-7">
        <div class="mx-auto w-fit rounded-full border border-[#17372d] bg-[#17372d] p-[2px]">
          <img src="{{ 'Coconut_milk.png' | asset_url }}" alt="Coconut milk" class="h-[82px] sm:h-[94px] w-[82px] sm:w-[94px] rounded-full object-cover" width="94" height="94" />
        </div>
        <h3 class="mt-4 font-serif text-[23px] font-normal leading-none text-brand-forest sm:text-[26px]">Coconut milk</h3>
        <p class="mx-auto mt-3 max-w-[270px] text-[14px] leading-[1.25] text-brand-forest/72 sm:text-[15px]">Nourishes and moisturizes the scalp.</p>
      </article>
      <article class="motion-panel rounded-[20px] bg-[#f7f3e9] px-6 pb-7 pt-6 sm:px-8 sm:pb-8 sm:pt-7">
        <div class="mx-auto w-fit rounded-full border border-[#17372d] bg-[#17372d] p-[2px]">
          <img src="{{ 'Goat_milk.png' | asset_url }}" alt="Goat milk" class="h-[82px] sm:h-[94px] w-[82px] sm:w-[94px] rounded-full object-cover" width="94" height="94" />
        </div>
        <h3 class="mt-4 font-serif text-[23px] font-normal leading-none text-brand-forest sm:text-[26px]">Goat milk</h3>
        <p class="mx-auto mt-3 max-w-[270px] text-[14px] leading-[1.25] text-brand-forest/72 sm:text-[15px]">Addresses dandruff and improves hair texture.</p>
      </article>
      <article class="motion-panel rounded-[20px] bg-[#f7f3e9] px-6 pb-7 pt-6 sm:px-8 sm:pb-8 sm:pt-7">
        <div class="mx-auto w-fit rounded-full border border-[#17372d] bg-[#17372d] p-[2px]">
          <img src="{{ 'Cow_milk.png' | asset_url }}" alt="Cow milk" class="h-[82px] sm:h-[94px] w-[82px] sm:w-[94px] rounded-full object-cover" width="94" height="94" />
        </div>
        <h3 class="mt-4 font-serif text-[23px] font-normal leading-none text-brand-forest sm:text-[26px]">Cow milk</h3>
        <p class="mx-auto mt-3 max-w-[270px] text-[14px] leading-[1.25] text-brand-forest/72 sm:text-[15px]">Controls hair fall and promotes hair growth.</p>
      </article>
    </div>

    <!-- Alert Pill -->
    <div class="mx-auto mt-8 hidden max-w-[900px] items-center justify-center gap-3 rounded-full border border-[#e8cf81] bg-[#f9f1cf] px-6 py-2.5 text-[15px] font-medium uppercase tracking-[0.08em] text-[#a3704c] lg:flex">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4 shrink-0">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <span>Always patch test first</span>
    </div>
    <div class="mx-auto mt-8 inline-flex items-center justify-center gap-2 rounded-full bg-white px-4 py-1 text-[11px] tracking-[0.16em] text-[#b08470] shadow-[0_4px_18px_rgba(17,48,39,0.06)] lg:hidden">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5 shrink-0">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <span>Always patch test first</span>
    </div>
  </div>
</section>

