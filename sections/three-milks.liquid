<section class="theme-three-milks">
  <div class="container-narrow theme-three-milks__container">
    <div class="theme-section-heading theme-section-heading--center">
      <div class="theme-section-heading__kicker theme-three-milks__kicker">The secret base</div>
      <h2 class="theme-section-heading__title theme-three-milks__title">Three milks. One complete formula.</h2>
      <p class="theme-section-heading__text theme-three-milks__text">Three nourishing milks work together for a healthier scalp and stronger, smoother hair.</p>
    </div>

    <!-- Mobile View -->
    <div class="theme-three-milks__mobile-grid">
      <article class="theme-three-milks__mobile-card motion-panel">
        <div class="theme-three-milks__mobile-image-wrap">
          <img src="{{ 'Coconut_milk.png' | asset_url }}" alt="Coconut milk" class="theme-three-milks__mobile-image" width="62" height="62" />
        </div>
        <div class="theme-three-milks__mobile-content">
          <h3 class="theme-three-milks__mobile-title">Coconut milk</h3>
          <p class="theme-three-milks__mobile-desc">Nourishes and moisturizes the scalp.</p>
        </div>
      </article>
      <article class="theme-three-milks__mobile-card motion-panel">
        <div class="theme-three-milks__mobile-image-wrap">
          <img src="{{ 'Goat_milk.png' | asset_url }}" alt="Goat milk" class="theme-three-milks__mobile-image" width="62" height="62" />
        </div>
        <div class="theme-three-milks__mobile-content">
          <h3 class="theme-three-milks__mobile-title">Goat milk</h3>
          <p class="theme-three-milks__mobile-desc">Addresses dandruff and improves hair texture.</p>
        </div>
      </article>
      <article class="theme-three-milks__mobile-card motion-panel">
        <div class="theme-three-milks__mobile-image-wrap">
          <img src="{{ 'Cow_milk.png' | asset_url }}" alt="Cow milk" class="theme-three-milks__mobile-image" width="62" height="62" />
        </div>
        <div class="theme-three-milks__mobile-content">
          <h3 class="theme-three-milks__mobile-title">Cow milk</h3>
          <p class="theme-three-milks__mobile-desc">Controls hair fall and promotes hair growth.</p>
        </div>
      </article>
    </div>

    <!-- Desktop View -->
    <div class="theme-three-milks__desktop-grid">
      <article class="theme-three-milks__card motion-panel">
        <div class="theme-three-milks__image-wrap">
          <img src="{{ 'Coconut_milk.png' | asset_url }}" alt="Coconut milk" class="theme-three-milks__image" width="94" height="94" />
        </div>
        <h3 class="theme-three-milks__card-title">Coconut milk</h3>
        <p class="theme-three-milks__card-desc">Nourishes and moisturizes the scalp.</p>
      </article>
      <article class="theme-three-milks__card motion-panel">
        <div class="theme-three-milks__image-wrap">
          <img src="{{ 'Goat_milk.png' | asset_url }}" alt="Goat milk" class="theme-three-milks__image" width="94" height="94" />
        </div>
        <h3 class="theme-three-milks__card-title">Goat milk</h3>
        <p class="theme-three-milks__card-desc">Addresses dandruff and improves hair texture.</p>
      </article>
      <article class="theme-three-milks__card motion-panel">
        <div class="theme-three-milks__image-wrap">
          <img src="{{ 'Cow_milk.png' | asset_url }}" alt="Cow milk" class="theme-three-milks__image" width="94" height="94" />
        </div>
        <h3 class="theme-three-milks__card-title">Cow milk</h3>
        <p class="theme-three-milks__card-desc">Controls hair fall and promotes hair growth.</p>
      </article>
    </div>

    <!-- Alert Pill -->
    <div class="theme-three-milks__alert theme-three-milks__alert--desktop">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="theme-three-milks__alert-icon">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <span>Always patch test first</span>
    </div>
    <div class="theme-three-milks__alert theme-three-milks__alert--mobile">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="theme-three-milks__alert-icon">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <span>Always patch test first</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Three milks base",
  "settings": [],
  "presets": [{ "name": "Three milks base" }]
}
{% endschema %}
