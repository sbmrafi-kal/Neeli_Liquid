<div class="theme-container theme-container--wide theme-page-spacing theme-account-page">
  <header class="theme-account-page__header">
    <div>
      <a href="{{ routes.account_url }}" class="theme-link-muted theme-account-page__back">&larr; Back to account</a>
      <h1 class="theme-page-title theme-page-title--lg">Order {{ order.name }}</h1>
      <p class="theme-page-subtitle">Placed on {{ order.created_at | time_tag: format: 'date' }}</p>
    </div>
    <span class="theme-account-page__status">
      {{ order.fulfillment_status_label }}
    </span>
  </header>

  <div class="theme-stack theme-stack--xl">
    <div class="theme-stack theme-stack--md">
      {%- for line_item in order.line_items -%}
        <div class="theme-card theme-card--surface theme-account-page__card">
          <div class="theme-media-frame theme-media-frame--square">
            {%- if line_item.image != blank -%}
              <img src="{{ line_item.image | image_url: width: 160 }}" alt="{{ line_item.title | escape }}" class="theme-media-fill">
            {%- else -%}
              <div class="theme-media-fill"></div>
            {%- endif -%}
          </div>
          <div class="theme-stack theme-stack--md">
            <div>
              <h3 class="theme-page-title theme-page-title--md">{{ line_item.product.title }}</h3>
              {%- if line_item.variant.title != blank -%}
                <p class="theme-page-subtitle">{{ line_item.variant.title }}</p>
              {%- endif -%}
              <span class="theme-page-subtitle">Qty: {{ line_item.quantity }}</span>
            </div>
            <span>{{ line_item.final_line_price | money }}</span>
          </div>
        </div>
      {%- endfor -%}
    </div>

    <div class="theme-card theme-card--soft theme-account-page__card">
      <div class="theme-account-page__summary-row">
        <span>Subtotal</span>
        <span>{{ order.line_items_subtotal_price | money }}</span>
      </div>
      <div class="theme-account-page__summary-row">
        <span>Shipping</span>
        <span>{{ order.shipping_price | money }}</span>
      </div>
      <div class="theme-account-page__summary-row">
        <span>Total</span>
        <span>{{ order.total_price | money }}</span>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Order Details",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
