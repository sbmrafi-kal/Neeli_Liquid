  {{ 'section-theme-product-page.css' | asset_url | stylesheet_tag }}
  {{ 'section-home-hero.css' | asset_url | stylesheet_tag }}
  {{ 'home-hero.js' | asset_url | script_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .theme-product-info-desktop {
    display: none;
  }
  
  .theme-product-info-mobile {
    display: block;
    margin-top: 1.5rem;
  }

  @media screen and (min-width: 990px) {
    .theme-product-info-desktop {
      display: block;
    }
    .theme-product-info-mobile {
      display: none;
    }
  }
{%- endstyle -%}

{%- assign hero_images = 'Product_carosul_01.png|Product_carosul_02.png|Product_carosul_03.png|Product_carosul_04.png|Product_carosul_05.png' | split: '|' -%}
{%- assign hero_thumbs = 'Product_carosul_01.png|Product_carosul_02.png|Product_carosul_03.png|Product_carosul_04.png|Product_carosul_05.png' | split: '|' -%}
{%- assign homepage_stamps = 'stamp_01.png|stamp_02.png|stamp_03.png|stamp_04.png|stamp_05.png' | split: '|' -%}

<section
  id="NeeliHomeHero-{{ section.id }}"
  class="theme-product-page theme-reveal section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}"
  data-section="{{ section.id }}"
>
  <script src="{{ 'theme-product-page.js' | asset_url }}" defer="defer"></script>

  <div class="theme-product-page__wrap">
    <div class="theme-product-page__hero">
      <div class="theme-product-page__hero-media">
        <div class="theme-hero-carousel" data-theme-carousel data-theme-autoplay="true" data-theme-interval="4800">
          <div class="theme-hero-carousel__stage">
            {%- for image in hero_images -%}
              <figure class="theme-hero-carousel__slide{% if forloop.first %} is-active{% endif %}" data-theme-carousel-slide>
                {%- if forloop.first -%}
                  {%- assign hero_loading = 'eager' -%}
                {%- else -%}
                  {%- assign hero_loading = 'lazy' -%}
                {%- endif -%}
                <img src="{{ image | asset_url }}" class="theme-hero-carousel__image image-zoom" loading="{{ hero_loading }}" width="750" height="1000" alt="{{ section.settings.hero_alt | escape }}">
              </figure>
            {%- endfor -%}

            <button class="theme-hero-carousel__control theme-hero-carousel__control--prev" type="button" aria-label="Previous image" data-theme-carousel-prev>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-left"><path d="m15 18-6-6 6-6"/></svg>
            </button>
            <button class="theme-hero-carousel__control theme-hero-carousel__control--next" type="button" aria-label="Next image" data-theme-carousel-next>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right"><path d="m9 18 6-6-6-6"/></svg>
            </button>
          </div>

          <div class="theme-hero-carousel__thumbs" role="tablist" aria-label="Homepage gallery thumbnails">
            {%- for image in hero_thumbs -%}
              <button
                class="theme-hero-carousel__thumb{% if forloop.first %} is-active{% endif %}"
                type="button"
                aria-label="Show image {{ forloop.index }}"
                data-theme-carousel-thumb="{{ forloop.index0 }}"
              >
                <img src="{{ image | asset_url }}" class="theme-hero-carousel__thumb-image" loading="lazy" width="750" height="1000" alt="">
              </button>
            {%- endfor -%}
          </div>

          <div class="theme-hero-carousel__stats">
            {%- assign stat_blocks = section.blocks | where: "type", "hero_stat" -%}
            {%- for block in stat_blocks -%}
              <div class="theme-hero-carousel__stat" {{ block.shopify_attributes }}>
                <div class="theme-hero-carousel__stat-value">{{ block.settings.value }}</div>
                <div class="theme-hero-carousel__stat-label">{{ block.settings.label }}</div>
              </div>
            {%- endfor -%}
          </div>
        </div>

        <div class="theme-hero-below theme-hero-below--desktop">
          <img src="{{ 'Below_the_product.png' | asset_url }}" class="theme-hero-below__image" loading="lazy" width="2000" height="2000" alt="">
        </div>
      </div>

      <!-- DESKTOP HERO INFO COLUMN -->
      <div class="theme-product-page__hero-info theme-product-info-desktop">
        <div class="theme-product-page__hero-header">
          <div class="theme-product-page__badge micro-fade-delayed">
            <span>{{ section.settings.badge }}</span>
          </div>

          <div class="theme-product-page__title-wrap">
            <h1 class="theme-product-page__title">{{ section.settings.title }}</h1>
          </div>

          <p class="theme-product-page__subtitle subtitle">
            {{ section.settings.subtitle }}
          </p>
        </div>

        <p class="theme-product-page__body theme-product-page__intro">
          {{ section.settings.body }}
        </p>

        <!-- Unified CTA Sheen Reorder Link Card -->
        <div class="theme-reorder-card cta-sheen motion-panel">
          <a class="theme-reorder-card__button theme-reorder-card__button--desktop hover-rise" href="{{ section.settings.button_link }}">
            <div class="flex flex-1 items-center gap-4 px-5 py-3">
              <svg class="theme-reorder-card__icon" stroke="currentColor" stroke-width="1.8" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M3 3v5h5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <div>
                <div class="theme-reorder-btn-text theme-reorder-btn-text--desktop">
                  {{ section.settings.cta_title }}
                </div>
                <div class="mt-1 text-[12px] text-white/72">{{ section.settings.cta_meta }}</div>
              </div>
            </div>
            <div class="flex items-center justify-end gap-3 border-t border-white/12 px-5 py-3 sm:min-w-[188px] sm:border-l sm:border-t-0">
              <span class="theme-reorder-card__price-old">
                {{ section.settings.cta_old_price }}
              </span>
              <span class="theme-reorder-card__price-new">
                {{ section.settings.cta_price }}
              </span>
            </div>
          </a>
        </div>

        <div class="theme-delivery-row">
          <div class="theme-delivery-row__item">
            <svg class="theme-delivery-row__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M3 7h11v10H3z" stroke="currentColor" stroke-width="1.7" />
              <path d="M14 10h3l2 2v5h-5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
              <circle cx="7" cy="18" r="1.4" fill="currentColor" />
              <circle cx="17" cy="18" r="1.4" fill="currentColor" />
            </svg>
            <span>{{ section.settings.delivery_1_text }}</span>
          </div>
          <div class="theme-delivery-row__item">
            <svg class="theme-delivery-row__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M3 7h18v10H3z" stroke="currentColor" stroke-width="1.7" />
              <path d="M8 12h8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
            </svg>
            <span>{{ section.settings.delivery_2_text }}</span>
          </div>
          <div class="theme-delivery-row__item">
            <svg class="theme-delivery-row__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M6 8h12l-1 11H7L6 8Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" />
              <path d="M9 8a3 3 0 0 1 6 0" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
            </svg>
            <span>{{ section.settings.delivery_3_text }}</span>
          </div>
        </div>

        <div class="theme-stamp-card motion-panel">
          <div class="theme-stamp-card__top">
            {%- for stamp in homepage_stamps -%}
              <div class="theme-stamp-card__stamp">
                {%- assign stamp_alt = 'Certification ' | append: forloop.index -%}
                <img src="{{ stamp | asset_url }}" class="theme-stamp-card__stamp-image" loading="lazy" width="1920" height="1080" alt="{{ stamp_alt | escape }}">
              </div>
            {%- endfor -%}
          </div>
          <div class="theme-stamp-card__stats">
            <div class="theme-stamp-card__stat">
              <div class="theme-stamp-card__stat-value">{{ section.settings.stat_1_value }}</div>
              <div class="theme-stamp-card__stat-label">{{ section.settings.stat_1_label }}</div>
            </div>
            <div class="theme-stamp-card__stat">
              <div class="theme-stamp-card__stat-value">{{ section.settings.stat_2_value }}</div>
              <div class="theme-stamp-card__stat-label">{{ section.settings.stat_2_label }}</div>
            </div>
            <div class="theme-stamp-card__stat">
              <div class="theme-stamp-card__stat-value">{{ section.settings.stat_3_value }}</div>
              <div class="theme-stamp-card__stat-label">{{ section.settings.stat_3_label }}</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- MOBILE HERO INFO CONTAINER (Spans full narrow width) -->
    <div class="theme-product-page__hero-info theme-product-info-mobile">
        <div class="theme-product-page__badge theme-product-page__badge--mobile">
          <span>{{ section.settings.badge }}</span>
        </div>

        <!-- Mobile Unified Reorder / Checkout CTA -->
        <div class="theme-reorder-card theme-reorder-card--mobile cta-sheen">
          <a class="theme-reorder-card__button theme-reorder-card__button--mobile" href="{{ section.settings.button_link }}">
            <div class="flex items-center gap-3">
              <svg class="theme-reorder-card__icon theme-reorder-card__icon--mobile" stroke="currentColor" stroke-width="1.8" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M3 3v5h5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <div>
                <div class="theme-reorder-btn-text theme-reorder-btn-text--mobile">
                  {{ section.settings.cta_title }}
                </div>
                <div class="mt-1 text-[11px] text-white/72">{{ section.settings.cta_meta }}</div>
              </div>
            </div>
            <div class="theme-reorder-card__price theme-reorder-card__price--mobile">
              <span class="theme-reorder-card__price-old">
                {{ section.settings.cta_old_price }}
              </span>
              <span class="theme-reorder-card__price-new theme-reorder-card__price-new--mobile">
                {{ section.settings.cta_price }}
              </span>
            </div>
          </a>
        </div>

        <h2 class="theme-product-page__subtitle theme-product-page__subtitle--mobile">
          {{ section.settings.subtitle }}
        </h2>
        <div class="theme-product-page__divider" />

        <p class="theme-product-page__body theme-product-page__intro theme-product-page__intro--mobile">
          {{ section.settings.body }}
        </p>

        <!-- Delivery columns -->
        <div class="theme-delivery-row theme-delivery-row--mobile">
          <div class="flex items-center justify-center gap-1.5 px-1 py-2.5 text-[10px]">
            <svg class="h-3.5 w-3.5" stroke="currentColor" stroke-width="1.9" fill="none" viewBox="0 0 24 24">
              <path d="M3 7h11v10H3z" />
              <path d="M14 10h3l2 2v5h-5" stroke-linecap="round" stroke-linejoin="round" />
              <circle cx="7" cy="18" r="1.4" fill="currentColor" />
              <circle cx="17" cy="18" r="1.4" fill="currentColor" />
            </svg>
            <span>{{ section.settings.delivery_1_text }}</span>
          </div>
          <div class="flex items-center justify-center gap-1.5 px-1 py-2.5 text-[10px]">
            <svg class="h-3.5 w-3.5" stroke="currentColor" stroke-width="1.9" fill="none" viewBox="0 0 24 24">
              <path d="M3 7h18v10H3z" />
              <path d="M8 12h8" stroke-linecap="round" />
            </svg>
            <span>{{ section.settings.delivery_2_text }}</span>
          </div>
          <div class="flex items-center justify-center gap-1.5 px-1 py-2.5 text-[10px]">
            <svg class="h-3.5 w-3.5" stroke="currentColor" stroke-width="1.9" fill="none" viewBox="0 0 24 24">
              <path d="M6 8h12l-1 11H7L6 8Z" stroke-linejoin="round" />
              <path d="M9 8a3 3 0 0 1 6 0" stroke-linecap="round" />
            </svg>
            <span>{{ section.settings.delivery_3_text }}</span>
          </div>
        </div>

        <!-- Mobile certifications panel -->
        <div class="motion-panel theme-mobile-stats-panel">
          <div class="grid grid-cols-3 gap-2 text-[#17372d]">
            <div class="border-r border-[#17372d]/8 px-2">
              <div class="font-serif text-[14px] font-normal leading-[0.98] tracking-[0.005em] text-[#17372d]">{{ section.settings.stat_1_value }}</div>
              <div class="mt-0.5 text-[8px] font-medium uppercase tracking-[0.1em] text-[#17372d]/72">{{ section.settings.stat_1_label }}</div>
            </div>
            <div class="border-r border-[#17372d]/8 px-2">
              <div class="font-serif text-[14px] font-normal leading-[0.98] tracking-[0.005em] text-[#17372d]">{{ section.settings.stat_2_value }}</div>
              <div class="mt-0.5 text-[8px] font-medium uppercase tracking-[0.1em] text-[#17372d]/72">{{ section.settings.stat_2_label }}</div>
            </div>
            <div class="px-2">
              <div class="font-serif text-[14px] font-normal leading-[0.98] tracking-[0.005em] text-[#17372d]">{{ section.settings.stat_3_value }}</div>
              <div class="mt-0.5 text-[8px] font-medium uppercase tracking-[0.1em] text-[#17372d]/72">{{ section.settings.stat_3_label }}</div>
            </div>
          </div>

          <div class="mt-1.5 grid grid-cols-4 items-center gap-0.5 pt-1">
            {%- for stamp in homepage_stamps offset: 1 limit: 4 -%}
              <div class="flex justify-center overflow-hidden">
                <img src="{{ stamp | asset_url }}" class="h-[58px] w-[58px] scale-[2.02] object-contain opacity-95 contrast-125 saturate-0" loading="lazy" width="58" height="58" alt="Certification">
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>
  </div>

</section>

{% schema %}
{
  "name": "homepage hero",
  "tag": "section",
  "class": "section theme-home-hero",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "text", "id": "badge", "label": "Badge", "default": "Minimizes hair fall" },
    { "type": "text", "id": "title", "label": "Title", "default": "Neelibhringadi Keram" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "One oil for complete hair recovery" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Hair recovery needs two wins - reduce the fall and support new growth. Most oils address one. Neelibhringadi works both sides." },
    { "type": "text", "id": "cta_title", "label": "CTA title", "default": "Reorder now" },
    { "type": "text", "id": "cta_meta", "label": "CTA meta", "default": "Limited-time offer" },
    { "type": "text", "id": "cta_old_price", "label": "Old price", "default": "₹350" },
    { "type": "text", "id": "cta_price", "label": "Price", "default": "₹315" },
    { "type": "url", "id": "button_link", "label": "CTA link" },
    { "type": "text", "id": "hero_alt", "label": "Hero image alt", "default": "Neelibhringadi Keram product gallery" },
    { "type": "text", "id": "stat_1_value", "label": "Stamp stat 1 value", "default": "1945" },
    { "type": "text", "id": "stat_1_label", "label": "Stamp stat 1 label", "default": "Established" },
    { "type": "text", "id": "stat_2_value", "label": "Stamp stat 2 value", "default": "350+" },
    { "type": "text", "id": "stat_2_label", "label": "Stamp stat 2 label", "default": "Products" },
    { "type": "text", "id": "stat_3_value", "label": "Stamp stat 3 value", "default": "Clinics & Academy" },
    { "type": "text", "id": "stat_3_label", "label": "Stamp stat 3 label", "default": "Expert led" },
    { "type": "text", "id": "delivery_1_text", "label": "Delivery row 1 text", "default": "2-4 day delivery" },
    { "type": "text", "id": "delivery_2_text", "label": "Delivery row 2 text", "default": "COD available" },
    { "type": "text", "id": "delivery_3_text", "label": "Delivery row 3 text", "default": "7-day returns" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "default": 0, "label": "Top padding" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "default": 16, "label": "Bottom padding" }
  ],
  "blocks": [
    {
      "type": "hero_stat",
      "name": "Hero stat",
      "settings": [
        { "type": "text", "id": "value", "default": "4.64★", "label": "Value" },
        { "type": "text", "id": "label", "default": "Ratings", "label": "Label" }
      ]
    }
  ],
  "presets": [
    {
      "name": "homepage hero",
      "blocks": [
        { "type": "hero_stat" },
        { "type": "hero_stat" },
        { "type": "hero_stat" },
        { "type": "hero_stat" }
      ]
    }
  ]
}
{% endschema %}
