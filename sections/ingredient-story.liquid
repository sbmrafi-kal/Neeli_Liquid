{{ 'section-theme-product-page.css' | asset_url | stylesheet_tag }}



<section class="theme-product-page__section theme-product-page__section--story theme-reveal color-{{ section.settings.color_scheme }} gradient">
  <!-- Sub-section 1: What's in it. What is not. -->
  <div class="theme-ingredient-story__whats-in-it">
    <div class="theme-product-page__wrap">
      <div class="theme-section-heading theme-section-heading--center theme-section-heading--flush">
        {%- if section.settings.heading != blank -%}
          <h2 class="theme-section-heading__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>

      <div class="theme-dual-panel">
        <div class="theme-panel theme-panel--soft">
          <div class="theme-list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'inclusion' -%}
                <div class="theme-list__item" {{ block.shopify_attributes }}>
                  <div class="theme-list__marker theme-list__marker--ok">
                    <svg width="14" height="14" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M2.5 6L5 8.5L9.5 3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <div>
                    <h3 class="theme-list__title">{{ block.settings.title }}</h3>
                    <p class="theme-list__text">{{ block.settings.text }}</p>
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

        <div class="theme-panel theme-panel--dark">
          <div class="theme-list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'exclusion' -%}
                <div class="theme-list__item" {{ block.shopify_attributes }}>
                  <div class="theme-list__marker theme-list__marker--no">
                    <svg width="14" height="14" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M3 3L9 9M9 3L3 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <div>
                    <h3 class="theme-list__title theme-list__title--inverse">{{ block.settings.title }}</h3>
                    <p class="theme-list__text theme-list__text--inverse">{{ block.settings.text }}</p>
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Sub-section 2: Kerala Ayurveda Difference -->
  <div class="theme-ingredient-story__difference">
    <div class="theme-product-page__wrap">
      <div class="theme-difference-heading theme-difference-heading--flush">
        {% render 'section-heading',
          title: section.settings.accordion_kicker,
          align: 'center',
          heading_tag: 'h2',
          inverse: true
        %}
      </div>

      <div class="theme-difference-panel motion-panel">
        <div class="theme-accordion">
          {%- for block in section.blocks -%}
            {%- if block.type == 'difference' -%}
              {% render 'accordion-item',
                item_id: 'Difference-' | append: block.id,
                title: block.settings.title,
                content: block.settings.text,
                icon: block.settings.icon
              %}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>

  <!-- Sub-section 3: Reviews -->
  <div class="theme-difference-reviews-wrap">
    <div class="theme-product-page__wrap">
      <div class="theme-review-grid theme-review-grid--story">
        {%- for block in section.blocks -%}
          {%- if block.type == 'story_review' -%}
            <div class="theme-review-card" {{ block.shopify_attributes }}>
              <div class="theme-review-card__top">
                <div>
                  <div class="theme-review-card__name">{{ block.settings.name }}</div>
                  <div class="theme-review-card__meta">{{ block.settings.meta }}</div>
                </div>
                <div class="theme-review-card__stars">
                  {%- for i in (1..5) -%}
                    <svg class="theme-review-card__star-svg" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                    </svg>
                  {%- endfor -%}
                </div>
              </div>
              {%- if block.settings.badge != blank -%}
                <div class="theme-review-card__badge">{{ block.settings.badge }}</div>
              {%- endif -%}
              <p class="theme-review-card__quote">"{{ block.settings.quote }}"</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ingredient story",
  "tag": "section",
  "class": "section theme-ingredient-story",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "checkbox", "id": "soft_background", "label": "Soft background", "default": true },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "The formula" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What's in it. What is not." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Two clear columns make the formula easier to scan and trust.</p>" },
    { "type": "text", "id": "accordion_kicker", "label": "Accordion kicker", "default": "Kerala Ayurveda Difference" },
    { "type": "text", "id": "accordion_heading", "label": "Accordion heading", "default": "Why the process matters" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "default": 88, "label": "Top padding" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "default": 88, "label": "Bottom padding" }
  ],
  "blocks": [
    {
      "type": "inclusion",
      "name": "Inclusion",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "100% NATURAL INGREDIENTS" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "No mineral oil, parabens, or synthetic fragrance. Pure botanical extraction." }
      ]
    },
    {
      "type": "exclusion",
      "name": "Exclusion",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "NO PARABENS" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "We use natural antioxidants to preserve the formula." }
      ]
    },
    {
      "type": "difference",
      "name": "Difference",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "none",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "leather", "label": "Leather" },
            { "value": "truck", "label": "Truck" },
            { "value": "ruler", "label": "Ruler" },
            { "value": "heart", "label": "Heart" }
          ]
        },
        { "type": "text", "id": "title", "label": "Title", "default": "INGREDIENTS" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Neeli, Bhringaraj, Amla and a triple-milk base selected to cool, fortify, and support regrowth." }
      ]
    },
    {
      "type": "story_review",
      "name": "Story review",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Priya M." },
        { "type": "text", "id": "meta", "label": "Meta", "default": "Bengaluru - 6 weeks" },
        { "type": "text", "id": "badge", "label": "Badge", "default": "Less fall - week 3" },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "Less hair in the shower drain by week three. That was the first sign it was working." }
      ]
    }
  ],
  "presets": [
    {
      "name": "ingredient story",
      "blocks": [
        { "type": "inclusion" },
        { "type": "inclusion" },
        { "type": "exclusion" },
        { "type": "exclusion" },
        { "type": "difference" },
        { "type": "difference" },
        { "type": "difference" },
        { "type": "difference" },
        { "type": "story_review" },
        { "type": "story_review" }
      ]
    }
  ]
}
{% endschema %}
