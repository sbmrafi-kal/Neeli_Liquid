{{ 'section-ingredient-story.css' | asset_url | stylesheet_tag }}

<section class="theme-product-page__section theme-product-page__section--story theme-reveal color-{{ section.settings.color_scheme }} gradient">
  <div class="theme-ingredient-story__whats-in-it">
    <div class="theme-product-page__wrap">
      <div class="theme-section-heading theme-section-heading--center theme-section-heading--flush">
        {%- if section.settings.heading != blank -%}
          <h2 class="theme-section-heading__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="theme-section-heading__text">{{ section.settings.text }}</div>
        {%- endif -%}
      </div>

      <div class="theme-dual-panel">
        {%- assign inclusions_markup = '' -%}
        {%- assign exclusions_markup = '' -%}
        {%- for block in section.blocks -%}
          {%- capture list_item -%}
            <div class="theme-list__item" {{ block.shopify_attributes }}>
              <div class="theme-list__marker theme-list__marker--{{ block.type | replace: 'inclusion', 'ok' | replace: 'exclusion', 'no' }}">
                {%- if block.type == 'inclusion' -%}
                  <svg width="14" height="14" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M2.5 6L5 8.5L9.5 3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {%- else -%}
                  <svg width="14" height="14" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M3 3L9 9M9 3L3 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {%- endif -%}
              </div>
              <div>
                <h3 class="theme-list__title{% if block.type == 'exclusion' %} theme-list__title--inverse{% endif %}">{{ block.settings.title }}</h3>
                {%- if block.settings.text != blank -%}
                  <p class="theme-list__text{% if block.type == 'exclusion' %} theme-list__text--inverse{% endif %}">{{ block.settings.text }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- endcapture -%}
          {%- if block.type == 'inclusion' -%}
            {%- assign inclusions_markup = inclusions_markup | append: list_item -%}
          {%- elsif block.type == 'exclusion' -%}
            {%- assign exclusions_markup = exclusions_markup | append: list_item -%}
          {%- endif -%}
        {%- endfor -%}

        <div class="theme-panel theme-panel--soft">
          <div class="theme-list">
            {{ inclusions_markup }}
          </div>
        </div>

        <div class="theme-panel theme-panel--dark">
          <div class="theme-list">
            {{ exclusions_markup }}
          </div>
        </div>
      </div>
    </div>
  </div>

  {%- assign difference_blocks = section.blocks | where: 'type', 'difference' -%}
  {%- if section.settings.show_difference and difference_blocks.size > 0 -%}
    <div class="theme-ingredient-story__difference">
      <div class="theme-product-page__wrap">
        <div class="theme-ingredient-story__difference-header">
          {%- assign difference_title = section.settings.accordion_kicker | default: section.settings.kicker -%}
          {%- assign difference_subtitle = section.settings.accordion_heading -%}
          {%- if difference_title != blank -%}
            <h3 class="theme-ingredient-story__difference-title">{{ difference_title }}</h3>
          {%- endif -%}
          {%- if difference_subtitle != blank -%}
            <div class="theme-ingredient-story__difference-subtitle">{{ difference_subtitle }}</div>
          {%- endif -%}
        </div>

        <div class="theme-difference-panel">
          <div class="theme-accordion">
            {%- for block in difference_blocks -%}
              {%
                render 'accordion-item',
                item_id: 'Difference-' | append: block.id,
                title: block.settings.title,
                content: block.settings.text,
                icon: block.settings.icon,
                open: false
              %}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "ingredient story",
  "tag": "section",
  "class": "section theme-ingredient-story",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "checkbox", "id": "soft_background", "label": "Soft background", "default": true },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "The formula" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What's in it. What is not." },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Two clear columns make the formula easier to scan and trust.</p>"
    },
    {
      "type": "checkbox",
      "id": "show_difference",
      "label": "Show difference accordion",
      "default": false
    },
    { "type": "text", "id": "accordion_kicker", "label": "Accordion kicker", "default": "Kerala Ayurveda Difference" },
    { "type": "text", "id": "accordion_heading", "label": "Accordion heading", "default": "Why it matters" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "default": 88, "label": "Top padding" },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 88,
      "label": "Bottom padding"
    }
  ],
  "blocks": [
    {
      "type": "inclusion",
      "name": "Inclusion",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "100% NATURAL INGREDIENTS" },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "High-quality natural ingredients sourced sustainably."
        }
      ]
    },
    {
      "type": "exclusion",
      "name": "Exclusion",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "NO PARABENS" },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "We use natural antioxidants to preserve the formula."
        }
      ]
    },
    {
      "type": "difference",
      "name": "Difference item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "none",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "leather", "label": "Leather" },
            { "value": "truck", "label": "Truck" },
            { "value": "ruler", "label": "Ruler" },
            { "value": "heart", "label": "Heart" }
          ]
        },
        { "type": "text", "id": "title", "label": "Title", "default": "INGREDIENTS" },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "A clear explanation of how the formula is put together."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ingredient story",
      "blocks": [
        { "type": "inclusion" },
        { "type": "inclusion" },
        { "type": "inclusion" },
        { "type": "exclusion" },
        { "type": "exclusion" },
        { "type": "exclusion" },
        { "type": "exclusion" },
        { "type": "difference" },
        { "type": "difference" },
        { "type": "difference" },
        { "type": "difference" }
      ]
    }
  ]
}
{% endschema %}
