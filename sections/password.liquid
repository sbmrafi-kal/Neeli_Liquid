<div class="theme-password-section">
  <div style="margin-bottom: 2rem;">
    {%- if settings.logo != blank -%}
      <img src="{{ settings.logo | image_url: width: 120 }}" alt="{{ shop.name }}" style="max-width: 120px; height: auto;">
    {%- else -%}
      <span style="font-family: var(--font-heading-family); font-size: 2.25rem; color: var(--theme-forest); font-weight: 400; letter-spacing: 0.02em;">{{ shop.name }}</span>
    {%- endif -%}
  </div>

  <h1 style="font-family: var(--font-heading-family); font-size: 2rem; color: var(--theme-forest); margin: 0 0 1rem; font-weight: 400; line-height: 1.2;">Opening Soon</h1>
  <p style="font-size: 0.9375rem; color: rgba(23, 55, 45, 0.72); margin: 0 0 2rem; line-height: 1.5;">Be the first to know when we launch our complete hair recovery solution.</p>

  {%- form 'customer', id: 'ContactPassword', class: 'password-signup-form' -%}
    {%- if form.posted_successfully? -%}
      <div style="background: #ecf8ee; border: 1px solid #38a55b; color: #1d201d; border-radius: 8px; padding: 0.75rem 1rem; margin-bottom: 1.5rem; font-size: 0.875rem;">
        You've been added to our launching list!
      </div>
    {%- endif -%}

    <input type="hidden" name="contact[tags]" value="prospect, password page">
    <div style="display: flex; gap: 0.5rem; margin-bottom: 2.5rem;">
      <input
        type="email"
        name="contact[email]"
        placeholder="Enter your email"
        style="flex-grow: 1; border: 1px solid rgba(23, 55, 45, 0.2); border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.9375rem; outline: none;"
        required
      >
      <button type="submit" class="theme-review-button" style="padding: 0.75rem 1.25rem; font-size: 0.875rem; background: #8f4f36; border-color: #8f4f36; color: #fff; cursor: pointer;">
        Notify Me
      </button>
    </div>
  {%- endform -%}

  <div style="border-top: 1px solid rgba(23, 55, 45, 0.08); padding-top: 1.5rem;">
    {%- form 'storefront_password', id: 'LoginPassword', class: 'password-login-form' -%}
      {%- if form.errors -%}
        <p style="color: #f44336; font-size: 0.8125rem; margin-top: 0; margin-bottom: 1rem;">Incorrect password.</p>
      {%- endif -%}
      <label for="password" style="display: block; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; color: rgba(23, 55, 45, 0.54); margin-bottom: 0.5rem; letter-spacing: 0.05em;">Enter store using password</label>
      <div style="display: flex; gap: 0.5rem; max-width: 320px; margin: 0 auto;">
        <input
          type="password"
          name="password"
          id="password"
          placeholder="Password"
          style="flex-grow: 1; border: 1px solid rgba(23, 55, 45, 0.2); border-radius: 8px; padding: 0.5rem 0.75rem; font-size: 0.875rem; outline: none;"
        >
        <button type="submit" class="theme-review-button" style="padding: 0.5rem 1rem; font-size: 0.8125rem; border-color: var(--theme-forest); color: var(--theme-forest); background: transparent; cursor: pointer;">
          Enter
        </button>
      </div>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Password Page",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
