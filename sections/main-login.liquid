<div class="theme-container theme-container--narrow theme-page-spacing theme-auth-page">
  <div id="recover">
    <h2 class="theme-page-title theme-page-title--md theme-text-center">Reset your password</h2>
    <p class="theme-page-subtitle theme-text-center">We will send you an email to reset your password.</p>

    {%- form 'recover_customer_password' -%}
      {%- if form.posted_successfully? -%}
        <div class="theme-page-alert theme-page-alert--success">
          We've sent you an email with a link to update your password.
        </div>
      {%- endif -%}

      <div class="theme-stack theme-stack--md">
        <div>
          <label for="RecoverEmail">Email</label>
          <input
            type="email"
            name="email"
            id="RecoverEmail"
            placeholder="Email"
            required
          >
        </div>
      </div>

      <button type="submit" class="theme-review-button">
        Submit
      </button>

      <a href="#login" class="theme-link-muted" data-theme-recover-toggle="hide">
        Cancel
      </a>
    {%- endform -%}
  </div>

  <div id="login">
    <h2 class="theme-page-title theme-page-title--lg theme-text-center">Login</h2>

    {%- form 'customer_login' -%}
      {%- if form.errors -%}
        <div class="theme-page-alert theme-page-alert--error">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="theme-stack theme-stack--md">
        <div>
          <label for="CustomerEmail">Email</label>
          <input
            type="email"
            name="customer[email]"
            id="CustomerEmail"
            placeholder="Email"
            required
          >
        </div>

        {%- if form.password_needed -%}
          <div>
            <div class="theme-login-row">
              <label for="CustomerPassword">Password</label>
              <a href="#recover" class="theme-link-muted" data-theme-recover-toggle="show">Forgot your password?</a>
            </div>
            <input
              type="password"
              name="customer[password]"
              id="CustomerPassword"
              placeholder="Password"
              required
            >
          </div>
        {%- endif -%}
      </div>

      <button type="submit" class="theme-review-button">
        Sign In
      </button>

      <div class="theme-login-footer">
        New customer? <a href="{{ routes.account_register_url }}" class="theme-link-forest">Create account</a>
      </div>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Login Page",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
