<div class="theme-container theme-page-spacing" style="max-width: 440px; margin: 0 auto;">
  <div id="recover" style="display: none;">
    <h2 style="font-family: var(--font-heading-family); font-size: 2.25rem; color: var(--theme-forest); text-align: center; margin-bottom: 1rem; font-weight: 400;">Reset your password</h2>
    <p style="font-size: 0.9375rem; color: rgba(23, 55, 45, 0.72); text-align: center; margin-bottom: 2rem;">We will send you an email to reset your password.</p>

    {%- form 'recover_customer_password' -%}
      {%- if form.posted_successfully? -%}
        <div style="background: #ecf8ee; border: 1px solid #38a55b; color: #1d201d; border-radius: 8px; padding: 0.75rem 1rem; margin-bottom: 1.5rem; font-size: 0.875rem;">
          We've sent you an email with a link to update your password.
        </div>
      {%- endif -%}

      <div style="margin-bottom: 1.5rem;">
        <label for="RecoverEmail" style="display: block; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; color: rgba(23, 55, 45, 0.62); margin-bottom: 0.5rem; letter-spacing: 0.05em;">Email</label>
        <input
          type="email"
          name="email"
          id="RecoverEmail"
          placeholder="Email"
          style="width: 100%; border: 1px solid rgba(23, 55, 45, 0.2); border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.9375rem; outline: none; background: #fff;"
          required
        >
      </div>

      <button type="submit" class="theme-review-button" style="display: inline-flex; width: 100%; justify-content: center; background: #8f4f36; border-color: #8f4f36; color: #fff; cursor: pointer; padding: 0.875rem 1.5rem;">
        Submit
      </button>

      <a href="#login" onclick="toggleRecover(false); return false;" style="display: block; text-align: center; margin-top: 1.25rem; font-size: 0.9375rem; color: rgba(23, 55, 45, 0.72); text-decoration: underline;">
        Cancel
      </a>
    {%- endform -%}
  </div>

  <div id="login">
    <h2 style="font-family: var(--font-heading-family); font-size: 2.5rem; color: var(--theme-forest); text-align: center; margin-bottom: 2rem; font-weight: 400;">Login</h2>

    {%- form 'customer_login' -%}
      {%- if form.errors -%}
        <div style="background: #fdf3f2; border: 1px solid #f44336; color: #1d201d; border-radius: 8px; padding: 0.75rem 1rem; margin-bottom: 1.5rem; font-size: 0.875rem;">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div style="margin-bottom: 1.25rem;">
        <label for="CustomerEmail" style="display: block; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; color: rgba(23, 55, 45, 0.62); margin-bottom: 0.5rem; letter-spacing: 0.05em;">Email</label>
        <input
          type="email"
          name="customer[email]"
          id="CustomerEmail"
          placeholder="Email"
          style="width: 100%; border: 1px solid rgba(23, 55, 45, 0.2); border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.9375rem; outline: none; background: #fff;"
          required
        >
      </div>

      {%- if form.password_needed -%}
        <div style="margin-bottom: 1.5rem;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
            <label for="CustomerPassword" style="display: block; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; color: rgba(23, 55, 45, 0.62); letter-spacing: 0.05em;">Password</label>
            <a href="#recover" onclick="toggleRecover(true); return false;" style="font-size: 0.8125rem; color: rgba(23, 55, 45, 0.62); text-decoration: underline;">Forgot your password?</a>
          </div>
          <input
            type="password"
            name="customer[password]"
            id="CustomerPassword"
            placeholder="Password"
            style="width: 100%; border: 1px solid rgba(23, 55, 45, 0.2); border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.9375rem; outline: none; background: #fff;"
            required
          >
        </div>
      {%- endif -%}

      <button type="submit" class="theme-review-button" style="display: inline-flex; width: 100%; justify-content: center; background: #8f4f36; border-color: #8f4f36; color: #fff; cursor: pointer; padding: 1rem 2rem;">
        Sign In
      </button>

      <div style="text-align: center; margin-top: 2rem; font-size: 0.9375rem; color: rgba(23, 55, 45, 0.72);">
        New customer? <a href="{{ routes.account_register_url }}" style="color: var(--theme-forest); font-weight: 600; text-decoration: underline;">Create account</a>
      </div>
    {%- endform -%}
  </div>
</div>

<script>
  function toggleRecover(show) {
    document.getElementById('recover').style.display = show ? 'block' : 'none';
    document.getElementById('login').style.display = show ? 'none' : 'block';
  }
  
  if (window.location.hash === '#recover') {
    toggleRecover(true);
  }
</script>

{% schema %}
{
  "name": "Login Page",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
