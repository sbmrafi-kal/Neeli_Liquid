<div class="theme-container theme-page-spacing theme-list-page">
  <header class="collection-hero theme-text-center">
    <h1 class="theme-page-title theme-page-title--xl">{{ collection.title | escape }}</h1>
    {%- if collection.description != blank -%}
      <div class="collection-hero__description rte theme-page-subtitle">
        {{ collection.description }}
      </div>
    {%- endif -%}
  </header>

  <div class="collection-grid theme-grid--cards-280">
    {%- for product in collection.products -%}
      <article class="theme-card theme-card--surface theme-review-card image-zoom-shell">
        <a href="{{ product.url }}" class="theme-media-frame theme-media-frame--square">
          {%- if product.featured_image != blank -%}
            <img
              src="{{ product.featured_image | image_url: width: 600 }}"
              alt="{{ product.featured_image.alt | escape }}"
              class="theme-media-fill image-zoom"

              loading="lazy"
            >
          {%- else -%}
            <div class="theme-media-fill"></div>
          {%- endif -%}
        </a>
        <div class="theme-stack theme-stack--md">
          <h3 class="theme-page-title theme-page-title--md">
            <a href="{{ product.url }}">{{ product.title | escape }}</a>
          </h3>
          <div class="theme-page-subtitle">
            {{ product.price | money }}
          </div>
          <div>
            <a href="{{ product.url }}" class="theme-review-button">
              View Recovery Product
            </a>
          </div>
        </div>
      </article>
    {%- else -%}
      <div class="text-center">
        <p>No products found in this recovery category.</p>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection Page",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
