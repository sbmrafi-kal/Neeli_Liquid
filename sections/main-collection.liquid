<div class="theme-container theme-page-spacing">
  <header class="collection-hero text-center" style="margin-bottom: 3.5rem;">
    <h1 class="theme-page-title" style="font-family: var(--font-heading-family); font-size: 2.75rem; color: var(--theme-forest);">{{ collection.title | escape }}</h1>
    {%- if collection.description != blank -%}
      <div class="collection-hero__description rte" style="max-width: 640px; margin: 1.25rem auto 0; font-size: 1rem; color: rgba(23, 55, 45, 0.72); line-height: 1.45;">
        {{ collection.description }}
      </div>
    {%- endif -%}
  </header>

  <div class="collection-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2rem;">
    {%- for product in collection.products -%}
      <article class="theme-review-card image-zoom-shell" style="border: 1px solid rgba(23, 55, 45, 0.08); border-radius: 12px; overflow: hidden; background: #fff; display: flex; flex-direction: column;">
        <a href="{{ product.url }}" style="display: block; overflow: hidden; position: relative; padding-top: 100%;">
          {%- if product.featured_image != blank -%}
            <img
              src="{{ product.featured_image | image_url: width: 600 }}"
              alt="{{ product.featured_image.alt | escape }}"
              class="image-zoom"
              style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-cover: cover; transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);"
              loading="lazy"
            >
          {%- endif -%}
        </a>
        <div style="padding: 1.5rem; display: flex; flex-direction: column; flex-grow: 1; text-align: center;">
          <h3 style="font-family: var(--font-heading-family); font-size: 1.375rem; margin: 0; font-weight: 400;">
            <a href="{{ product.url }}" style="color: var(--theme-forest); text-decoration: none;">{{ product.title | escape }}</a>
          </h3>
          <div style="margin-top: 0.5rem; font-size: 1.125rem; font-weight: 600; color: #8f4f36;">
            {{ product.price | money }}
          </div>
          <div style="margin-top: auto; padding-top: 1.25rem;">
            <a href="{{ product.url }}" class="theme-review-button" style="display: inline-flex; width: 100%; padding: 0.875rem 1.5rem; font-size: 0.875rem; justify-content: center; box-sizing: border-box; text-decoration: none;">
              View Recovery Product
            </a>
          </div>
        </div>
      </article>
    {%- else -%}
      <div class="text-center" style="grid-column: 1 / -1; padding: 4rem 0;">
        <p style="font-size: 1.125rem; color: rgba(23, 55, 45, 0.62);">No products found in this recovery category.</p>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection Page",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
