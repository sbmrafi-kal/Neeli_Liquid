{{ 'section-header-figma.css' | asset_url | stylesheet_tag }}

<header class="theme-header-figma" role="banner">
  <div class="theme-header-figma__inner">
    <div class="theme-header-figma__left">
      <nav class="theme-header-figma__nav" aria-label="Primary">
        {%- for i in (1..5) -%}
          {%- assign title = section.settings['nav_' | append: i | append: '_title'] | default: '' -%}
          {%- assign url = section.settings['nav_' | append: i | append: '_url'] | default: routes.root_url -%}
          {%- if title != blank -%}
            <a class="theme-header-figma__nav-link" href="{{ url }}">{{ title }}</a>
          {%- endif -%}
        {%- endfor -%}
      </nav>
    </div>

    <div class="theme-header-figma__center">
      <a class="theme-header-figma__brand" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        {%- if section.settings.logo_image != blank -%}
          {{ section.settings.logo_image | image_url: width: 600 | image_tag: class: 'theme-header-figma__brand-image', loading: 'eager', alt: section.settings.logo_alt }}
        {%- else -%}
          <span class="theme-header-figma__brand-text">{{ section.settings.logo_text | default: shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <div class="theme-header-figma__right">
      <button class="theme-header-figma__action" type="button" aria-label="Search">🔍</button>
      <a class="theme-header-figma__action" href="{{ routes.cart_url }}" aria-label="Cart">🛒</a>
      <a class="theme-header-figma__action" href="{{ routes.account_url }}" aria-label="Account">👤</a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header (Figma)",
  "settings": [
    { "type": "image_picker", "id": "logo_image", "label": "Logo image" },
    { "type": "text", "id": "logo_alt", "label": "Logo alt text" },
    { "type": "text", "id": "logo_text", "label": "Logo fallback text", "default": "Shop" }
  ],
  "presets": [{ "name": "Header (Figma)" }]
}
{% endschema %}
