{{ 'section-header-figma.css' | asset_url | stylesheet_tag }}

<header class="theme-header-figma" role="banner">
  <div class="theme-header-figma__inner">
    <div class="theme-header-figma__left">
      <nav class="theme-header-figma__nav" aria-label="Primary">
        {%- assign nav_1_title = section.settings.nav_1_title | default: '' -%}
        {%- assign nav_2_title = section.settings.nav_2_title | default: '' -%}
        {%- assign nav_3_title = section.settings.nav_3_title | default: '' -%}
        {%- assign nav_4_title = section.settings.nav_4_title | default: '' -%}
        {%- assign nav_5_title = section.settings.nav_5_title | default: '' -%}

        {%- assign nav_1_url = section.settings.nav_1_url | default: routes.root_url -%}
        {%- assign nav_2_url = section.settings.nav_2_url | default: routes.root_url -%}
        {%- assign nav_3_url = section.settings.nav_3_url | default: routes.root_url -%}
        {%- assign nav_4_url = section.settings.nav_4_url | default: routes.root_url -%}
        {%- assign nav_5_url = section.settings.nav_5_url | default: routes.root_url -%}

        {%- if nav_1_title != blank -%}
          <a class="theme-header-figma__nav-link" href="{{ nav_1_url }}">{{ nav_1_title }}</a>
        {%- endif -%}
        {%- if nav_2_title != blank -%}
          <a class="theme-header-figma__nav-link" href="{{ nav_2_url }}">{{ nav_2_title }}</a>
        {%- endif -%}
        {%- if nav_3_title != blank -%}
          <a class="theme-header-figma__nav-link" href="{{ nav_3_url }}">{{ nav_3_title }}</a>
        {%- endif -%}
        {%- if nav_4_title != blank -%}
          <a class="theme-header-figma__nav-link" href="{{ nav_4_url }}">{{ nav_4_title }}</a>
        {%- endif -%}
        {%- if nav_5_title != blank -%}
          <a class="theme-header-figma__nav-link" href="{{ nav_5_url }}">{{ nav_5_title }}</a>
        {%- endif -%}
      </nav>
    </div>

    <div class="theme-header-figma__center">
      <a class="theme-header-figma__brand" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        {%- if section.settings.logo_image != blank -%}
          {{
            section.settings.logo_image
            | image_url: width: 600
            | image_tag: class: 'theme-header-figma__brand-image', loading: 'eager', alt: section.settings.logo_alt
          }}
        {%- else -%}
          {%- assign logo_text = section.settings.logo_text | default: shop.name -%}
          {%- assign logo_parts = logo_text | split: ' ' -%}
          {%- assign logo_first = logo_parts[0] | downcase -%}
          {%- assign logo_rest = logo_parts | slice: 1, logo_parts.size | join: ' ' | downcase -%}
          <span class="theme-header-figma__brand-text">
            <span class="brand-line brand-line--top">{{ logo_first }}</span>
            {%- if logo_rest != blank -%}
              <span class="brand-line brand-line--bottom">{{ logo_rest }}</span>
            {%- endif -%}
          </span>
        {%- endif -%}
      </a>
    </div>

    <div class="theme-header-figma__right">
      <button class="theme-header-figma__action" type="button" aria-label="Search">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8"></circle>
          <path d="m21 21-4.35-4.35" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
        </svg>
      </button>
      <a class="theme-header-figma__action" href="{{ routes.cart_url }}" aria-label="Cart">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="8" cy="21" r="1" stroke="currentColor" stroke-width="1.6"></circle>
          <circle cx="19" cy="21" r="1" stroke="currentColor" stroke-width="1.6"></circle>
          <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="theme-header-figma__cart-count" aria-label="{{ cart.item_count }} items">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
      <a class="theme-header-figma__action" href="{{ routes.account_url }}" aria-label="Account">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="8" r="5" stroke="currentColor" stroke-width="1.8"></circle>
          <path d="M20 21a8 8 0 0 0-16 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
        </svg>
      </a>
    </div>
  </div>

  <div class="theme-header-figma__breadcrumbs-wrap">
    <div class="theme-header-figma__breadcrumbs" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      {%- assign breadcrumb_label = '' -%}
      {%- unless request.page_type == 'index' -%}
        {%- case request.page_type -%}
          {%- when 'product' -%}
            {%- if product != blank -%}
              {%- assign breadcrumb_label = product.title -%}
            {%- else -%}
              {%- assign path_parts = request.path | split: '/' | reverse -%}
              {%- assign prod_handle = path_parts[0] -%}
              {%- assign candidate_product = all_products[prod_handle] -%}
              {%- if candidate_product != blank -%}
                {%- assign breadcrumb_label = candidate_product.title -%}
              {%- endif -%}
            {%- endif -%}
          {%- when 'collection' -%}
            {%- if collection != blank -%}
              {%- assign breadcrumb_label = collection.title -%}
            {%- endif -%}
          {%- when 'page' -%}
            {%- if page != blank and page.title != 'Home' -%}
              {%- assign breadcrumb_label = page.title -%}
            {%- endif -%}
          {%- when 'article' -%}
            {%- if article != blank -%}
              {%- assign breadcrumb_label = article.title -%}
            {%- endif -%}
        {%- endcase -%}
      {%- endunless -%}
      {%- assign custom_breadcrumb_label = section.settings.breadcrumb_current_label | strip -%}
      {%- if request.page_type == 'product'
        and custom_breadcrumb_label != blank
        and custom_breadcrumb_label != 'Home'
        and custom_breadcrumb_label != 'Current Page'
      -%}
        {%- assign breadcrumb_label = custom_breadcrumb_label -%}
      {%- endif -%}
      {%- if breadcrumb_label == blank
        and custom_breadcrumb_label != blank
        and custom_breadcrumb_label != 'Home'
        and custom_breadcrumb_label != 'Current Page'
      -%}
        {%- assign breadcrumb_label = custom_breadcrumb_label -%}
      {%- endif -%}
      {%- if breadcrumb_label != blank and breadcrumb_label != 'Home' -%}
        <span class="theme-header-figma__breadcrumb-sep">&gt;</span>
        <span class="theme-header-figma__breadcrumb-current">{{ breadcrumb_label }}</span>
      {%- endif -%}
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header (Figma)",
  "settings": [
    { "type": "text", "id": "nav_1_title", "label": "Nav item 1 label", "default": "Shop All" },
    { "type": "url", "id": "nav_1_url", "label": "Nav item 1 link" },
    { "type": "text", "id": "nav_2_title", "label": "Nav item 2 label", "default": "Clinics" },
    { "type": "url", "id": "nav_2_url", "label": "Nav item 2 link" },
    { "type": "text", "id": "nav_3_title", "label": "Nav item 3 label", "default": "Resorts" },
    { "type": "url", "id": "nav_3_url", "label": "Nav item 3 link" },
    { "type": "text", "id": "nav_4_title", "label": "Nav item 4 label", "default": "Hospitals" },
    { "type": "url", "id": "nav_4_url", "label": "Nav item 4 link" },
    { "type": "text", "id": "nav_5_title", "label": "Nav item 5 label", "default": "Academy" },
    { "type": "url", "id": "nav_5_url", "label": "Nav item 5 link" },
    { "type": "image_picker", "id": "logo_image", "label": "Logo image" },
    { "type": "text", "id": "logo_alt", "label": "Logo alt text" },
    { "type": "text", "id": "logo_text", "label": "Logo fallback text", "default": "Shop" },
    { "type": "text", "id": "breadcrumb_current_label", "label": "Breadcrumb current label", "default": "Current Page" }
  ],
  "presets": [{ "name": "Header (Figma)" }]
}
{% endschema %}
