<div class="theme-container theme-page-spacing theme-list-page">
  <header class="blog-header theme-text-center">
    <h1 class="theme-page-title theme-page-title--xl">{{ blog.title | escape }}</h1>
  </header>

  <div class="blog-articles theme-grid--cards-320">
    {%- for article in blog.articles -%}
      <article class="theme-card theme-card--surface theme-review-card image-zoom-shell">
        {%- if article.image != blank -%}
          <a href="{{ article.url }}" class="theme-media-frame theme-media-frame--wide">
            <img
              src="{{ article.image | image_url: width: 600 }}"
              alt="{{ article.image.alt | escape }}"
              class="theme-media-fill image-zoom"

              loading="lazy"
            >
          </a>
        {%- else -%}
          <a href="{{ article.url }}" class="theme-media-frame theme-media-frame--wide">
            <div class="theme-media-fill"></div>
          </a>
        {%- endif -%}
        <div class="theme-stack theme-stack--md">
          <span class="theme-page-kicker">{{ article.published_at | time_tag: format: 'date' }}</span>
          <h3 class="theme-page-title theme-page-title--md">
            <a href="{{ article.url }}">{{ article.title | escape }}</a>
          </h3>
          {%- if article.excerpt.size > 0 -%}
            <p class="theme-page-subtitle">
              {{ article.excerpt | strip_html | truncatewords: 30 }}
            </p>
          {%- else -%}
            <p class="theme-page-subtitle">
              {{ article.content | strip_html | truncatewords: 30 }}
            </p>
          {%- endif -%}
          <div>
            <a href="{{ article.url }}" class="theme-link-forest">Read Story</a>
          </div>
        </div>
      </article>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Blog List",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
