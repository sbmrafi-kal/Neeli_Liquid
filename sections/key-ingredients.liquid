{{ 'section-key-ingredients.css' | asset_url | stylesheet_tag }}<section class="theme-key-ingredients  color-{{ section.settings.color_scheme }} gradient">
  <div class="theme-product-page__wrap">
    <div class="theme-ki-header">
      {%- if section.settings.heading != blank -%}
        <h2 class="theme-ki-header__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="theme-ki-header__text">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="theme-ki-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'ingredient' -%}
          <div class="theme-ki-card motion-panel" {{ block.shopify_attributes }}>
            {%- assign ingredient_mobile_image = block.settings.mobile_image | default: block.settings.image -%}
            {%- assign show_ingredient_text = false -%}
            {%- if section.settings.show_text or block.settings.title != blank or block.settings.subtitle != blank or block.settings.text != blank -%}
              {%- assign show_ingredient_text = true -%}
            {%- endif -%}
            {%- if block.settings.image != blank -%}
              <div class="theme-ki-card__img-wrap">
                <picture>
                  {%- if ingredient_mobile_image != blank -%}
                    <source media="(max-width: 989px)" srcset="{{ ingredient_mobile_image | image_url: width: 480 }}">
                  {%- endif -%}
                  {{
                    block.settings.image
                    | image_url: width: 900
                    | image_tag:
                      class: 'theme-ki-card__img image-zoom',
                      loading: 'lazy',
                      widths: '240, 360, 480, 720, 900',
                      alt: block.settings.title
                  }}
                </picture>
              </div>
            {%- endif -%}

            {%- if show_ingredient_text -%}
              <div class="theme-ki-card__content">
                {%- if block.settings.title != blank -%}
                  <h3 class="theme-ki-card__title">{{ block.settings.title }}</h3>
                {%- endif -%}

                {%- if block.settings.subtitle != blank -%}
                  <div class="theme-ki-card__subtitle">{{ block.settings.subtitle }}</div>
                {%- endif -%}

                {%- if block.settings.text != blank -%}
                  <div class="theme-ki-card__text rte">{{ block.settings.text }}</div>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "key ingredients",
  "tag": "section",
  "class": "section theme-key-ingredients-section",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Key Ingredients" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Only potent Ayurvedic botanicals. No mineral oil, no artificial fragrances, no hidden chemicals.</p>" },
    { "type": "checkbox", "id": "show_text", "label": "Show card text", "default": true },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "default": 36, "label": "Top padding" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "default": 36, "label": "Bottom padding" }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Bringaraj" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "False Daisy" },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Supports hair growth. Activates follicles and increases scalp circulation.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "key ingredients",
      "blocks": [
        { "type": "ingredient" },
        { "type": "ingredient" },
        { "type": "ingredient" },
        { "type": "ingredient" }
      ]
    }
  ]
}
{% endschema %}
