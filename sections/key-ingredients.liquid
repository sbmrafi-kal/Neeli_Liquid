{{ 'section-neeli-product-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="neeli-product-page__section neeli-reveal section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient {% if section.settings.soft_background %}neeli-product-page__section--soft{% endif %}">
  <div class="neeli-product-page__wrap">
    <div class="neeli-section-heading neeli-section-heading--center neeli-key-ingredients__heading">
      {%- if section.settings.heading != blank -%}
        <h2 class="neeli-section-heading__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="neeli-ingredient-grid">
      {%- assign ingredient_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'ingredient' -%}
          {%- assign ingredient_index = ingredient_index | plus: 1 -%}
          {%- case ingredient_index -%}
            {%- when 1 -%}
              {%- assign default_image = 'ing-bringaraj.jpg' -%}
            {%- when 2 -%}
              {%- assign default_image = 'ing-amla.jpg' -%}
            {%- when 3 -%}
              {%- assign default_image = 'ing-neeli.jpg' -%}
            {%- else -%}
              {%- assign default_image = 'ing-coconut.jpg' -%}
          {%- endcase -%}
            <article class="neeli-ingredient neeli-panel" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 1200 | image_tag: class: 'neeli-ingredient__media', loading: 'lazy', alt: block.settings.title }}
              {%- else -%}
                <img src="{{ default_image | asset_url }}" class="neeli-ingredient__media" loading="lazy" width="670" height="302" alt="{{ block.settings.title | escape }}">
              {%- endif -%}
              <div class="neeli-ingredient__body">
                <h3 class="neeli-ingredient__title">{{ block.settings.title }}</h3>
                <p class="neeli-ingredient__text">{{ block.settings.text }}</p>
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
    </div>

    <div class="neeli-milk-section">
      {% render 'section-heading',
        kicker: section.settings.milk_kicker,
        title: section.settings.milk_heading,
        text: section.settings.milk_text,
        align: 'center',
        heading_tag: 'h2'
      %}

      <div class="neeli-milk-grid">
        {%- assign milk_index = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'milk' -%}
            {%- assign milk_index = milk_index | plus: 1 -%}
            {%- case milk_index -%}
              {%- when 1 -%}
                {%- assign default_milk_image = 'Coconut_milk.jpg' -%}
              {%- when 2 -%}
                {%- assign default_milk_image = 'Goat_milk.jpg' -%}
              {%- else -%}
                {%- assign default_milk_image = 'Cow_milk.jpg' -%}
            {%- endcase -%}
            <article class="neeli-milk neeli-panel" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 1000 | image_tag: class: 'neeli-milk__media', loading: 'lazy', alt: block.settings.title }}
              {%- else -%}
                <img src="{{ default_milk_image | asset_url }}" class="neeli-milk__media" loading="lazy" width="800" height="920" alt="{{ block.settings.title | escape }}">
              {%- endif -%}
              <div class="neeli-milk__body">
                <h3 class="neeli-milk__title">{{ block.settings.title }}</h3>
                <p class="neeli-milk__text">{{ block.settings.text }}</p>
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="neeli-patch-test">
        <span class="neeli-patch-test__icon" aria-hidden="true">!</span>
        <span>Always patch test first</span>
      </div>
    </div>

    <div class="neeli-steps-section">
      {% render 'section-heading',
        kicker: section.settings.steps_kicker,
        title: section.settings.steps_heading,
        text: section.settings.steps_text,
        align: 'center',
        heading_tag: 'h2'
      %}

      <div class="neeli-step-hero">
        <img src="{{ 'massage-ritual.png' | asset_url }}" class="float-soft image-zoom" loading="lazy" width="1206" height="678" alt="{{ section.settings.steps_heading | escape }}">
      </div>

      <div class="neeli-step-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'step' -%}
            <article class="neeli-step neeli-panel" {{ block.shopify_attributes }}>
              <div class="neeli-step__body">
                <div class="neeli-step__number">{{ block.settings.number }}</div>
                <h3 class="neeli-step__title">{{ block.settings.title }}</h3>
                <p class="neeli-step__text">{{ block.settings.text }}</p>
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "key ingredients",
  "tag": "section",
  "class": "section neeli-key-ingredients",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "checkbox", "id": "soft_background", "label": "Soft background", "default": true },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Key Ingredients" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The botanicals that do the work." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Four ingredients to explain the core formula.</p>" },
    { "type": "text", "id": "milk_kicker", "label": "Milk kicker", "default": "The secret base" },
    { "type": "text", "id": "milk_heading", "label": "Milk heading", "default": "Three milks. One complete formula." },
    { "type": "richtext", "id": "milk_text", "label": "Milk text", "default": "<p>Three nourishing milks work together for a healthier scalp and stronger hair.</p>" },
    { "type": "text", "id": "steps_kicker", "label": "Steps kicker", "default": "Your easy massage ritual" },
    { "type": "text", "id": "steps_heading", "label": "Steps heading", "default": "Warm. Apply. Massage." },
    { "type": "richtext", "id": "steps_text", "label": "Steps text", "default": "<p>Use the oil two to three times a week with a consistent routine.</p>" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "default": 36, "label": "Top padding" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "default": 36, "label": "Bottom padding" }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Bringaraj" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Supports hair growth and scalp circulation." }
      ]
    },
    {
      "type": "milk",
      "name": "Milk",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Coconut milk" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Nourishes and moisturizes the scalp." }
      ]
    },
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "1" },
        { "type": "text", "id": "title", "label": "Title", "default": "WARM" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Warm oil penetrates; cold oil sits on the surface." }
      ]
    }
  ],
  "presets": [
    {
      "name": "key ingredients",
      "blocks": [
        { "type": "ingredient" },
        { "type": "ingredient" },
        { "type": "ingredient" },
        { "type": "ingredient" },
        { "type": "milk" },
        { "type": "milk" },
        { "type": "milk" },
        { "type": "step" },
        { "type": "step" },
        { "type": "step" }
      ]
    }
  ]
}
{% endschema %}
