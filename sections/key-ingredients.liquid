{{ 'section-theme-product-page.css' | asset_url | stylesheet_tag }}
{{ 'section-key-ingredients.css' | asset_url | stylesheet_tag }}<section class="theme-key-ingredients  color-{{ section.settings.color_scheme }} gradient" style="--pt: {{ section.settings.padding_top }}px; --pb: {{ section.settings.padding_bottom }}px;">
  <div class="theme-product-page__wrap">
    <div class="theme-ki-header">
      {%- if section.settings.heading != blank -%}
        <h2 class="theme-ki-header__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="theme-ki-header__text">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="theme-ki-grid">
      {%- assign ingredient_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'ingredient' -%}
          {%- assign ingredient_index = ingredient_index | plus: 1 -%}
          {%- case ingredient_index -%}
            {%- when 1 -%}
              {%- assign default_image = 'ing-bringaraj.jpg' -%}
            {%- when 2 -%}
              {%- assign default_image = 'ing-amla.jpg' -%}
            {%- when 3 -%}
              {%- assign default_image = 'ing-neeli.png' -%}
            {%- else -%}
              {%- assign default_image = 'ing-coconut.jpg' -%}
          {%- endcase -%}
          
          <div class="theme-ki-card motion-panel" {{ block.shopify_attributes }}>
            <div class="theme-ki-card__img-wrap">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 240 | image_tag: class: 'theme-ki-card__img image-zoom', loading: 'lazy', alt: block.settings.title }}
              {%- else -%}
                <img src="{{ default_image | asset_url }}" class="theme-ki-card__img image-zoom" loading="lazy" width="120" height="120" alt="{{ block.settings.title | escape }}">
              {%- endif -%}
            </div>
            
            <h3 class="theme-ki-card__title">{{ block.settings.title }}</h3>
            
            {%- if block.settings.subtitle != blank -%}
              <div class="theme-ki-card__subtitle">{{ block.settings.subtitle }}</div>
            {%- endif -%}
            
            <p class="theme-ki-card__text">{{ block.settings.text }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "key ingredients",
  "tag": "section",
  "class": "section theme-key-ingredients-section",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What's in it. What is not." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Only potent Ayurvedic botanicals. No mineral oil, no artificial fragrances, no hidden chemicals.</p>" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "default": 36, "label": "Top padding" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "default": 36, "label": "Bottom padding" }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Neeli" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "For scalp health" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Reduces inflammation and stops premature greying." }
      ]
    }
  ],
  "presets": [
    {
      "name": "key ingredients",
      "blocks": [
        { "type": "ingredient" },
        { "type": "ingredient" },
        { "type": "ingredient" },
        { "type": "ingredient" }
      ]
    }
  ]
}
{% endschema %}
