{{ 'section-theme-product-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="theme-product-page__section theme-reveal section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient {% if section.settings.soft_background %}theme-product-page__section--soft{% endif %}">
  <div class="theme-product-page__wrap">
    <div class="theme-section-heading theme-section-heading--center theme-key-ingredients__heading">
      {%- if section.settings.heading != blank -%}
        <h2 class="theme-section-heading__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <!-- Mobile Key Ingredients Layout -->
    <div class="theme-key-ingredients--mobile lg:hidden">
      {%- assign ingredient_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'ingredient' -%}
          {%- assign ingredient_index = ingredient_index | plus: 1 -%}
          {%- case ingredient_index -%}
            {%- when 1 -%}
              {%- assign default_image = 'ing-bringaraj.jpg' -%}
            {%- when 2 -%}
              {%- assign default_image = 'ing-amla.jpg' -%}
            {%- when 3 -%}
              {%- assign default_image = 'ing-neeli.png' -%}
            {%- else -%}
              {%- assign default_image = 'ing-coconut.jpg' -%}
          {%- endcase -%}
          <article class="theme-ingredient-mobile motion-panel" {{ block.shopify_attributes }}>
            <div class="theme-ingredient-mobile__media-wrap">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 400 | image_tag: class: 'theme-ingredient-mobile__media image-zoom', loading: 'lazy', alt: block.settings.title }}
              {%- else -%}
                <img src="{{ default_image | asset_url }}" class="theme-ingredient-mobile__media image-zoom" loading="lazy" width="126" height="126" alt="{{ block.settings.title | escape }}">
              {%- endif -%}
            </div>
            <div class="theme-ingredient-mobile__body">
              <h3 class="theme-ingredient-mobile__title">{{ block.settings.title }}</h3>
              <p class="theme-ingredient-mobile__text">{{ block.settings.text }}</p>
            </div>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Desktop Key Ingredients Layout -->
    <div class="theme-key-ingredients--desktop hidden lg:grid">
      {%- assign ingredient_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'ingredient' -%}
          {%- assign ingredient_index = ingredient_index | plus: 1 -%}
          {%- case ingredient_index -%}
            {%- when 1 -%}
              {%- assign default_image = 'ing-bringaraj.jpg' -%}
            {%- when 2 -%}
              {%- assign default_image = 'ing-amla.jpg' -%}
            {%- when 3 -%}
              {%- assign default_image = 'ing-neeli.png' -%}
            {%- else -%}
              {%- assign default_image = 'ing-coconut.jpg' -%}
          {%- endcase -%}
          <article class="theme-ingredient-desktop motion-panel" {{ block.shopify_attributes }}>
            <div class="theme-ingredient-desktop__media-wrap">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 600 | image_tag: class: 'theme-ingredient-desktop__media image-zoom', loading: 'lazy', alt: block.settings.title }}
              {%- else -%}
                <img src="{{ default_image | asset_url }}" class="theme-ingredient-desktop__media image-zoom" loading="lazy" width="600" height="300" alt="{{ block.settings.title | escape }}">
              {%- endif -%}
            </div>
            <div class="theme-ingredient-desktop__body">
              <h3 class="theme-ingredient-desktop__title">{{ block.settings.title }}</h3>
              <p class="theme-ingredient-desktop__text">{{ block.settings.text }}</p>
            </div>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>


  </div>
</section>

{% schema %}
{
  "name": "key ingredients",
  "tag": "section",
  "class": "section theme-key-ingredients",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "checkbox", "id": "soft_background", "label": "Soft background", "default": true },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "The botanicals" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Key Ingredients" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Four ingredients to explain the core formula.</p>" },

    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "default": 36, "label": "Top padding" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "default": 36, "label": "Bottom padding" }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Bringaraj" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Supports hair growth and scalp circulation." }
      ]
    }
  ],
  "presets": [
    {
      "name": "key ingredients",
      "blocks": [
        { "type": "ingredient" },
        { "type": "ingredient" },
        { "type": "ingredient" },
        { "type": "ingredient" }
      ]
    }
  ]
}
{% endschema %}
