{{ 'section-theme-product-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="theme-product-page__section theme-timeline theme-reveal section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="theme-ritual-guide">
    <div class="theme-ritual-guide__inner">
      <div class="theme-ritual-guide__card motion-panel">
        <div class="theme-ritual-guide__content">
          <svg class="theme-ritual-guide__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="3.2" stroke="currentColor" stroke-width="1.8" />
            <path d="M12 2.5v2.2M12 19.3v2.2M4.7 4.7l1.6 1.6M17.7 17.7l1.6 1.6M2.5 12h2.2M19.3 12h2.2M4.7 19.3l1.6-1.6M17.7 6.3l1.6-1.6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          </svg>
          <div>
            <div class="theme-ritual-guide__title">{{ section.settings.ritual_title }}</div>
            <p class="theme-ritual-guide__text">{{ section.settings.ritual_text }}</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="theme-timeline__heading-band">
    {% render 'section-heading',
      kicker: section.settings.kicker,
      title: section.settings.heading,
      text: section.settings.text,
      align: 'center',
      inverse: section.settings.inverse_text,
      heading_tag: 'h2'
    %}
  </div>

  <div class="theme-product-page__wrap theme-timeline-container">
    <!-- MOBILE VIEW (hidden on desktop) -->
    <div class="theme-timeline__mobile-only">
      {%- assign stage_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'stage' -%}
          {%- assign stage_index = stage_index | plus: 1 -%}
          {%- case stage_index -%}
            {%- when 1 -%}
              {%- assign default_stage_image = 'expect-1.jpg' -%}
            {%- when 2 -%}
              {%- assign default_stage_image = 'expect-2.jpg' -%}
            {%- else -%}
              {%- assign default_stage_image = 'expect-3.jpg' -%}
          {%- endcase -%}
          <div class="theme-timeline__mobile-row" {{ block.shopify_attributes }}>
            <div class="theme-timeline__mobile-left">
              <div class="theme-timeline__mobile-img-wrap">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 200 | image_tag: class: 'theme-timeline__mobile-img', loading: 'lazy', alt: block.settings.title }}
                {%- else -%}
                  <img src="{{ default_stage_image | asset_url }}" class="theme-timeline__mobile-img" loading="lazy" width="92" height="92" alt="{{ block.settings.title | escape }}">
                {%- endif -%}
              </div>
              <div class="theme-timeline__mobile-phase">{{ block.settings.mobile_phase }}</div>
            </div>
            <div class="theme-timeline__mobile-right">
              <div class="theme-timeline__mobile-label">{{ block.settings.label }}</div>
              <h3 class="theme-timeline__mobile-title">{{ block.settings.title }}</h3>
              <p class="theme-timeline__mobile-body">{{ block.settings.body }}</p>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- DESKTOP VIEW (hidden on mobile) -->
    <div class="theme-timeline__desktop-only">
      {%- assign stage_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'stage' -%}
          {%- assign stage_index = stage_index | plus: 1 -%}
          {%- case stage_index -%}
            {%- when 1 -%}
              {%- assign default_stage_image = 'expect-1.jpg' -%}
            {%- when 2 -%}
              {%- assign default_stage_image = 'expect-2.jpg' -%}
            {%- else -%}
              {%- assign default_stage_image = 'expect-3.jpg' -%}
          {%- endcase -%}
          <div class="theme-timeline__desktop-col" {{ block.shopify_attributes }}>
            <div class="theme-timeline__desktop-top">
              <div class="theme-timeline__desktop-phase">
                {{ block.settings.phase }}
              </div>
              <div class="theme-timeline__desktop-img-wrap">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 300 | image_tag: class: 'theme-timeline__desktop-img', loading: 'lazy', alt: block.settings.title }}
                {%- else -%}
                  <img src="{{ default_stage_image | asset_url }}" class="theme-timeline__desktop-img" loading="lazy" width="116" height="94" alt="{{ block.settings.title | escape }}">
                {%- endif -%}
              </div>
            </div>

            <div class="theme-timeline__desktop-bottom">
              <div class="theme-timeline__desktop-label">
                {{ block.settings.label }}
              </div>
              <h3 class="theme-timeline__desktop-title">
                {{ block.settings.title }}
              </h3>
              <p class="theme-timeline__desktop-body">
                {{ block.settings.body }}
              </p>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.footnote != blank -%}
      <p class="theme-timeline__footnote">{{ section.settings.footnote }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "timeline",
  "tag": "section",
  "class": "section theme-timeline-section",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "checkbox", "id": "inverse_text", "label": "Use inverse heading text", "default": false },
    { "type": "text", "id": "ritual_title", "label": "Ritual guide title", "default": "The Ritual Guide" },
    { "type": "textarea", "id": "ritual_text", "label": "Ritual guide text", "default": "Warm slightly. Massage into roots. Leave for 30 - 60mins. Use two to three times a week." },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "What to expect" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The honest sequence." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Root strength comes before visible density.</p>" },
    { "type": "text", "id": "footnote", "label": "Footnote", "default": "Based on consistent use as directed. Individual results may vary." },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "default": 36, "label": "Top padding" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "default": 28, "label": "Bottom padding" }
  ],
  "blocks": [
    {
      "type": "stage",
      "name": "Stage",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "phase", "label": "Phase", "default": "FIRST TIME" },
        { "type": "text", "id": "mobile_phase", "label": "Mobile phase", "default": "First Time" },
        { "type": "text", "id": "label", "label": "Label", "default": "FIRST APPLICATION" },
        { "type": "text", "id": "title", "label": "Title", "default": "Scalp cools immediately" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "The oil absorbs without heaviness and supports the first visible improvements." }
      ]
    }
  ],
  "presets": [
    {
      "name": "timeline",
      "blocks": [
        { "type": "stage" },
        { "type": "stage" },
        { "type": "stage" }
      ]
    }
  ]
}
{% endschema %}
