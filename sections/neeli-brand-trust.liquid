{{ 'section-neeli-product-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="neeli-product-page__section neeli-product-page__section--forest neeli-reveal section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="neeli-product-page__wrap">
    <div class="neeli-trust-band">
      <div class="neeli-trust-band__image-wrap">
        <img src="{{ 'Flower.png' | asset_url }}" class="neeli-trust-band__image image-zoom" loading="lazy" width="1024" height="1024" alt="{{ section.settings.heading | escape }}">
      </div>

      <div class="neeli-trust-band__content">
        {%- if section.settings.kicker != blank -%}
          <p class="neeli-trust-band__eyebrow">{{ section.settings.kicker }}</p>
        {%- endif -%}
        <h2 class="neeli-trust-band__title">{{ section.settings.heading }}</h2>
        <div class="neeli-trust-band__text rte">{{ section.settings.text }}</div>

        <div class="neeli-trust-band__divider"></div>

        {%- if section.settings.patents_kicker != blank -%}
          <p class="neeli-trust-band__eyebrow">{{ section.settings.patents_kicker }}</p>
        {%- endif -%}
        <h2 class="neeli-trust-band__title neeli-trust-band__title--secondary">{{ section.settings.patents_heading }}</h2>
        <div class="neeli-trust-band__text rte">{{ section.settings.patents_text }}</div>

        <div class="neeli-trust-band__patents">
          <div class="neeli-trust-band__patent-card motion-panel">
            <img src="{{ 'US_Flag.png' | asset_url }}" class="neeli-trust-band__flag" loading="lazy" width="1432" height="954" alt="{{ section.settings.us_title | escape }}">
            <div class="neeli-trust-band__patent-title">{{ section.settings.us_title }}</div>
            <div class="neeli-trust-band__patent-text rte">{{ section.settings.us_text }}</div>
          </div>
          <div class="neeli-trust-band__patent-card motion-panel">
            <img src="{{ 'Japan_Flag.png' | asset_url }}" class="neeli-trust-band__flag" loading="lazy" width="1270" height="844" alt="{{ section.settings.japan_title | escape }}">
            <div class="neeli-trust-band__patent-title">{{ section.settings.japan_title }}</div>
            <div class="neeli-trust-band__patent-text rte">{{ section.settings.japan_text }}</div>
          </div>
        </div>
      </div>

      <div class="neeli-trust-band__mark">
        <img src="{{ 'ka-mark.png' | asset_url }}" class="neeli-trust-band__mark-image" loading="lazy" width="238" height="328" alt="{{ section.settings.mark_heading | escape }}">
        {%- if section.settings.mark_kicker != blank -%}
          <p class="neeli-trust-band__eyebrow neeli-trust-band__eyebrow--mark">{{ section.settings.mark_kicker }}</p>
        {%- endif -%}
        <h2 class="neeli-trust-band__mark-heading">{{ section.settings.mark_heading }}</h2>
        <div class="neeli-trust-band__mark-text rte">
          {{ section.settings.mark_text }}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Neeli brand trust",
  "tag": "section",
  "class": "section neeli-brand-trust",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-3" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Full spectrum" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Classical and proprietary Ayurvedic products." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Therapies, academies, and R&D sit alongside the product line.</p>" },
    { "type": "text", "id": "patents_kicker", "label": "Patents kicker", "default": "Internationally recognized" },
    { "type": "text", "id": "patents_heading", "label": "Patents heading", "default": "Patented formulations" },
    { "type": "richtext", "id": "patents_text", "label": "Patents text", "default": "<p>Kerala Ayurveda has carried forward classical wisdom for modern wellness rituals.</p>" },
    { "type": "text", "id": "us_title", "label": "US title", "default": "US patent" },
    { "type": "richtext", "id": "us_text", "label": "US text", "default": "<p>Protected formulation details and process knowledge.</p>" },
    { "type": "text", "id": "japan_title", "label": "Japan title", "default": "Japan patent" },
    { "type": "richtext", "id": "japan_text", "label": "Japan text", "default": "<p>Recognition of the proprietary process and method.</p>" },
    { "type": "text", "id": "mark_kicker", "label": "Mark kicker", "default": "Rooted in authenticity" },
    { "type": "text", "id": "mark_heading", "label": "Mark heading", "default": "Authentic Ayurveda." },
    { "type": "richtext", "id": "mark_text", "label": "Mark text", "default": "<p>Bring the same trust cues from the Neeli landing page into Shopify.</p>" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "default": 36, "label": "Top padding" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "default": 36, "label": "Bottom padding" }
  ],
  "presets": [
    {
      "name": "Neeli brand trust"
    }
  ]
}
{% endschema %}
