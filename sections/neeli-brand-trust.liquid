{{ 'section-neeli-product-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="neeli-product-page__section neeli-product-page__section--forest neeli-reveal section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="neeli-product-page__wrap">
    <div class="neeli-trust-grid">
      <div class="neeli-trust-card">
        {{ 'Flower.png' | asset_url | image_tag: class: 'image-zoom subtle-zoom', loading: 'lazy', alt: section.settings.heading }}
        <p class="neeli-section-heading__kicker" style="color: rgba(247,243,233,0.7);">{{ section.settings.kicker }}</p>
        <h2 class="neeli-trust-card__title">{{ section.settings.heading }}</h2>
        <div class="neeli-trust-card__text rte">{{ section.settings.text }}</div>
      </div>

      <div class="neeli-trust-card">
        <p class="neeli-section-heading__kicker" style="color: rgba(247,243,233,0.7);">{{ section.settings.patents_kicker }}</p>
        <h2 class="neeli-trust-card__title">{{ section.settings.patents_heading }}</h2>
        <div class="neeli-trust-card__text rte">{{ section.settings.patents_text }}</div>

        <div class="neeli-trust-cards" style="margin-top: 1rem;">
          <div class="neeli-trust-card neeli-trust-card--outlined">
            {{ 'US_Flag.png' | asset_url | image_tag: class: 'neeli-hero-carousel__thumb-image', loading: 'lazy', alt: section.settings.us_title }}
            <h3 class="neeli-trust-card__title">{{ section.settings.us_title }}</h3>
            <div class="neeli-trust-card__text rte">{{ section.settings.us_text }}</div>
          </div>
          <div class="neeli-trust-card neeli-trust-card--outlined">
            {{ 'Japan_Flag.png' | asset_url | image_tag: class: 'neeli-hero-carousel__thumb-image', loading: 'lazy', alt: section.settings.japan_title }}
            <h3 class="neeli-trust-card__title">{{ section.settings.japan_title }}</h3>
            <div class="neeli-trust-card__text rte">{{ section.settings.japan_text }}</div>
          </div>
        </div>
      </div>

      <div class="neeli-trust-card">
        <p class="neeli-section-heading__kicker" style="color: rgba(247,243,233,0.7);">{{ section.settings.mark_kicker }}</p>
        <h2 class="neeli-trust-card__title">{{ section.settings.mark_heading }}</h2>
        {{ 'ka-mark.png' | asset_url | image_tag: class: 'image-zoom subtle-zoom', loading: 'lazy', alt: section.settings.mark_heading }}
        <div class="neeli-trust-card__text rte">{{ section.settings.mark_text }}</div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Neeli brand trust",
  "tag": "section",
  "class": "section neeli-brand-trust",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-3" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Full spectrum" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Classical and proprietary Ayurvedic products." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Therapies, academies, and R&D sit alongside the product line.</p>" },
    { "type": "text", "id": "patents_kicker", "label": "Patents kicker", "default": "Internationally recognized" },
    { "type": "text", "id": "patents_heading", "label": "Patents heading", "default": "Patented formulations" },
    { "type": "richtext", "id": "patents_text", "label": "Patents text", "default": "<p>Kerala Ayurveda has carried forward classical wisdom for modern wellness rituals.</p>" },
    { "type": "text", "id": "us_title", "label": "US title", "default": "US patent" },
    { "type": "richtext", "id": "us_text", "label": "US text", "default": "<p>Protected formulation details and process knowledge.</p>" },
    { "type": "text", "id": "japan_title", "label": "Japan title", "default": "Japan patent" },
    { "type": "richtext", "id": "japan_text", "label": "Japan text", "default": "<p>Recognition of the proprietary process and method.</p>" },
    { "type": "text", "id": "mark_kicker", "label": "Mark kicker", "default": "Rooted in authenticity" },
    { "type": "text", "id": "mark_heading", "label": "Mark heading", "default": "Authentic Ayurveda." },
    { "type": "richtext", "id": "mark_text", "label": "Mark text", "default": "<p>Bring the same trust cues from the Neeli landing page into Shopify.</p>" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "default": 36, "label": "Top padding" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "default": 36, "label": "Bottom padding" }
  ],
  "presets": [
    {
      "name": "Neeli brand trust"
    }
  ]
}
{% endschema %}
