<section class="theme-massage-ritual">
  {{ 'section-massage-ritual.css' | asset_url | stylesheet_tag }}
  <div class="theme-massage-ritual__hero">
    <img src="{{ 'massage-ritual.png' | asset_url }}" alt="Your Easy Massage Ritual" class="theme-massage-ritual__hero-image" width="1206" height="678" />
  </div>

  <div class="container-narrow theme-massage-ritual__container">
    <!-- Mobile Steps View -->
    <div class="theme-massage-ritual__mobile-grid">
      <div class="theme-massage-ritual__mobile-step">
        <div class="theme-massage-ritual__mobile-number-wrap">
          <div class="theme-massage-ritual__mobile-number">1</div>
          <div class="theme-massage-ritual__mobile-label">WARM</div>
        </div>
        <div class="theme-massage-ritual__mobile-content">
          <p class="theme-massage-ritual__mobile-desc">Warm oil penetrates - cold oil sits on the surface.</p>
        </div>
      </div>
      <div class="theme-massage-ritual__mobile-step">
        <div class="theme-massage-ritual__mobile-number-wrap">
          <div class="theme-massage-ritual__mobile-number">2</div>
          <div class="theme-massage-ritual__mobile-label">APPLY</div>
        </div>
        <div class="theme-massage-ritual__mobile-content">
          <p class="theme-massage-ritual__mobile-desc">Apply adequate amount gently onto the scalp and hair</p>
        </div>
      </div>
      <div class="theme-massage-ritual__mobile-step theme-massage-ritual__mobile-step--last">
        <div class="theme-massage-ritual__mobile-number-wrap">
          <div class="theme-massage-ritual__mobile-number">3</div>
          <div class="theme-massage-ritual__mobile-label">MASSAGE</div>
        </div>
        <div class="theme-massage-ritual__mobile-content">
          <p class="theme-massage-ritual__mobile-desc">Circular motion, 5 minutes. Fingertips, not nails.</p>
        </div>
      </div>
    </div>

    <!-- Desktop Steps View -->
    <div class="theme-massage-ritual__desktop-grid">
      <div class="theme-massage-ritual__desktop-step theme-massage-ritual__desktop-step--bordered">
        <div class="theme-massage-ritual__desktop-number">1</div>
        <div class="theme-massage-ritual__desktop-label">WARM</div>
        <p class="theme-massage-ritual__desktop-desc">Warm oil penetrates - cold oil sits on the surface.</p>
      </div>
      <div class="theme-massage-ritual__desktop-step theme-massage-ritual__desktop-step--bordered">
        <div class="theme-massage-ritual__desktop-number">2</div>
        <div class="theme-massage-ritual__desktop-label">APPLY</div>
        <p class="theme-massage-ritual__desktop-desc">Apply adequate amount gently onto the scalp and hair</p>
      </div>
      <div class="theme-massage-ritual__desktop-step">
        <div class="theme-massage-ritual__desktop-number">3</div>
        <div class="theme-massage-ritual__desktop-label">MASSAGE</div>
        <p class="theme-massage-ritual__desktop-desc">Circular motion, 5 minutes. Fingertips, not nails.</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Massage ritual",
  "settings": [],
  "presets": [{ "name": "Massage ritual" }]
}
{% endschema %}
