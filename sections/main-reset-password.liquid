<div class="neeli-container neeli-page-spacing" style="max-width: 440px; margin: 0 auto;">
  <h2 style="font-family: var(--font-heading-family); font-size: 2.5rem; color: var(--neeli-forest); text-align: center; margin-bottom: 1rem; font-weight: 400;">Reset Account Password</h2>
  <p style="font-size: 0.9375rem; color: rgba(23, 55, 45, 0.72); text-align: center; margin-bottom: 2.5rem;">Enter a new password for your account.</p>

  {%- form 'reset_customer_password' -%}
    {%- if form.errors -%}
      <div style="background: #fdf3f2; border: 1px solid #f44336; color: #1d201d; border-radius: 8px; padding: 0.75rem 1rem; margin-bottom: 1.5rem; font-size: 0.875rem;">
        {{ form.errors | default_errors }}
      </div>
    {%- endif -%}

    <div style="display: grid; gap: 1.25rem; margin-bottom: 1.75rem;">
      <div>
        <label for="password" style="display: block; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; color: rgba(23, 55, 45, 0.62); margin-bottom: 0.5rem; letter-spacing: 0.05em;">New Password</label>
        <input
          type="password"
          name="customer[password]"
          id="password"
          placeholder="New password"
          style="width: 100%; border: 1px solid rgba(23, 55, 45, 0.2); border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.9375rem; outline: none; background: #fff;"
          required
        >
      </div>

      <div>
        <label for="password_confirmation" style="display: block; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; color: rgba(23, 55, 45, 0.62); margin-bottom: 0.5rem; letter-spacing: 0.05em;">Confirm Password</label>
        <input
          type="password"
          name="customer[password_confirmation]"
          id="password_confirmation"
          placeholder="Confirm password"
          style="width: 100%; border: 1px solid rgba(23, 55, 45, 0.2); border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.9375rem; outline: none; background: #fff;"
          required
        >
      </div>
    </div>

    <button type="submit" class="neeli-review-button" style="display: inline-flex; width: 100%; justify-content: center; background: #8f4f36; border-color: #8f4f36; color: #fff; cursor: pointer; padding: 1rem 2rem;">
      Reset Password
    </button>
  {%- endform -%}
</div>

{% schema %}
{
  "name": "Reset Password",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
