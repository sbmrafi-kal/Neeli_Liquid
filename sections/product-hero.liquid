{{ 'section-neeli-product-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  id="NeeliProduct-{{ section.id }}"
  class="neeli-product-page neeli-reveal section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
>
  <script src="{{ 'neeli-product-page.js' | asset_url }}" defer="defer"></script>

  {%- if product.media.size > 0 -%}
    {%- assign hero_images = product.media -%}
  {%- else -%}
    {%- assign hero_images = 'Product_carosul_01.png|Product_carosul_02.png|Product_carosul_03.png|Product_carosul_04.png|Product_carosul_05.png' | split: '|' -%}
  {%- endif -%}

  <div class="neeli-product-page__wrap">
    <div class="neeli-product-page__hero">
      <div class="neeli-product-page__hero-media">
        <div class="neeli-hero-carousel" data-neeli-carousel data-neeli-autoplay="true" data-neeli-interval="4800">
          <div class="neeli-hero-carousel__stage">
            {%- for media in hero_images -%}
              <figure class="neeli-hero-carousel__slide{% if forloop.first %} is-active{% endif %}" data-neeli-carousel-slide>
                {%- if forloop.first -%}
                  {%- assign hero_loading = 'eager' -%}
                {%- else -%}
                  {%- assign hero_loading = 'lazy' -%}
                {%- endif -%}
                {%- if media.preview_image != blank -%}
                  <img src="{{ media.preview_image | image_url: width: 750 }}" class="neeli-hero-carousel__image image-zoom" loading="{{ hero_loading }}" width="750" height="1000" alt="{{ product.title | escape }}">
                {%- elsif media.src != blank -%}
                  <img src="{{ media | image_url: width: 750 }}" class="neeli-hero-carousel__image image-zoom" loading="{{ hero_loading }}" width="750" height="1000" alt="{{ product.title | escape }}">
                {%- else -%}
                  <img src="{{ media | asset_url }}" class="neeli-hero-carousel__image image-zoom" loading="{{ hero_loading }}" width="750" height="1000" alt="{{ product.title | escape }}">
                {%- endif -%}
              </figure>
            {%- endfor -%}

            <button class="neeli-hero-carousel__control neeli-hero-carousel__control--prev" type="button" aria-label="Previous image" data-neeli-carousel-prev>
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </button>
            <button class="neeli-hero-carousel__control neeli-hero-carousel__control--next" type="button" aria-label="Next image" data-neeli-carousel-next>
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </button>
          </div>

          <div class="neeli-hero-carousel__thumbs" role="tablist" aria-label="Product gallery thumbnails">
            {%- for media in hero_images -%}
              <button
                class="neeli-hero-carousel__thumb{% if forloop.first %} is-active{% endif %}"
                type="button"
                aria-label="Show image {{ forloop.index }}"
                data-neeli-carousel-thumb="{{ forloop.index0 }}"
              >
                {%- if media.preview_image != blank -%}
                  <img src="{{ media.preview_image | image_url: width: 120 }}" class="neeli-hero-carousel__thumb-image" loading="lazy" width="90" height="120" alt="">
                {%- elsif media.src != blank -%}
                  <img src="{{ media | image_url: width: 120 }}" class="neeli-hero-carousel__thumb-image" loading="lazy" width="90" height="120" alt="">
                {%- else -%}
                  <img src="{{ media | asset_url }}" class="neeli-hero-carousel__thumb-image" loading="lazy" width="90" height="120" alt="">
                {%- endif -%}
              </button>
            {%- endfor -%}
          </div>

          <div class="neeli-hero-carousel__stats">
            {%- assign stat_blocks = section.blocks | where: "type", "hero_stat" -%}
            {%- if stat_blocks.size > 0 -%}
              {%- for block in stat_blocks -%}
                <div class="neeli-hero-carousel__stat" {{ block.shopify_attributes }}>
                  <div class="neeli-hero-carousel__stat-value">{{ block.settings.value }}</div>
                  <div class="neeli-hero-carousel__stat-label">{{ block.settings.label }}</div>
                </div>
              {%- endfor -%}
            {%- else -%}
              <div class="neeli-hero-carousel__stat">
                <div class="neeli-hero-carousel__stat-value">4.64★</div>
                <div class="neeli-hero-carousel__stat-label">Ratings</div>
              </div>
              <div class="neeli-hero-carousel__stat">
                <div class="neeli-hero-carousel__stat-value">312</div>
                <div class="neeli-hero-carousel__stat-label">Reviews</div>
              </div>
              <div class="neeli-hero-carousel__stat">
                <div class="neeli-hero-carousel__stat-value">30</div>
                <div class="neeli-hero-carousel__stat-label">Uses</div>
              </div>
              <div class="neeli-hero-carousel__stat">
                <div class="neeli-hero-carousel__stat-value">300+</div>
                <div class="neeli-hero-carousel__stat-label">Happy Customers</div>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>

      <div
        id="ProductInfo-{{ section.id }}"
        class="neeli-product-page__hero-info"
      >
        <div class="neeli-product-page__hero-header">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'text' -%}
                {%- if block.settings.text != blank -%}
                  <div class="neeli-product-page__badge-row" {{ block.shopify_attributes }}>
                    <span class="neeli-product-page__badge">{{ block.settings.text }}</span>
                  </div>
                {%- endif -%}
              {%- when 'title' -%}
                <div class="neeli-product-page__title-wrap" {{ block.shopify_attributes }}>
                  <h1 class="neeli-product-page__title">{{ product.title | escape }}</h1>
                </div>
              {%- when 'caption' -%}
                {%- if block.settings.text != blank -%}
                  <p
                    class="neeli-product-page__subtitle{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}"
                    {{ block.shopify_attributes }}
                  >
                    {{ block.settings.text }}
                  </p>
                {%- endif -%}
              {%- when 'custom_liquid' -%}
                <div {{ block.shopify_attributes }}>{{ block.settings.custom_liquid }}</div>
            {%- endcase -%}
          {%- endfor -%}
        </div>

        <div class="neeli-product-page__form-card">
          <div class="neeli-product-page__body neeli-product-page__intro" style="margin-bottom: 1.5rem;">
            {%- if product.description != blank -%}
              {{ product.description | strip_html | truncatewords: 35 }}
            {%- else -%}
              Hair recovery needs two wins - reduce the fall and support new growth. Neelibhringadi works both sides.
            {%- endif -%}
          </div>

          <!-- Dynamic Shopify Form -->
          {%- form 'product', product, id: "neeli-product-form", class: "neeli-product-form" -%}
            <!-- Product Price -->
            <div class="neeli-product-price-row" style="display: flex; align-items: baseline; gap: 1rem; margin-bottom: 1.5rem;">
              <span style="font-size: 2rem; font-weight: 700; color: var(--neeli-forest);">{{ product.selected_or_first_available_variant.price | money }}</span>
              {%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
                <span style="font-size: 1.25rem; text-decoration: line-through; color: rgba(23, 55, 45, 0.44);">{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
              {%- endif -%}
            </div>

            <!-- Variant Select -->
            {%- if product.variants.size > 1 -%}
              <div class="neeli-variant-picker" style="margin-bottom: 1.5rem;">
                <label for="ProductSelect-{{ section.id }}" style="display: block; font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; color: rgba(23, 55, 45, 0.62); margin-bottom: 0.5rem; letter-spacing: 0.05em;">Select Option</label>
                <select name="id" id="ProductSelect-{{ section.id }}" class="neeli-variant-select" style="width: 100%; border: 1px solid rgba(23, 55, 45, 0.2); border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.9375rem; background: #fff; color: var(--neeli-forest); outline: none;">
                  {%- for variant in product.variants -%}
                    <option value="{{ variant.id }}" 
                      {% if variant == product.selected_or_first_available_variant %}selected="selected"{% endif %} 
                      {% unless variant.available %}disabled="disabled"{% endunless %}>
                      {{ variant.title }} - {{ variant.price | money }} {% unless variant.available %}(Sold Out){% endunless %}
                    </option>
                  {%- endfor -%}
                </select>
              </div>
            {%- else -%}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            {%- endif -%}

            <!-- Quantity Selector -->
            <div class="neeli-quantity-selector" style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.75rem;">
              <span style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; color: rgba(23, 55, 45, 0.62); letter-spacing: 0.05em;">Quantity</span>
              <div style="display: flex; align-items: center; border: 1px solid rgba(23, 55, 45, 0.2); border-radius: 8px; overflow: hidden; background: #fff;">
                <button type="button" onclick="adjustQty(-1)" style="border: none; background: transparent; padding: 0.5rem 1rem; cursor: pointer; color: var(--neeli-forest); font-weight: 600; font-size: 1rem;">-</button>
                <input type="number" id="Quantity-{{ section.id }}" name="quantity" value="1" min="1" style="width: 50px; text-align: center; border: none; outline: none; font-size: 0.9375rem; color: var(--neeli-forest); background: transparent; pointer-events: none;">
                <button type="button" onclick="adjustQty(1)" style="border: none; background: transparent; padding: 0.5rem 1rem; cursor: pointer; color: var(--neeli-forest); font-weight: 600; font-size: 1rem;">+</button>
              </div>
            </div>

            <!-- Add to Cart CTA -->
            <button type="submit" name="add" class="neeli-review-button" style="width: 100%; display: flex; justify-content: center; align-items: center; padding: 1.125rem 2rem; font-size: 1rem; background: #8f4f36; border-color: #8f4f36; color: #fff; cursor: pointer; margin-bottom: 1.5rem; text-transform: uppercase; font-weight: 700; border-radius: 9999px; letter-spacing: 0.05em; transition: transform 0.2s ease, background-color 0.2s ease;">
              {%- if product.selected_or_first_available_variant.available -%}
                Add to Cart
              {%- else -%}
                Sold Out
              {%- endif -%}
            </button>
          {%- endform -%}

          <script>
            function adjustQty(amount) {
              const input = document.getElementById('Quantity-{{ section.id }}');
              let currentVal = parseInt(input.value) || 1;
              currentVal = Math.max(1, currentVal + amount);
              input.value = currentVal;
            }
          </script>

          {%- for block in section.blocks -%}
            {%- if block.type == 'hero_quote' -%}
              <blockquote class="neeli-product-page__quote-wrap" {{ block.shopify_attributes }}>
                <p class="neeli-product-page__quote">{{ block.settings.quote }}</p>
                <p class="neeli-product-page__quote-meta">{{ block.settings.author }}</p>
              </blockquote>
            {%- endif -%}
          {%- endfor -%}

          {%- for block in section.blocks -%}
            {%- if block.type == 'hero_feature' and block.settings.text != blank -%}
              <p class="neeli-product-page__body neeli-product-page__cert-note" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </p>
            {%- endif -%}
          {%- endfor -%}

          <div class="neeli-stamp-card motion-panel" style="margin-top: 1rem;">
            <div class="neeli-stamp-card__top">
              {%- assign stamp_images = 'stamp_01.png|stamp_02.png|stamp_03.png|stamp_04.png|stamp_05.png' | split: '|' -%}
              {%- for stamp in stamp_images -%}
                <div class="neeli-stamp-card__stamp">
                  {%- assign stamp_alt = 'Certification ' | append: forloop.index -%}
                  <img src="{{ stamp | asset_url }}" class="neeli-stamp-card__stamp-image" loading="lazy" width="1920" height="1080" alt="{{ stamp_alt | escape }}">
                </div>
              {%- endfor -%}
            </div>
            <div class="neeli-stamp-card__stats">
              <div class="neeli-stamp-card__stat">
                <div class="neeli-stamp-card__stat-value">1945</div>
                <div class="neeli-stamp-card__stat-label">Established</div>
              </div>
              <div class="neeli-stamp-card__stat">
                <div class="neeli-stamp-card__stat-value">350+</div>
                <div class="neeli-stamp-card__stat-label">Products</div>
              </div>
              <div class="neeli-stamp-card__stat">
                <div class="neeli-stamp-card__stat-value">Clinics &amp; Academy</div>
                <div class="neeli-stamp-card__stat-label">Expert led</div>
              </div>
            </div>
          </div>

          {%- for block in section.blocks -%}
            {%- if block.type == 'hero_note' and block.settings.text != blank -%}
              <p class="neeli-product-page__body neeli-product-page__hero-note" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </p>
            {%- endif -%}
          {%- endfor -%}

          <div class="neeli-reorder-card cta-sheen motion-panel" style="margin-top: 1.5rem;">
            <button class="neeli-reorder-card__button" type="button" onclick="document.getElementById('neeli-product-form').submit();">
              <div class="neeli-reorder-card__main">
                <svg class="neeli-reorder-card__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M3 3v5h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <div>
                  <div class="neeli-reorder-card__title">Reorder now</div>
                  <div class="neeli-reorder-card__meta">Quick checkouts</div>
                </div>
              </div>
              <div class="neeli-reorder-card__price">
                {%- if product.compare_at_price > product.price -%}
                  <span class="neeli-reorder-card__price-old">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
                <span class="neeli-reorder-card__price-new">{{ product.price | money }}</span>
              </div>
            </button>
          </div>

          <div class="neeli-delivery-row">
            <div class="neeli-delivery-row__item">
              <svg class="neeli-delivery-row__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M3 7h11v10H3z" stroke="currentColor" stroke-width="1.7" />
                <path d="M14 10h3l2 2v5h-5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                <circle cx="7" cy="18" r="1.4" fill="currentColor" />
                <circle cx="17" cy="18" r="1.4" fill="currentColor" />
              </svg>
              <span>2-4 day delivery</span>
            </div>
            <div class="neeli-delivery-row__item">
              <svg class="neeli-delivery-row__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M3 7h18v10H3z" stroke="currentColor" stroke-width="1.7" />
                <path d="M8 12h8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
              </svg>
              <span>COD available</span>
            </div>
            <div class="neeli-delivery-row__item">
              <svg class="neeli-delivery-row__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M6 8h12l-1 11H7L6 8Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" />
                <path d="M9 8a3 3 0 0 1 6 0" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
              </svg>
              <span>7-day returns</span>
            </div>
          </div>

          {%- for block in section.blocks -%}
            {%- if block.type == 'hero_upsell' -%}
              <div class="neeli-upsell-card hover-rise" {{ block.shopify_attributes }}>
                <img src="{{ 'upsell.png' | asset_url }}" class="neeli-upsell-card__image" loading="lazy" width="1000" height="1000" alt="{{ block.settings.title | escape }}">
                <div class="neeli-upsell-card__copy">
                  <div class="neeli-upsell-card__title">{{ block.settings.title }}</div>
                  <p class="neeli-upsell-card__text">{{ block.settings.text }}</p>
                </div>
                {%- if block.settings.button_label != blank -%}
                  {%- if block.settings.button_link != blank -%}
                    <a class="neeli-upsell-card__button premium-button" href="{{ block.settings.button_link }}">
                      {{ block.settings.button_label }}
                    </a>
                  {%- else -%}
                    <span class="neeli-upsell-card__button premium-button" role="presentation">
                      {{ block.settings.button_label }}
                    </span>
                  {%- endif -%}
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "product hero",
  "tag": "section",
  "class": "section neeli-product-hero",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_sticky_info",
      "default": true,
      "label": "Sticky product info"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "media_size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "large",
      "label": "Media size"
    },
    {
      "type": "checkbox",
      "id": "constrain_to_viewport",
      "default": true,
      "label": "Constrain to viewport"
    },
    {
      "type": "select",
      "id": "media_fit",
      "options": [
        { "value": "contain", "label": "Contain" },
        { "value": "cover", "label": "Cover" }
      ],
      "default": "contain",
      "label": "Media fit"
    },
    {
      "type": "select",
      "id": "gallery_layout",
      "options": [
        { "value": "stacked", "label": "Stacked" },
        { "value": "columns", "label": "Columns" },
        { "value": "thumbnail", "label": "Thumbnail" },
        { "value": "thumbnail_slider", "label": "Thumbnail slider" }
      ],
      "default": "stacked",
      "label": "Gallery layout"
    },
    {
      "type": "select",
      "id": "mobile_thumbnails",
      "options": [
        { "value": "columns", "label": "Columns" },
        { "value": "show", "label": "Show" },
        { "value": "hide", "label": "Hide" }
      ],
      "default": "hide",
      "label": "Mobile thumbnails"
    },
    {
      "type": "select",
      "id": "media_position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left",
      "label": "Media position"
    },
    {
      "type": "checkbox",
      "id": "hide_variants",
      "default": false,
      "label": "Hide variant media"
    },
    {
      "type": "checkbox",
      "id": "enable_video_looping",
      "default": false,
      "label": "Enable video looping"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 36,
      "label": "Top padding"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 16,
      "label": "Bottom padding"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Hero badge",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "default": "Minimizes hair fall",
          "label": "Badge text"
        }
      ]
    },
    {
      "type": "title",
      "name": "Title",
      "limit": 1
    },
    {
      "type": "caption",
      "name": "Subtitle",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "default": "One oil for complete hair recovery",
          "label": "Text"
        },
        {
          "type": "select",
          "id": "text_style",
          "options": [
            { "value": "body", "label": "Body" },
            { "value": "subtitle", "label": "Subtitle" },
            { "value": "uppercase", "label": "Uppercase" }
          ],
          "default": "body",
          "label": "Style"
        }
      ]
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1
    },
    {
      "type": "variant_picker",
      "name": "Variant picker",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "picker_type",
          "options": [
            { "value": "dropdown", "label": "Dropdown" },
            { "value": "button", "label": "Buttons" }
          ],
          "default": "button",
          "label": "Picker type"
        },
        {
          "id": "swatch_shape",
          "label": "Swatch shape",
          "type": "select",
          "options": [
            { "value": "circle", "label": "Circle" },
            { "value": "square", "label": "Square" },
            { "value": "none", "label": "None" }
          ],
          "default": "circle"
        }
      ]
    },
    {
      "type": "quantity_selector",
      "name": "Quantity selector",
      "limit": 1
    },
    {
      "type": "buy_buttons",
      "name": "Buy buttons",
      "limit": 1,
      "settings": [
        { "type": "checkbox", "id": "show_dynamic_checkout", "default": true, "label": "Show dynamic checkout" },
        { "type": "checkbox", "id": "show_gift_card_recipient", "default": true, "label": "Show gift card recipient" }
      ]
    },
    {
      "type": "description",
      "name": "Description",
      "limit": 1
    },
    {
      "type": "share",
      "name": "Share",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "share_label", "default": "Share", "label": "Label" }
      ]
    },
    {
      "type": "custom_liquid",
      "name": "liquid",
      "settings": [
        { "type": "liquid", "id": "custom_liquid", "label": "Liquid" }
      ]
    },
    {
      "type": "hero_stat",
      "name": "Hero stat",
      "settings": [
        { "type": "text", "id": "value", "default": "4.64★", "label": "Value" },
        { "type": "text", "id": "label", "default": "Ratings", "label": "Label" }
      ]
    },
    {
      "type": "hero_feature",
      "name": "Hero feature",
