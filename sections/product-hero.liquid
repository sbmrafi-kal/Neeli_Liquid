  {{ 'section-theme-product-page.css' | asset_url | stylesheet_tag }}
  {{ 'section-product-hero.css' | asset_url | stylesheet_tag }}
  {{ 'product-hero.js' | asset_url | script_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: 48px;
    padding-bottom: 32px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: 48px;
      padding-bottom: 32px;
    }
  }

  .theme-product-info-desktop {
    display: none;
  }

  .theme-product-info-mobile {
    display: block;
    margin-top: 1.5rem;
  }

  @media screen and (min-width: 990px) {
    .theme-product-info-desktop {
      display: block;
    }
    .theme-product-info-mobile {
      display: none;
    }
  }

  /* Carousel control alignment */
  .theme-hero-carousel__control {
    top: 50%;
    transform: translateY(-50%);
  }

  /* Thumbnail size and active shadow */
  .theme-hero-carousel__thumb-image {
    width: 90px;
    height: 120px;
  }
  .theme-hero-carousel__thumb.is-active {
    box-shadow: 0 0 6px var(--brand-gold);
  }

  /* Badge styling */
  .micro-fade-delayed.mt-4.inline-flex {
    background: var(--brand-gold-gradient);
    font-size: 13px;
    border-color: #d8cba1;
  }

  /* Title typography */
  .theme-product-page__title {
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  /* Quote block */
  .theme-product-page__quote-wrap {
    background: rgba(248,241,223,0.9);
    color: #17372d;
  }
  .theme-product-page__quote-meta {
    text-decoration: underline;
  }

  /* Stamp grid layout */
  .theme-stamp-card__stamp {
    flex: 1 0 20%;
    gap: 12px;
    mix-blend-mode: multiply;
  }

  /* Delivery rows */
  .theme-delivery-row__item svg {
    stroke: #17372d;
  }
  .theme-delivery-row__item {
    font-size: 10px;
    border-bottom: 1px solid #e0e0e0;
  }

  /* Buttons */
  .cta-sheen, .premium-button {
    background: var(--brand-gold-gradient, linear-gradient(45deg, #f4bb28, #ffd700));
    transition: transform var(--duration-short) ease;
  }
  .cta-sheen:hover, .premium-button:hover {
    transform: translateY(-2px);
  }
{%- endstyle -%}

{%- assign product_override = all_products[section.settings.product] -%}
{%- if product_override != blank -%}
  {%- assign product = product_override -%}
{%- endif -%}
{%- if product == blank -%}
  {%- assign product = all_products['neelibhringadi-keram'] -%}
{%- endif -%}
{%- assign product_title = product.title | default: 'Neelibhringadi Keram' -%}
{%- assign product_variant = product.selected_or_first_available_variant -%}
{%- assign product_price = product_variant.price | default: 38500 -%}

<section
  id="NeeliProduct-{{ section.id }}"
  class="theme-product-page theme-reveal section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
>
  <script src="{{ 'theme-product-page.js' | asset_url }}" defer="defer"></script>

{%- assign hero_images = 'Product_carosul_01.png|Product_carosul_02.png|Product_carosul_03.png|Product_carosul_04.png|Product_carosul_05.png' | split: '|' -%}

  <div class="theme-product-page__wrap">
    <div class="theme-product-page__hero">
      <div class="theme-product-page__hero-media">
        <div class="theme-hero-carousel" data-theme-carousel data-theme-autoplay="false" data-theme-interval="4800">
          <div class="theme-hero-carousel__stage">
            {%- for media in hero_images -%}
              <figure class="theme-hero-carousel__slide{% if forloop.first %} is-active{% endif %}" data-theme-carousel-slide>
                {%- if forloop.first -%}
                  {%- assign hero_loading = 'eager' -%}
                {%- else -%}
                  {%- assign hero_loading = 'lazy' -%}
                {%- endif -%}
                {%- if media.preview_image != blank -%}
                  <img src="{{ media.preview_image | image_url: width: 750 }}" class="theme-hero-carousel__image image-zoom" loading="{{ hero_loading }}" width="750" height="1000" alt="{{ product_title | escape }}">
                {%- elsif media.src != blank -%}
                  <img src="{{ media | image_url: width: 750 }}" class="theme-hero-carousel__image image-zoom" loading="{{ hero_loading }}" width="750" height="1000" alt="{{ product_title | escape }}">
                {%- else -%}
                  <img src="{{ media | asset_url }}" class="theme-hero-carousel__image image-zoom" loading="{{ hero_loading }}" width="750" height="1000" alt="{{ product_title | escape }}">
                {%- endif -%}
              </figure>
            {%- endfor -%}

            <button class="theme-hero-carousel__control theme-hero-carousel__control--prev" type="button" aria-label="Previous image" data-theme-carousel-prev>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-left"><path d="m15 18-6-6 6-6"/></svg>
            </button>
            <button class="theme-hero-carousel__control theme-hero-carousel__control--next" type="button" aria-label="Next image" data-theme-carousel-next>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right"><path d="m9 18 6-6-6-6"/></svg>
            </button>
          </div>

          <div class="theme-hero-carousel__thumbs" role="tablist" aria-label="Product gallery thumbnails">
            {%- for media in hero_images -%}
              <button
                class="theme-hero-carousel__thumb{% if forloop.first %} is-active{% endif %}"
                type="button"
                aria-label="Show image {{ forloop.index }}"
                data-theme-carousel-thumb="{{ forloop.index0 }}"
              >
                {%- if media.preview_image != blank -%}
                  <img src="{{ media.preview_image | image_url: width: 120 }}" class="theme-hero-carousel__thumb-image" loading="lazy" width="90" height="120" alt="">
                {%- elsif media.src != blank -%}
                  <img src="{{ media | image_url: width: 120 }}" class="theme-hero-carousel__thumb-image" loading="lazy" width="90" height="120" alt="">
                {%- else -%}
                  <img src="{{ media | asset_url }}" class="theme-hero-carousel__thumb-image" loading="lazy" width="90" height="120" alt="">
                {%- endif -%}
              </button>
            {%- endfor -%}
          </div>

          <div class="theme-hero-carousel__stats">
            {%- assign stat_blocks = section.blocks | where: "type", "hero_stat" -%}
            {%- for block in stat_blocks -%}
              <div class="theme-hero-carousel__stat" {{ block.shopify_attributes }}>
                <div class="theme-hero-carousel__stat-value">{{ block.settings.value }}</div>
                <div class="theme-hero-carousel__stat-label">{{ block.settings.label }}</div>
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>

      <!-- DESKTOP HERO INFO COLUMN -->
      <div id="ProductInfo-{{ section.id }}" class="theme-product-page__hero-info theme-product-info-desktop">
        <div class="theme-product-page__hero-header">
          {%- assign badges = section.blocks | where: "type", "text" -%}
          {%- if badges.size > 0 -%}
            <div class="micro-fade-delayed mt-4 inline-flex flex-wrap items-center gap-2 rounded-[18px] border border-[#d8cba1] bg-[#f8f0d6] px-4 py-2 text-[12px] font-medium uppercase tracking-[0.07em] text-[#17372d] sm:text-[13px] xl:text-[14px]">
              {%- for block in badges -%}
                {%- unless forloop.first -%}<span class="text-[13px] leading-none">•</span>{%- endunless -%}
                <span {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
              {%- endfor -%}
            </div>
          {%- else -%}
            <div class="micro-fade-delayed mt-4 inline-flex flex-wrap items-center gap-2 rounded-[18px] border border-[#d8cba1] bg-[#f8f0d6] px-4 py-2 text-[12px] font-medium uppercase tracking-[0.07em] text-[#17372d] sm:text-[13px] xl:text-[14px]">
              <span class="text-[13px] leading-none">•</span>
              <span>Minimizes hair fall</span>
              <span class="text-[13px] leading-none">•</span>
              <span>Supports hair growth</span>
            </div>
          {%- endif -%}

          <div class="theme-product-page__category">
            {{ section.settings.category_label }}
          </div>

          <div class="theme-product-page__title-wrap">
            <h1 class="theme-product-page__title">{{ product_title | escape }}</h1>
          </div>

          <div class="theme-product-page__rating-row" aria-label="Product rating">
            <div class="theme-product-page__price-inline">
              {{ product_price | money }}
            </div>
            <div class="theme-product-page__rating-inline">
              <span class="theme-product-page__rating-stars" aria-hidden="true">★★★★☆</span>
              <span class="theme-product-page__rating-count">{{ section.settings.review_count }}</span>
            </div>
          </div>

          {%- assign subtitle_block = section.blocks | where: "type", "caption" | first -%}
          <p class="theme-product-page__subtitle subtitle">
            {%- if subtitle_block -%}
              {{ subtitle_block.settings.text }}
            {%- else -%}
              One oil for complete hair recovery
            {%- endif -%}
          </p>
        </div>

        {%- assign hero_note_block = section.blocks | where: "type", "hero_note" | first -%}
        <p class="theme-product-page__body theme-product-page__intro">
          {%- if hero_note_block -%}
            {{ hero_note_block.settings.text }}
          {%- else -%}
            Hair recovery needs two wins - reduce the fall and support new growth. Most oils address one. Neelibhringadi works both sides.
          {%- endif -%}
        </p>

        {%- assign quote_block = section.blocks | where: "type", "hero_quote" | first -%}
        <div class="theme-product-page__quote-wrap motion-panel">
          <div class="theme-product-page__quote">
            {%- if quote_block -%}
              {{ quote_block.settings.quote }}
            {%- else -%}
              "Hair fall reduced noticeably, and I can already see tiny baby hairs coming"
            {%- endif -%}
          </div>
          <div class="theme-product-page__quote-meta">
            {%- if quote_block -%}
              {{ quote_block.settings.author }}
            {%- else -%}
              - ANU R., CHENNAI
            {%- endif -%}
          </div>
        </div>

        {%- assign feature_block = section.blocks | where: "type", "hero_feature" | first -%}
        <p class="theme-product-page__body theme-product-page__cert-note">
          {%- if feature_block -%}
            {{ feature_block.settings.title }} {{ feature_block.settings.text }}
          {%- else -%}
            Made by BAMS doctors in our GMP & ISO - certified facility. FDA compliant and AYUSH licensed.
          {%- endif -%}
        </p>

        <div class="theme-stamp-card motion-panel">
          <div class="theme-stamp-card__top">
            {%- assign stamp_images = 'stamp_01.png|stamp_02.png|stamp_03.png|stamp_04.png|stamp_05.png' | split: '|' -%}
            {%- for stamp in stamp_images -%}
              <div class="theme-stamp-card__stamp">
                {%- assign stamp_alt = 'Certification ' | append: forloop.index -%}
                <img src="{{ stamp | asset_url }}" class="theme-stamp-card__stamp-image" loading="lazy" width="1920" height="1080" alt="{{ stamp_alt | escape }}">
              </div>
            {%- endfor -%}
          </div>
          <div class="theme-stamp-card__stats">
            <div class="theme-stamp-card__stat">
              <div class="theme-stamp-card__stat-value">{{ section.settings.stat_1_value }}</div>
              <div class="theme-stamp-card__stat-label">{{ section.settings.stat_1_label }}</div>
            </div>
            <div class="theme-stamp-card__stat">
              <div class="theme-stamp-card__stat-value">{{ section.settings.stat_2_value }}</div>
              <div class="theme-stamp-card__stat-label">{{ section.settings.stat_2_label }}</div>
            </div>
            <div class="theme-stamp-card__stat">
              <div class="theme-stamp-card__stat-value">{{ section.settings.stat_3_value }}</div>
              <div class="theme-stamp-card__stat-label">{{ section.settings.stat_3_label }}</div>
            </div>
          </div>
        </div>

        {%- if section.settings.description_block != blank -%}
          <p class="theme-product-page__description-block">
            {{ section.settings.description_block }}
          </p>
        {%- endif -%}

        <div class="theme-product-page__form-card">
          <!-- Dynamic Shopify Form -->
          {%- if product != blank and product.selected_or_first_available_variant != blank -%}
          {%- form 'product', product, id: "theme-product-form", class: "theme-product-form" -%}
            <!-- Variant Select -->
            {%- if product.variants.size > 1 -%}
              <div class="theme-variant-picker theme-variant-picker--desktop">
                <label for="ProductSelect-{{ section.id }}" class="theme-variant-picker__label">Select Option</label>
                <select name="id" id="ProductSelect-{{ section.id }}" class="theme-variant-select theme-variant-select--desktop">
                  {%- for variant in product.variants -%}
                    <option value="{{ variant.id }}" 
                      data-price="{{ variant.price | money }}"
                      data-compare-price="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money }}{% endif %}"
                      data-available="{{ variant.available }}"
                      {% if variant == product.selected_or_first_available_variant %}selected="selected"{% endif %}>
                      {{ variant.title }}
                    </option>
                  {%- endfor -%}
                </select>
              </div>
            {%- else -%}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            {%- endif -%}

            <input type="hidden" name="quantity" value="1">

            <!-- Unified CTA Sheen Submit Button -->
            <button type="submit" name="add" class="theme-reorder-card__button theme-reorder-card__button--desktop cta-sheen hover-rise" {% unless product.selected_or_first_available_variant.available %}disabled="disabled"{% endunless %}>
              <div class="flex flex-1 items-center gap-4 px-5 py-3">
                <svg class="theme-reorder-card__icon" stroke="currentColor" stroke-width="1.8" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M3 3v5h5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <div>
                  <div class="theme-reorder-btn-text theme-reorder-btn-text--desktop">
                    {%- if product.selected_or_first_available_variant.available -%}
                      Reorder now
                    {%- else -%}
                      Sold Out
                    {%- endif -%}
                  </div>
                  {%- if section.settings.cta_meta != blank -%}
                    <div class="mt-1 text-[12px] text-white/72">{{ section.settings.cta_meta }}</div>
                  {%- endif -%}
                </div>
              </div>
              <div class="flex items-center justify-end gap-3 border-t border-white/12 px-5 py-3 sm:min-w-[188px] sm:border-l sm:border-t-0">
                <span class="theme-reorder-card__price-old{% unless product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %} is-hidden{% endunless %}">
                  {{ product_variant.compare_at_price | money }}
                </span>
                <span class="theme-reorder-card__price-new">
                  {{ product_price | money }}
                </span>
              </div>
            </button>
          {%- endform -%}
          {%- endif -%}
        </div>

        <div class="theme-delivery-row">
          <div class="theme-delivery-row__item">
            <svg class="theme-delivery-row__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M3 7h11v10H3z" stroke="currentColor" stroke-width="1.7" />
              <path d="M14 10h3l2 2v5h-5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
              <circle cx="7" cy="18" r="1.4" fill="currentColor" />
              <circle cx="17" cy="18" r="1.4" fill="currentColor" />
            </svg>
            <span>{{ section.settings.delivery_1_text }}</span>
          </div>
          <div class="theme-delivery-row__item">
            <svg class="theme-delivery-row__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M3 7h18v10H3z" stroke="currentColor" stroke-width="1.7" />
              <path d="M8 12h8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
            </svg>
            <span>{{ section.settings.delivery_2_text }}</span>
          </div>
          <div class="theme-delivery-row__item">
            <svg class="theme-delivery-row__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M6 8h12l-1 11H7L6 8Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" />
              <path d="M9 8a3 3 0 0 1 6 0" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
            </svg>
            <span>{{ section.settings.delivery_3_text }}</span>
          </div>
        </div>

        {%- assign upsell_block = section.blocks | where: "type", "hero_upsell" | first -%}
        {%- if upsell_block -%}
          <div class="theme-upsell-card hover-rise">
            <img src="{{ 'upsell.png' | asset_url }}" class="theme-upsell-card__image" loading="lazy" width="1000" height="1000" alt="{{ upsell_block.settings.title | escape }}">
            <div class="theme-upsell-card__copy">
              <div class="theme-upsell-card__title">{{ upsell_block.settings.title }}</div>
              <p class="theme-upsell-card__text">{{ upsell_block.settings.text }}</p>
            </div>
            {%- if upsell_block.settings.button_label != blank -%}
              {%- if upsell_block.settings.button_link != blank -%}
                <a class="theme-upsell-card__button premium-button" href="{{ upsell_block.settings.button_link }}">
                  {{ upsell_block.settings.button_label }}
                </a>
              {%- else -%}
                <span class="theme-upsell-card__button premium-button" role="presentation">
                  {{ upsell_block.settings.button_label }}
                </span>
              {%- endif -%}
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    <!-- MOBILE HERO INFO CONTAINER (Spans full narrow width) -->
    <div class="theme-product-info-mobile">
      {%- if badges.size > 0 -%}
        <div class="inline-flex flex-wrap items-center gap-2 rounded-full border border-[#e4cf8f] bg-[#fbf4de] px-3 py-1.5 text-[10px] font-medium uppercase tracking-[0.08em] text-[#17372d]">
          {%- for block in badges -%}
            {%- unless forloop.first -%}<span class="text-[11px] leading-none">•</span>{%- endunless -%}
            <span>{{ block.settings.text }}</span>
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="inline-flex flex-wrap items-center gap-2 rounded-full border border-[#e4cf8f] bg-[#fbf4de] px-3 py-1.5 text-[10px] font-medium uppercase tracking-[0.08em] text-[#17372d]">
          <span class="text-[11px] leading-none">•</span>
          <span>Minimizes hair fall</span>
          <span class="text-[11px] leading-none">•</span>
          <span>Supports hair growth</span>
        </div>
      {%- endif -%}

      <!-- Mobile Checkout Forms -->
      {%- if product != blank and product.selected_or_first_available_variant != blank -%}
      {%- form 'product', product, id: "theme-product-form-mobile", class: "theme-product-form theme-product-form--mobile" -%}
        <!-- Variant Selector -->
        {%- if product.variants.size > 1 -%}
          <div class="theme-variant-picker theme-variant-picker--mobile">
            <select name="id" id="ProductSelect-Mobile-{{ section.id }}" class="theme-variant-select theme-variant-select--mobile">
              {%- for variant in product.variants -%}
                <option value="{{ variant.id }}" 
                  data-price="{{ variant.price | money }}"
                  data-compare-price="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money }}{% endif %}"
                  data-available="{{ variant.available }}"
                  {% if variant == product.selected_or_first_available_variant %}selected="selected"{% endif %}>
                  {{ variant.title }}
                </option>
              {%- endfor -%}
            </select>
          </div>
        {%- else -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        {%- endif -%}

        <input type="hidden" name="quantity" value="1">

        <!-- Mobile Unified Reorder / Checkout CTA -->
        <button type="submit" name="add" class="theme-reorder-card__button theme-reorder-card__button--mobile cta-sheen" {% unless product.selected_or_first_available_variant.available %}disabled="disabled"{% endunless %}>
          <div class="flex items-center gap-3">
            <svg class="theme-reorder-card__icon theme-reorder-card__icon--mobile" stroke="currentColor" stroke-width="1.8" fill="none" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M3 3v5h5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <div>
              <div class="theme-reorder-btn-text theme-reorder-btn-text--mobile">
                {%- if product.selected_or_first_available_variant.available -%}
                  Reorder now
                {%- else -%}
                  Sold Out
                {%- endif -%}
              </div>
              {%- if section.settings.cta_meta != blank -%}
                <div class="mt-1 text-[11px] text-white/72">{{ section.settings.cta_meta }}</div>
              {%- endif -%}
            </div>
          </div>
          <div class="flex items-center gap-2 border-l border-white/14 pl-4">
                <span class="theme-reorder-card__price-old{% unless product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %} is-hidden{% endunless %}">
              {{ product_variant.compare_at_price | money }}
            </span>
            <span class="theme-reorder-card__price-new theme-reorder-card__price-new--mobile">
              {{ product_price | money }}
            </span>
          </div>
        </button>
      {%- endform -%}
      {%- endif -%}

      <h2 class="mt-4 font-serif text-[15px] font-normal leading-none text-[#17372d]/84">
        {%- if subtitle_block -%}
          {{ subtitle_block.settings.text }}
        {%- else -%}
          One oil for complete hair recovery
        {%- endif -%}
      </h2>
      <div class="mt-3 h-px w-full bg-[#17372d]/10" />

      <p class="mt-4 text-[14px] leading-[1.42] text-[#17372d]/72">
        {%- if hero_note_block -%}
          {{ hero_note_block.settings.text }}
        {%- else -%}
          Hair recovery needs two wins - reduce the fall and support new growth. Most oils address one. Neelibhringadi works both sides.
        {%- endif -%}
      </p>

      <!-- Delivery columns -->
      <div class="mt-5 grid grid-cols-3 overflow-hidden rounded-[2px] bg-[#f6f2e8] text-[#17372d]">
        <div class="flex items-center justify-center gap-1.5 px-1 py-2.5 text-[10px]">
          <svg class="h-3.5 w-3.5" stroke="currentColor" stroke-width="1.9" fill="none" viewBox="0 0 24 24">
            <path d="M3 7h11v10H3z" />
            <path d="M14 10h3l2 2v5h-5" stroke-linecap="round" stroke-linejoin="round" />
            <circle cx="7" cy="18" r="1.4" fill="currentColor" />
            <circle cx="17" cy="18" r="1.4" fill="currentColor" />
          </svg>
          <span>{{ section.settings.delivery_1_text }}</span>
        </div>
        <div class="flex items-center justify-center gap-1.5 px-1 py-2.5 text-[10px]">
          <svg class="h-3.5 w-3.5" stroke="currentColor" stroke-width="1.9" fill="none" viewBox="0 0 24 24">
            <path d="M3 7h18v10H3z" />
            <path d="M8 12h8" stroke-linecap="round" />
          </svg>
          <span>{{ section.settings.delivery_2_text }}</span>
        </div>
        <div class="flex items-center justify-center gap-1.5 px-1 py-2.5 text-[10px]">
          <svg class="h-3.5 w-3.5" stroke="currentColor" stroke-width="1.9" fill="none" viewBox="0 0 24 24">
            <path d="M6 8h12l-1 11H7L6 8Z" stroke-linejoin="round" />
            <path d="M9 8a3 3 0 0 1 6 0" stroke-linecap="round" />
          </svg>
          <span>{{ section.settings.delivery_3_text }}</span>
        </div>
      </div>

      <!-- Upsell container -->
      {%- if upsell_block -%}
        <div class="mt-3 flex items-center gap-3 rounded-[16px] bg-[#8f4f36] p-3 text-white shadow-sm">
            <img src="{{ 'upsell.png' | asset_url }}" class="h-[58px] w-[66px] rounded-[10px] object-cover" width="66" height="58" alt="Upsell Product">
          <div class="min-w-0 flex-1">
            <div class="text-[13px] font-medium leading-none">{{ upsell_block.settings.title }}</div>
            <div class="mt-1 text-[12px] leading-tight text-white/74">{{ upsell_block.settings.text }}</div>
          </div>
          {%- if upsell_block.settings.button_link != blank -%}
            <a href="{{ upsell_block.settings.button_link }}" class="premium-button rounded-[12px] bg-[#f4bb28] px-3 py-2 text-[13px] font-bold leading-none text-[#1c2018] border-0 cursor-pointer text-decoration-none">
              {{ upsell_block.settings.button_label }}
            </a>
          {%- else -%}
            <button type="submit" name="add" onclick="document.getElementById('theme-product-form-mobile').submit();" class="premium-button rounded-[12px] bg-[#f4bb28] px-3 py-2 text-[13px] font-bold leading-none text-[#1c2018] border-0 cursor-pointer">
              {{ upsell_block.settings.button_label }}
            </button>
          {%- endif -%}
        </div>
      {%- endif -%}

      <!-- Review Quote -->
      <div class="mt-4 rounded-r-xl border-l-[4px] border-[#f3b324] bg-[#f8f1df] px-4 py-3">
        <p class="text-[13px] leading-[1.35] text-[#17372d]/78">
          {%- if quote_block -%}
            {{ quote_block.settings.quote }}
          {%- else -%}
            "Hair fall reduced noticeably, and I can already see tiny baby hairs coming"
          {%- endif -%}
        </p>
        <p class="mt-1 text-[11px] font-medium uppercase tracking-[0.08em] text-[#17372d]/58">
          {%- if quote_block -%}
            {{ quote_block.settings.author }}
          {%- else -%}
            - ANU R., CHENNAI
          {%- endif -%}
        </p>
      </div>

      <p class="mt-4 text-[14px] leading-[1.45] text-[#17372d]/72">
        {%- if feature_block -%}
          {{ feature_block.settings.title }} {{ feature_block.settings.text }}
        {%- else -%}
          Made by BAMS doctors in our GMP & ISO - certified facility. FDA compliant and AYUSH licensed.
        {%- endif -%}
      </p>

      <!-- Mobile certifications panel -->
      <div class="motion-panel mt-3 rounded-[14px] border border-[#17372d]/10 bg-white px-3 py-2 shadow-[0_8px_20px_rgba(17,48,39,0.04)]">
        <div class="grid grid-cols-3 gap-2 text-[#17372d]">
          <div class="border-r border-[#17372d]/8 px-2">
            <div class="font-serif text-[14px] font-normal leading-[0.98] tracking-[0.005em] text-[#17372d]">{{ section.settings.stat_1_value }}</div>
            <div class="mt-0.5 text-[8px] font-medium uppercase tracking-[0.1em] text-[#17372d]/72">{{ section.settings.stat_1_label }}</div>
          </div>
          <div class="border-r border-[#17372d]/8 px-2">
            <div class="font-serif text-[14px] font-normal leading-[0.98] tracking-[0.005em] text-[#17372d]">{{ section.settings.stat_2_value }}</div>
            <div class="mt-0.5 text-[8px] font-medium uppercase tracking-[0.1em] text-[#17372d]/72">{{ section.settings.stat_2_label }}</div>
          </div>
          <div class="px-2">
            <div class="font-serif text-[14px] font-normal leading-[0.98] tracking-[0.005em] text-[#17372d]">{{ section.settings.stat_3_value }}</div>
            <div class="mt-0.5 text-[8px] font-medium uppercase tracking-[0.1em] text-[#17372d]/72">{{ section.settings.stat_3_label }}</div>
          </div>
        </div>

        <div class="mt-1.5 grid grid-cols-4 items-center gap-0.5 pt-1">
          {%- assign mobile_stamp_images = 'stamp_01.png|stamp_02.png|stamp_03.png|stamp_04.png|stamp_05.png' | split: '|' -%}
          {%- for stamp in mobile_stamp_images offset: 1 limit: 4 -%}
            <div class="flex justify-center overflow-hidden">
              <img src="{{ stamp | asset_url }}" class="h-[58px] w-[58px] scale-[2.02] object-contain opacity-95 contrast-125 saturate-0" loading="lazy" width="58" height="58" alt="Certification">
            </div>
          {%- endfor -%}
        </div>
      </div>

      {%- if section.settings.description_block != blank -%}
        <p class="theme-product-page__description-block">
          {{ section.settings.description_block }}
        </p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "product hero",
  "tag": "section",
  "class": "section theme-product-hero",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product override"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_info",
      "default": true,
      "label": "Sticky product info"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "media_size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "large",
      "label": "Media size"
    },
    {
      "type": "checkbox",
      "id": "constrain_to_viewport",
      "default": true,
      "label": "Constrain to viewport"
    },
    {
      "type": "select",
      "id": "media_fit",
      "options": [
        { "value": "contain", "label": "Contain" },
        { "value": "cover", "label": "Cover" }
      ],
      "default": "contain",
      "label": "Media fit"
    },
    {
      "type": "select",
      "id": "gallery_layout",
      "options": [
        { "value": "stacked", "label": "Stacked" },
        { "value": "columns", "label": "Columns" },
        { "value": "thumbnail", "label": "Thumbnail" },
        { "value": "thumbnail_slider", "label": "Thumbnail slider" }
      ],
      "default": "stacked",
      "label": "Gallery layout"
    },
    {
      "type": "select",
      "id": "mobile_thumbnails",
      "options": [
        { "value": "columns", "label": "Columns" },
        { "value": "show", "label": "Show" },
        { "value": "hide", "label": "Hide" }
      ],
      "default": "hide",
      "label": "Mobile thumbnails"
    },
    {
      "type": "select",
      "id": "media_position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left",
      "label": "Media position"
    },
    {
      "type": "checkbox",
      "id": "hide_variants",
