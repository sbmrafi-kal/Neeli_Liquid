      "label": "Hide variant media"
    },
    {
      "type": "checkbox",
      "id": "enable_video_looping",
      "default": false,
      "label": "Enable video looping"
    },
    {
      "type": "text",
      "id": "stat_1_value",
      "label": "Stamp stat 1 value",
      "default": "1945"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stamp stat 1 label",
      "default": "Established"
    },
    {
      "type": "text",
      "id": "stat_2_value",
      "label": "Stamp stat 2 value",
      "default": "350+"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stamp stat 2 label",
      "default": "Products"
    },
    {
      "type": "text",
      "id": "stat_3_value",
      "label": "Stamp stat 3 value",
      "default": "Clinics & Academy"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stamp stat 3 label",
      "default": "Expert led"
    },
    {
      "type": "text",
      "id": "delivery_1_text",
      "label": "Delivery row 1 text",
      "default": "2-4 day delivery"
    },
    {
      "type": "text",
      "id": "delivery_2_text",
      "label": "Delivery row 2 text",
      "default": "COD available"
    },
    {
      "type": "text",
      "id": "delivery_3_text",
      "label": "Delivery row 3 text",
      "default": "7-day returns"
    },
    {
      "type": "text",
      "id": "category_label",
      "label": "Category label",
      "default": "HAIR CARE"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review count",
      "default": "86"
    },
    {
      "type": "text",
      "id": "cta_meta",
      "label": "CTA meta text",
      "default": "Limited-time offer"
    },
    {
      "type": "textarea",
      "id": "description_block",
      "label": "Description block",
      "default": "Neeli cools scalp inflammation that weakens follicles. Bhringaraja activates dormant roots. Amla fortifies the shaft from within. The triple-milk base carries all three deeper than a standard oil carrier - processed over eleven days to bind the herbal essence to the oil."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 36,
      "label": "Top padding"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 16,
      "label": "Bottom padding"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Hero badge",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "default": "Minimizes hair fall",
          "label": "Badge text"
        }
      ]
    },
    {
      "type": "title",
      "name": "Title",
      "limit": 1
    },
    {
      "type": "caption",
      "name": "Subtitle",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "default": "One oil for complete hair recovery",
          "label": "Text"
        },
        {
          "type": "select",
          "id": "text_style",
          "options": [
            { "value": "body", "label": "Body" },
            { "value": "subtitle", "label": "Subtitle" },
            { "value": "uppercase", "label": "Uppercase" }
          ],
          "default": "body",
          "label": "Style"
        }
      ]
    },
    {
