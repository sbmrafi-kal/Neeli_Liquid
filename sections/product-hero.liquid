  {{ 'section-theme-product-page.css' | asset_url | stylesheet_tag }}
  {{ 'section-product-hero.css' | asset_url | stylesheet_tag }}
  {{ 'sticky-cart-bar.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'product-hero.js' | asset_url }}" defer="defer"></script>



{%- assign product_override = all_products[section.settings.product] -%}
{%- if product_override != blank -%}
  {%- assign product = product_override -%}
{%- endif -%}
{%- assign product_title = product.title | default: 'Neelibhringadi Keram' -%}
{%- assign selected_variant = product.selected_or_first_available_variant -%}
{%- assign hero_stat_blocks = section.blocks | where: "type", "hero_stat" -%}
{%- assign hero_image_blocks = section.blocks | where: "type", "hero_image" -%}

<section
  id="NeeliProduct-{{ section.id }}"
  class="theme-product-page theme-reveal  gradient color-{{ section.settings.color_scheme }}"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
>
  <script src="{{ 'theme-product-page.js' | asset_url }}" defer="defer"></script>

{%- assign hero_images = hero_image_blocks -%}
{%- if hero_images.size == 0 -%}
  {%- assign hero_images = product.media -%}
{%- endif -%}
{%- assign hero_fallback_image = product.featured_image -%}

  <div class="container-narrow">
    <div class="theme-product-page__hero">
      <div class="theme-product-page__hero-media">
        <div class="theme-hero-carousel" data-theme-carousel data-theme-autoplay="false" data-theme-interval="4800">
          <div class="theme-hero-carousel__stage">
            {%- for media in hero_images -%}
              <figure class="theme-hero-carousel__slide{% if forloop.first %} is-active{% endif %}" data-theme-carousel-slide>
                {%- if forloop.first -%}
                  {%- assign hero_loading = 'eager' -%}
                {%- else -%}
                  {%- assign hero_loading = 'lazy' -%}
                {%- endif -%}
                {%- if hero_image_blocks.size > 0 -%}
                  {%- if media.settings.image != blank -%}
                    {{ media.settings.image | image_url: width: 750 | image_tag: class: 'theme-hero-carousel__image image-zoom', loading: hero_loading, width: 750, height: 1000, alt: product_title }}
                  {%- endif -%}
                {%- elsif media.preview_image != blank -%}
                  {{ media.preview_image | image_url: width: 750 | image_tag: class: 'theme-hero-carousel__image image-zoom', loading: hero_loading, width: 750, height: 1000, alt: product_title }}
                {%- elsif media.src != blank -%}
                  {{ media | image_url: width: 750 | image_tag: class: 'theme-hero-carousel__image image-zoom', loading: hero_loading, width: 750, height: 1000, alt: product_title }}
                {%- endif -%}
              </figure>
            {%- endfor -%}

            {%- if hero_images.size == 0 and hero_fallback_image != blank -%}
              <figure class="theme-hero-carousel__slide is-active" data-theme-carousel-slide>
                {{ hero_fallback_image | image_url: width: 750 | image_tag: class: 'theme-hero-carousel__image image-zoom', loading: 'eager', width: 750, height: 1000, alt: product_title }}
              </figure>
            {%- endif -%}

            <button class="theme-hero-carousel__control theme-hero-carousel__control--prev" type="button" aria-label="Previous image" data-theme-carousel-prev>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-left"><path d="m15 18-6-6 6-6"/></svg>
            </button>
            <button class="theme-hero-carousel__control theme-hero-carousel__control--next" type="button" aria-label="Next image" data-theme-carousel-next>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right"><path d="m9 18 6-6-6-6"/></svg>
            </button>
          </div>

          <div class="theme-hero-carousel__thumbs" role="tablist" aria-label="Product gallery thumbnails">
            {%- for media in hero_images -%}
              <button
                class="theme-hero-carousel__thumb{% if forloop.first %} is-active{% endif %}"
                type="button"
                aria-label="Show image {{ forloop.index }}"
                data-theme-carousel-thumb="{{ forloop.index0 }}"
              >
                {%- if hero_image_blocks.size > 0 -%}
                  {%- if media.settings.image != blank -%}
                    {{ media.settings.image | image_url: width: 120 | image_tag: class: 'theme-hero-carousel__thumb-image', loading: 'lazy', width: 90, height: 120, alt: '' }}
                  {%- endif -%}
                {%- elsif media.preview_image != blank -%}
                  {{ media.preview_image | image_url: width: 120 | image_tag: class: 'theme-hero-carousel__thumb-image', loading: 'lazy', width: 90, height: 120, alt: '' }}
                {%- elsif media.src != blank -%}
                  {{ media | image_url: width: 120 | image_tag: class: 'theme-hero-carousel__thumb-image', loading: 'lazy', width: 90, height: 120, alt: '' }}
                {%- endif -%}
              </button>
            {%- endfor -%}

            {%- if hero_images.size == 0 and hero_fallback_image != blank -%}
              <button class="theme-hero-carousel__thumb is-active" type="button" aria-label="Show image 1" data-theme-carousel-thumb="0">
                {{ hero_fallback_image | image_url: width: 120 | image_tag: class: 'theme-hero-carousel__thumb-image', loading: 'lazy', width: 90, height: 120, alt: '' }}
              </button>
            {%- endif -%}
          </div>

          <div class="theme-hero-carousel__stats">
            <div class="theme-hero-carousel__stat">
              <span class="theme-hero-carousel__stat-icon theme-hero-carousel__stat-icon--rating" aria-hidden="true"></span>
              <div class="theme-hero-carousel__stat-value">{{ section.settings.stat_1_value }}</div>
              <div class="theme-hero-carousel__stat-label">{{ section.settings.stat_1_label }}</div>
            </div>
            <div class="theme-hero-carousel__stat">
              <span class="theme-hero-carousel__stat-icon theme-hero-carousel__stat-icon--reviews" aria-hidden="true"></span>
              <div class="theme-hero-carousel__stat-value">{{ section.settings.stat_2_value }}</div>
              <div class="theme-hero-carousel__stat-label">{{ section.settings.stat_2_label }}</div>
            </div>
            <div class="theme-hero-carousel__stat">
              <span class="theme-hero-carousel__stat-icon theme-hero-carousel__stat-icon--uses" aria-hidden="true"></span>
              <div class="theme-hero-carousel__stat-value">{{ section.settings.stat_3_value }}</div>
              <div class="theme-hero-carousel__stat-label">{{ section.settings.stat_3_label }}</div>
            </div>
            <div class="theme-hero-carousel__stat">
              <span class="theme-hero-carousel__stat-icon theme-hero-carousel__stat-icon--sales" aria-hidden="true"></span>
              <div class="theme-hero-carousel__stat-value">{{ section.settings.stat_4_value }}</div>
              <div class="theme-hero-carousel__stat-label">{{ section.settings.stat_4_label }}</div>
            </div>
          </div>
        </div>

      </div>

      <!-- DESKTOP HERO INFO COLUMN -->
      <div id="ProductInfo-{{ section.id }}" class="theme-product-page__hero-info theme-product-info-desktop">
        <div class="theme-product-page__hero-header">
          {%- assign badges = section.blocks | where: "type", "text" -%}
          {%- if badges.size > 0 -%}
            <div class="theme-product-page__badge micro-fade-delayed">
              {%- for block in badges -%}
                {%- assign badge_parts = block.settings.text | split: '•' -%}
                {%- for badge_text in badge_parts -%}
                  {%- assign clean_badge = badge_text | strip -%}
                  {%- if clean_badge != blank -%}
                    <span class="theme-product-page__badge-line" {{ block.shopify_attributes }}>
                      <span class="theme-badge-bullet">•</span>
                      <span>{{ clean_badge | strip_html }}</span>
                    </span>
                  {%- endif -%}
                {%- endfor -%}
              {%- endfor -%}
            </div>
          {%- else -%}
            <div class="theme-product-page__badge micro-fade-delayed">
              <span class="theme-product-page__badge-line"><span class="theme-badge-bullet">•</span><span>Minimizes hair fall</span></span>
              <span class="theme-product-page__badge-line"><span class="theme-badge-bullet">•</span><span>Supports hair growth</span></span>
            </div>
          {%- endif -%}


          <div class="theme-product-page__title-wrap">
            <h1 class="theme-product-page__title">{{ product_title | escape }}</h1>
          </div>


          {%- assign subtitle_block = section.blocks | where: "type", "caption" | first -%}
          <p class="theme-product-page__subtitle subtitle">
            {%- if subtitle_block -%}
              {{ subtitle_block.settings.text | strip_html }}
            {%- else -%}
              One oil for complete hair recovery
            {%- endif -%}
          </p>

          {%- assign hero_note_block = section.blocks | where: "type", "hero_note" | first -%}
          <p class="theme-product-page__body theme-product-page__intro">
            {%- capture hero_note_text -%}
              {%- if hero_note_block -%}
                {{ hero_note_block.settings.text | strip_html }}
              {%- else -%}
                Hair recovery needs two wins - reduce the fall and support new growth. Most oils address one. Neelibhringadi works both sides.
              {%- endif -%}
            {%- endcapture -%}
            {{ hero_note_text | strip }}
          </p>
        </div>

        <div class="theme-product-page__form-card">
        {%- if product != blank and selected_variant != blank -%}
        {%- form 'product', product, id: "theme-product-form", class: "theme-product-form" -%}
            {%- if product.variants.size > 1 -%}
              <div class="theme-variant-boxes theme-variant-boxes--desktop">
                {%- for variant in product.variants -%}
                  <label class="theme-variant-box {% if variant == product.selected_or_first_available_variant %}is-selected{% endif %}" for="Variant-{{ section.id }}-{{ forloop.index }}">
                    <input type="radio" class="theme-variant-box__input" name="id" value="{{ variant.id }}" id="Variant-{{ section.id }}-{{ forloop.index }}"
                      data-price="{{ variant.price | money }}"
                      data-compare-price="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money }}{% endif %}"
                      data-available="{{ variant.available }}"
                      {% if variant == product.selected_or_first_available_variant %}checked{% endif %}>
                    <div class="theme-variant-box__title">{{ variant.title }}</div>
                    <div class="theme-variant-box__price-row">
                      <span class="theme-variant-box__mrp">M.R.P.</span>
                      <span class="theme-variant-box__price-new">{{ variant.price | money }}</span>
                      {%- if variant.compare_at_price > variant.price -%}
                        <span class="theme-variant-box__price-old">{{ variant.compare_at_price | money }}</span>
                      {%- endif -%}
                    </div>
                  </label>
                {%- endfor -%}
              </div>
            {%- else -%}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            {%- endif -%}
            <input type="hidden" name="quantity" value="1">
          {%- endform -%}
          {%- endif -%}
        </div>

        <div class="theme-delivery-banner">
          <span class="theme-delivery-banner__truck" aria-hidden="true">🚚</span>
          <span class="theme-delivery-banner__text">{{ section.settings.delivery_banner_text | strip_html }}</span>
        </div>

        {%- assign quote_block = section.blocks | where: "type", "hero_quote" | first -%}
        <div class="theme-product-page__quote-wrap motion-panel">
          <div class="theme-product-page__quote">
            {%- if quote_block -%}
              {{ quote_block.settings.quote | strip_html }}
            {%- else -%}
              "Hair fall reduced noticeably, and I can already see tiny baby hairs coming"
            {%- endif -%}
          </div>
          <div class="theme-product-page__quote-meta">
            {%- if quote_block -%}
              {{ quote_block.settings.author | strip_html }}
            {%- else -%}
              - ANU R., CHENNAI
            {%- endif -%}
          </div>
        </div>

        {%- if section.settings.description_block != blank -%}
          <div class="theme-product-page__desc-title">{{ section.settings.description_title }}</div>
          <p class="theme-product-page__description-block">
            {{ section.settings.description_block | strip_html }}
          </p>
        {%- endif -%}

        <div class="theme-new-cert-block motion-panel">
          <div class="theme-new-cert-block__stats">
            <div class="theme-new-cert-block__stat">
              <div class="theme-new-cert-block__stat-val">{{ section.settings.stat_1_value }}</div>
              <div class="theme-new-cert-block__stat-lbl">{{ section.settings.stat_1_label }}</div>
            </div>
            <div class="theme-new-cert-block__stat">
              <div class="theme-new-cert-block__stat-val">{{ section.settings.stat_2_value }}</div>
              <div class="theme-new-cert-block__stat-lbl">{{ section.settings.stat_2_label }}</div>
            </div>
            <div class="theme-new-cert-block__stat">
              <div class="theme-new-cert-block__stat-val">{{ section.settings.stat_3_value }}</div>
              <div class="theme-new-cert-block__stat-lbl">{{ section.settings.stat_3_label }}</div>
            </div>
          </div>
          <div class="theme-new-cert-block__stamps">
            {%- if section.settings.stamp_1_image != blank -%}
              {{ section.settings.stamp_1_image | image_url: width: 180 | image_tag: loading: 'lazy', alt: section.settings.stamp_1_alt }}
            {%- endif -%}
            {%- if section.settings.stamp_2_image != blank -%}
              {{ section.settings.stamp_2_image | image_url: width: 180 | image_tag: loading: 'lazy', alt: section.settings.stamp_2_alt }}
            {%- endif -%}
            {%- if section.settings.stamp_3_image != blank -%}
              {{ section.settings.stamp_3_image | image_url: width: 180 | image_tag: loading: 'lazy', alt: section.settings.stamp_3_alt }}
            {%- endif -%}
            {%- if section.settings.stamp_4_image != blank -%}
              {{ section.settings.stamp_4_image | image_url: width: 180 | image_tag: loading: 'lazy', alt: section.settings.stamp_4_alt }}
            {%- endif -%}
          </div>
        </div>

        {% render 'ritual-guide', title: section.settings.ritual_title, text: section.settings.ritual_text %}
      </div>

      <!-- MOBILE HERO INFO CONTAINER (Spans full narrow width) -->
    <div class="theme-product-info-mobile">
      {%- if badges.size > 0 -%}
        <div class="theme-product-page__badge theme-product-page__badge--mobile">
          {%- for block in badges -%}
            {%- assign badge_parts = block.settings.text | split: '•' -%}
            {%- for badge_text in badge_parts -%}
              {%- assign clean_badge = badge_text | strip -%}
              {%- if clean_badge != blank -%}
                <span class="theme-product-page__badge-line">
                  <span class="theme-badge-bullet">•</span>
                  <span>{{ clean_badge }}</span>
                </span>
              {%- endif -%}
            {%- endfor -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="theme-product-page__badge theme-product-page__badge--mobile">
          <span class="theme-product-page__badge-line"><span class="theme-badge-bullet">•</span><span>Minimizes hair fall</span></span>
          <span class="theme-product-page__badge-line"><span class="theme-badge-bullet">•</span><span>Supports hair growth</span></span>
        </div>
      {%- endif -%}

      <div class="theme-product-page__title-wrap">
        <h1 class="theme-product-page__title">{{ product_title | escape }}</h1>
      </div>

      <p class="theme-product-page__subtitle subtitle">
        {%- if subtitle_block -%}
          {{ subtitle_block.settings.text }}
        {%- else -%}
          One oil for complete hair recovery
        {%- endif -%}
      </p>

      <p class="theme-product-page__body theme-product-page__intro">
        {%- capture hero_note_text -%}
          {%- if hero_note_block -%}
            {{ hero_note_block.settings.text }}
          {%- else -%}
            Hair recovery needs two wins - reduce the fall and support new growth. Most oils address one. Neelibhringadi works both sides.
          {%- endif -%}
        {%- endcapture -%}
        {{ hero_note_text | strip | replace: 'Neelibhringadi works', 'Neelibhringadi<br class="theme-hero-note-break">works' }}
      </p>

      <div class="theme-product-page__quote-wrap motion-panel">
        <div class="theme-product-page__quote">
          {%- if quote_block -%}
            {{ quote_block.settings.quote }}
          {%- else -%}
            "Hair fall reduced noticeably, and I can already see tiny baby hairs coming"
          {%- endif -%}
        </div>
        <div class="theme-product-page__quote-meta">
          {%- if quote_block -%}
            {{ quote_block.settings.author }}
          {%- else -%}
            - ANU R., CHENNAI
          {%- endif -%}
        </div>
      </div>

      <div class="theme-product-page__form-card">
        {%- if product != blank and selected_variant != blank -%}
        {%- form 'product', product, id: "theme-product-form-mobile", class: "theme-product-form" -%}
          <button type="submit" name="add" class="theme-reorder-btn theme-reorder-btn--mobile cta-sheen" {% unless selected_variant.available %}disabled="disabled"{% endunless %}>
            <div class="theme-reorder-btn__left">
              <svg class="theme-reorder-btn__icon theme-reorder-btn__icon--mobile" stroke="currentColor" stroke-width="1.8" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M3 3v5h5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <div class="theme-reorder-btn__content">
                <div class="theme-reorder-btn__title theme-reorder-btn__title--mobile">
                  {%- if selected_variant.available -%}
                    Add to Cart
                  {%- else -%}
                    Sold Out
                  {%- endif -%}
                </div>
              </div>
            </div>
            <div class="theme-reorder-btn__right theme-reorder-btn__right--mobile">
              {%- if selected_variant.compare_at_price > selected_variant.price -%}
                <span class="theme-reorder-btn__price-old">{{ selected_variant.compare_at_price | money }}</span>
              {%- else -%}
                <span class="theme-reorder-btn__price-old" hidden></span>
              {%- endif -%}
              <span class="theme-reorder-btn__price-new theme-reorder-btn__price-new--mobile">{{ selected_variant.price | money }}</span>
            </div>
          </button>

          <div class="theme-delivery-banner">
            Free delivery on orders over ₹299 | <span class="theme-delivery-banner__truck">🚚</span> 2-4 days delivery
          </div>

          {%- if product.variants.size > 1 -%}
            <div class="theme-variant-boxes theme-variant-boxes--mobile">
              {%- for variant in product.variants -%}
                <label class="theme-variant-box {% if variant == product.selected_or_first_available_variant %}is-selected{% endif %}" for="Variant-Mobile-{{ section.id }}-{{ forloop.index }}">
                  <input type="radio" class="theme-variant-box__input" name="id" value="{{ variant.id }}" id="Variant-Mobile-{{ section.id }}-{{ forloop.index }}"
                    data-price="{{ variant.price | money }}"
                    data-compare-price="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money }}{% endif %}"
                    data-available="{{ variant.available }}"
                    {% if variant == product.selected_or_first_available_variant %}checked{% endif %}>
                  <div class="theme-variant-box__title">{{ variant.title }}</div>
                  <div class="theme-variant-box__price-row">
                    <span class="theme-variant-box__mrp">M.R.P.</span>
                    <span class="theme-variant-box__price-new">{{ variant.price | money }}</span>
                    {%- if variant.compare_at_price > variant.price -%}
                      <span class="theme-variant-box__price-old">{{ variant.compare_at_price | money }}</span>
                    {%- endif -%}
                  </div>
                </label>
              {%- endfor -%}
            </div>
          {%- else -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          {%- endif -%}
          <input type="hidden" name="quantity" value="1">
        {%- endform -%}
        {%- endif -%}
      </div>

      {%- if section.settings.description_block != blank -%}
        <div class="theme-product-page__desc-title">{{ section.settings.description_title }}</div>
        <p class="theme-product-page__description-block">
          {{ section.settings.description_block }}
        </p>
      {%- endif -%}

      <div class="theme-new-cert-block motion-panel">
        <div class="theme-new-cert-block__stats">
          {%- if hero_stat_blocks.size > 0 -%}
            {%- for block in hero_stat_blocks limit: 3 -%}
              <div class="theme-new-cert-block__stat" {{ block.shopify_attributes }}>
                <div class="theme-new-cert-block__stat-val">{{ block.settings.value }}</div>
                <div class="theme-new-cert-block__stat-lbl">{{ block.settings.label }}</div>
              </div>
            {%- endfor -%}
          {%- else -%}
            <div class="theme-new-cert-block__stat">
              <div class="theme-new-cert-block__stat-val">{{ section.settings.stat_1_value }}</div>
              <div class="theme-new-cert-block__stat-lbl">{{ section.settings.stat_1_label }}</div>
            </div>
            <div class="theme-new-cert-block__stat">
              <div class="theme-new-cert-block__stat-val">{{ section.settings.stat_2_value }}</div>
              <div class="theme-new-cert-block__stat-lbl">{{ section.settings.stat_2_label }}</div>
            </div>
            <div class="theme-new-cert-block__stat">
              <div class="theme-new-cert-block__stat-val">{{ section.settings.stat_3_value }}</div>
              <div class="theme-new-cert-block__stat-lbl">{{ section.settings.stat_3_label }}</div>
            </div>
          {%- endif -%}
        </div>
        <div class="theme-new-cert-block__stamps">
          {%- if section.settings.stamp_1_image != blank -%}
            {{ section.settings.stamp_1_image | image_url: width: 180 | image_tag: loading: 'lazy', alt: section.settings.stamp_1_alt }}
          {%- endif -%}
          {%- if section.settings.stamp_2_image != blank -%}
            {{ section.settings.stamp_2_image | image_url: width: 180 | image_tag: loading: 'lazy', alt: section.settings.stamp_2_alt }}
          {%- endif -%}
          {%- if section.settings.stamp_3_image != blank -%}
            {{ section.settings.stamp_3_image | image_url: width: 180 | image_tag: loading: 'lazy', alt: section.settings.stamp_3_alt }}
          {%- endif -%}
          {%- if section.settings.stamp_4_image != blank -%}
            {{ section.settings.stamp_4_image | image_url: width: 180 | image_tag: loading: 'lazy', alt: section.settings.stamp_4_alt }}
          {%- endif -%}
        </div>
      </div>

      {% render 'ritual-guide', title: section.settings.ritual_title, text: section.settings.ritual_text %}
    </div>
  </div>
  </div>
  {% render 'sticky-cart-bar' %}
</section>

{% schema %}
{
  "name": "product hero",
  "tag": "section",
  "class": "section theme-product-hero",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product override"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_info",
      "default": true,
      "label": "Sticky product info"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "media_size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "large",
      "label": "Media size"
    },
    {
      "type": "checkbox",
      "id": "constrain_to_viewport",
      "default": true,
