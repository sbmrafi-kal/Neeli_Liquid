        { "type": "url", "id": "button_link", "label": "Button link" }
      ]
    },
    {
      "type": "hero_note",
      "name": "Hero note",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "default": "Neeli cools scalp inflammation that weakens follicles. Bhringaraja activates dormant roots. Amla fortifies the shaft from within.",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "product hero",
      "blocks": [
        { "type": "text" },
        { "type": "title" },
        { "type": "caption" },
        { "type": "hero_stat" },
        { "type": "hero_stat" },
        { "type": "hero_stat" },
        { "type": "hero_stat" },
        { "type": "hero_feature" },
        { "type": "hero_feature" },
        { "type": "hero_quote" },
        { "type": "hero_note" },
        { "type": "hero_upsell" }
      ]
