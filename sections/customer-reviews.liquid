  {{ 'section-theme-product-page.css' | asset_url | stylesheet_tag }}
  {{ 'section-customer-reviews.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'customer-reviews.js' | asset_url }}" defer="defer"></script>



<section class="theme-product-page__section theme-reveal  color-{{ section.settings.color_scheme }} gradient {% if section.settings.soft_background %}theme-product-page__section--soft{% endif %}" style="--pt: {{ section.settings.padding_top }}px; --pb: {{ section.settings.padding_bottom }}px;">
  <div class="theme-product-page__wrap">
    <div class="theme-reviews-header-wrap">
      <div class="theme-section-heading theme-section-heading--center">
        {%- if section.settings.kicker != blank -%}
          <span class="theme-section-heading__kicker theme-reviews-section__kicker">{{ section.settings.kicker }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="theme-section-heading__title theme-reviews-section__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="theme-section-heading__text theme-reviews-section__text">{{ section.settings.text }}</div>
        {%- endif -%}
      </div>

      <div class="theme-reviews-rating-header">
        <div class="theme-reviews-rating-header__score-mobile lg:hidden">{{ section.settings.rating_score }}</div>
        <div class="theme-reviews-rating-header__stars">
          {%- for i in (1..4) -%}
            <svg class="theme-reviews-rating-header__star-svg theme-reviews-rating-header__star-svg--filled" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
          {%- endfor -%}
          <svg class="theme-reviews-rating-header__star-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
        </div>
        <div class="theme-reviews-rating-header__score-desktop hidden lg:block">{{ section.settings.rating_score }}</div>
      </div>
    </div>

    <div class="theme-review-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
          <article class="theme-review-card motion-panel" {{ block.shopify_attributes }}>
            <div class="theme-review-card__header">
              <div class="theme-review-card__header-left">
                <div class="theme-review-card__author-name">{{ block.settings.name }}</div>
                <div class="theme-review-card__stars">
                  {%- for i in (1..5) -%}
                    <svg class="theme-review-card__star-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                    </svg>
                  {%- endfor -%}
                </div>
              </div>
              <div class="theme-review-card__verified">{{ block.settings.meta }}</div>
            </div>
            <p class="theme-review-card__quote">&ldquo;{{ block.settings.body }}&rdquo;</p>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <div class="theme-reviews-footer">
        {%- if section.settings.button_link != blank -%}
          <a class="theme-review-button-v2" href="{{ section.settings.button_link }}">
            {{ section.settings.button_label }}
          </a>
        {%- else -%}
          <button type="button" class="theme-review-button-v2">
            {{ section.settings.button_label }}
          </button>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "customer reviews",
  "tag": "section",
  "class": "section theme-customer-reviews",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "checkbox", "id": "soft_background", "label": "Soft background", "default": false },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Feedback" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Customer Reviews" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Real customer language, carried into the Shopify theme.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Read all reviews" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "text", "id": "rating_score", "label": "Rating score", "default": "4.64 / 5.0" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "default": 36, "label": "Top padding" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "default": 36, "label": "Bottom padding" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "ANJALI K." },
        { "type": "text", "id": "meta", "label": "Meta", "default": "Verified Purchase" },
        { "type": "text", "id": "badge", "label": "Badge", "default": "Postpartum hair fall" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Within a month the amount of hair on my brush was noticeably less." }
      ]
    }
  ],
  "presets": [
    {
      "name": "customer reviews",
      "blocks": [
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
