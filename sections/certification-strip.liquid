{{ 'section-certification-strip.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign has_marks = false
  if section.settings.mark_1_image != blank
    or section.settings.mark_2_image != blank
    or section.settings.mark_3_image != blank
    or section.settings.mark_4_image != blank
    or section.settings.stat_1_value != blank
    or section.settings.stat_2_value != blank
    or section.settings.stat_3_value != blank
    assign has_marks = true
  endif
-%}

{%- if has_marks -%}
  <section
    class="theme-cert-strip theme-reveal section-{{ section.id }}-padding"
    style="--pt: {{ section.settings.padding_top }}px; --pb: {{ section.settings.padding_bottom }}px;"
  >
    <div class="theme-cert-strip__inner">
      <div class="theme-cert-strip__marks" aria-label="Certification marks">
        {%- for mark_index in (1..4) -%}
          {%- capture mark_image_key -%}mark_{{ mark_index }}_image{%- endcapture -%}
          {%- capture mark_alt_key -%}mark_{{ mark_index }}_alt{%- endcapture -%}
          {%- assign mark_image = section.settings[mark_image_key] -%}
          {%- assign mark_alt = section.settings[mark_alt_key] | default: 'Certification mark' -%}
          <div class="theme-cert-strip__mark">
            {%- if mark_image != blank -%}
              {{
                mark_image
                | image_url: width: 140
                | image_tag:
                  class: 'theme-cert-strip__mark-image',
                  loading: 'lazy',
                  widths: '72, 96, 120, 140',
                  alt: mark_alt
              }}
            {%- else -%}
              <div class="theme-cert-strip__mark-placeholder" aria-hidden="true">
                {{ 'image' | placeholder_svg_tag: 'theme-cert-strip__placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      <div class="theme-cert-strip__stats" aria-label="Brand highlights">
        {%- for stat_index in (1..3) -%}
          {%- capture stat_value_key -%}stat_{{ stat_index }}_value{%- endcapture -%}
          {%- capture stat_label_key -%}stat_{{ stat_index }}_label{%- endcapture -%}
          {%- assign stat_value = section.settings[stat_value_key] -%}
          {%- assign stat_label = section.settings[stat_label_key] -%}
          {%- if stat_value != blank or stat_label != blank -%}
            <div class="theme-cert-strip__stat">
              {%- if stat_value != blank -%}
                <div class="theme-cert-strip__stat-value">{{ stat_value }}</div>
              {%- endif -%}
              {%- if stat_label != blank -%}
                <div class="theme-cert-strip__stat-label">{{ stat_label }}</div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "certification strip",
  "tag": "section",
  "class": "section theme-cert-strip-section",
  "settings": [
    { "type": "image_picker", "id": "mark_1_image", "label": "Mark 1 image" },
    { "type": "text", "id": "mark_1_alt", "label": "Mark 1 alt text", "default": "Certification mark 1" },
    { "type": "image_picker", "id": "mark_2_image", "label": "Mark 2 image" },
    { "type": "text", "id": "mark_2_alt", "label": "Mark 2 alt text", "default": "Certification mark 2" },
    { "type": "image_picker", "id": "mark_3_image", "label": "Mark 3 image" },
    { "type": "text", "id": "mark_3_alt", "label": "Mark 3 alt text", "default": "Certification mark 3" },
    { "type": "image_picker", "id": "mark_4_image", "label": "Mark 4 image" },
    { "type": "text", "id": "mark_4_alt", "label": "Mark 4 alt text", "default": "Certification mark 4" },
    { "type": "text", "id": "stat_1_value", "label": "Stat 1 value", "default": "1945" },
    { "type": "text", "id": "stat_1_label", "label": "Stat 1 label", "default": "Established" },
    { "type": "text", "id": "stat_2_value", "label": "Stat 2 value", "default": "350+" },
    { "type": "text", "id": "stat_2_label", "label": "Stat 2 label", "default": "Products" },
    { "type": "text", "id": "stat_3_value", "label": "Stat 3 value", "default": "Clinics & Academy" },
    { "type": "text", "id": "stat_3_label", "label": "Stat 3 label", "default": "Expert led" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 80, "step": 4, "default": 16, "label": "Top padding" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 80, "step": 4, "default": 12, "label": "Bottom padding" }
  ],
  "presets": [{ "name": "certification strip" }]
}
{% endschema %}
