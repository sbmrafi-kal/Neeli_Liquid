{{ 'section-ingredients-in-out.css' | asset_url | stylesheet_tag }}

<section class="theme-ingredients-in-out section" role="region" aria-label="What's in it. What is not.">
  <div class="container-narrow">
    <div class="theme-ingredients-in-out__inner">
      {%- if section.settings.heading != blank -%}
        <h2 class="theme-ingredients-in-out__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      <div class="theme-ingredients-in-out__split">
        {%- assign inclusion_items = '' -%}
        {%- assign exclusion_items = '' -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.title == blank and block.settings.text == blank -%}
            {%- continue -%}
          {%- endif -%}
          {%- capture item_markup -%}
            <li class="theme-ingredients-in-out__item" {{ block.shopify_attributes }}>
              {%- if block.settings.title != blank -%}
                <strong>{{ block.settings.title }}</strong>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="theme-ingredients-in-out__item-text rte">{{ block.settings.text }}</div>
              {%- endif -%}
            </li>
          {%- endcapture -%}
          {%- if block.type == 'inclusion' -%}
            {%- assign inclusion_items = inclusion_items | append: item_markup -%}
          {%- elsif block.type == 'exclusion' -%}
            {%- assign exclusion_items = exclusion_items | append: item_markup -%}
          {%- endif -%}
        {%- endfor -%}

        <div class="theme-ingredients-in-out__box theme-ingredients-in-out__box--in">
          {%- if section.settings.inclusion_heading != blank -%}
            <h3 class="theme-ingredients-in-out__box-title">{{ section.settings.inclusion_heading }}</h3>
          {%- endif -%}
          <ul>
            {{ inclusion_items }}
          </ul>
        </div>

        <div class="theme-ingredients-in-out__box theme-ingredients-in-out__box--out">
          {%- if section.settings.exclusion_heading != blank -%}
            <h3 class="theme-ingredients-in-out__box-title">{{ section.settings.exclusion_heading }}</h3>
          {%- endif -%}
          <ul>
            {{ exclusion_items }}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ingredients — In & Out",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "What's in it. What is not." },
    { "type": "text", "id": "inclusion_heading", "label": "Inclusion heading", "default": "What's in it" },
    { "type": "text", "id": "exclusion_heading", "label": "Exclusion heading", "default": "What is not" }
  ],
  "blocks": [
    {
      "type": "inclusion",
      "name": "Inclusion",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "text", "label": "Text" }
      ]
    },
    {
      "type": "exclusion",
      "name": "Exclusion",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "text", "label": "Text" }
      ]
    }
  ],
  "presets": [{ "name": "Ingredients — In & Out" }]
}
{% endschema %}
