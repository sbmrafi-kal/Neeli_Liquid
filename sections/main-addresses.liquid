<div class="theme-container theme-container--medium theme-page-spacing theme-account-page">
  <header class="theme-account-page__header">
    <div>
      <a href="{{ routes.account_url }}" class="theme-link-muted theme-account-page__back">&larr; Back to account</a>
      <h1 class="theme-page-title theme-page-title--lg">Your Addresses</h1>
    </div>
  </header>

  <div class="theme-stack theme-stack--xl">
    {%- paginate customer.addresses by 10 -%}
      {%- for address in customer.addresses -%}
        <div class="theme-card theme-card--surface theme-account-page__card">
          {%- if address == customer.default_address -%}
            <span class="theme-account-page__badge">
              Default
            </span>
          {%- endif -%}
          <div class="theme-account-page__address">
            {{ address | format_address }}
          </div>
          <div class="theme-account-page__actions">
            <button class="theme-review-button" type="button">
              Edit
            </button>
            <form class="address-delete-form" method="post" action="/account/addresses/{{ address.id }}" data-confirm-delete="true">
              <input type="hidden" name="_method" value="delete">
              <button type="submit" class="theme-review-button">
                Delete
              </button>
            </form>
          </div>
        </div>
      {%- endfor -%}
      {%- if paginate.pages > 1 -%}
        <div class="theme-text-center">
          {{ paginate | default_pagination }}
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

{% schema %}
{
  "name": "Addresses Page",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
