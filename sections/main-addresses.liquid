<div class="theme-container theme-page-spacing" style="max-width: 720px; margin: 0 auto;">
  <header style="border-bottom: 1px solid rgba(23, 55, 45, 0.08); padding-bottom: 1.5rem; margin-bottom: 3rem; display: flex; justify-content: space-between; align-items: baseline;">
    <div>
      <a href="{{ routes.account_url }}" style="color: rgba(23, 55, 45, 0.62); text-decoration: underline; font-size: 0.875rem; display: inline-block; margin-bottom: 0.5rem;">&larr; Back to account</a>
      <h1 style="font-family: var(--font-heading-family); font-size: 2.5rem; color: var(--theme-forest); margin: 0; font-weight: 400;">Your Addresses</h1>
    </div>
  </header>

  <div style="display: grid; gap: 2rem;">
    {%- paginate customer.addresses by 10 -%}
      {%- for address in customer.addresses -%}
        <div style="background: #fff; border: 1px solid rgba(23, 55, 45, 0.08); border-radius: 12px; padding: 1.75rem; position: relative;">
          {%- if address == customer.default_address -%}
            <span style="position: absolute; right: 1.75rem; top: 1.75rem; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; padding: 0.25rem 0.625rem; background: #fcfaf4; border: 1px solid rgba(23, 55, 45, 0.1); border-radius: 4px; color: var(--theme-forest);">
              Default
            </span>
          {%- endif -%}
          <div style="font-size: 0.9375rem; color: rgba(23, 55, 45, 0.88); line-height: 1.5; margin-bottom: 1.5rem;">
            {{ address | format_address }}
          </div>
          <div style="display: flex; gap: 1rem;">
            <button class="theme-review-button" style="padding: 0.5rem 1rem; font-size: 0.8125rem; border-color: rgba(23, 55, 45, 0.2); color: rgba(23, 55, 45, 0.72); background: transparent;">
              Edit
            </button>
            <form class="address-delete-form" method="post" action="/account/addresses/{{ address.id }}" onsubmit="return confirm('Are you sure you want to delete this address?');">
              <input type="hidden" name="_method" value="delete">
              <button type="submit" class="theme-review-button" style="padding: 0.5rem 1rem; font-size: 0.8125rem; border-color: #f44336; color: #f44336; background: transparent; cursor: pointer;">
                Delete
              </button>
            </form>
          </div>
        </div>
      {%- endfor -%}
      {%- if paginate.pages > 1 -%}
        <div style="text-align: center; margin-top: 2rem;">
          {{ paginate | default_pagination }}
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

{% schema %}
{
  "name": "Addresses Page",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
