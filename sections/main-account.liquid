<div class="theme-container theme-container--wide theme-page-spacing theme-account-page">
  <header class="theme-account-page__header">
    <div>
      <h1 class="theme-page-title theme-page-title--xl">Your Account</h1>
      <p class="theme-page-subtitle">Welcome back, {{ customer.first_name }}</p>
    </div>
    <a href="{{ routes.account_logout_url }}" class="theme-link-muted">Log Out</a>
  </header>

  <div class="theme-stack theme-stack--xl">
    <div>
      <h2 class="theme-page-title theme-page-title--md">Order History</h2>

      {%- paginate customer.orders by 20 -%}
        {%- if customer.orders.size > 0 -%}
          <div class="theme-stack theme-stack--md">
            {%- for order in customer.orders -%}
              <div class="theme-card theme-card--surface theme-account-page__card">
                <div class="theme-account-page__order">
                  <h3 class="theme-page-title theme-page-title--md">
                    <a href="{{ order.customer_url }}">Order {{ order.name }}</a>
                  </h3>
                  <p class="theme-page-subtitle">Placed on {{ order.created_at | time_tag: format: 'date' }}</p>
                  <span class="theme-account-page__status">
                    {{ order.fulfillment_status_label }}
                  </span>
                </div>
                <div class="theme-text-right">
                  <span>{{ order.total_net_amount | money }}</span>
                  <span>{{ order.item_count }} item(s)</span>
                </div>
              </div>
            {%- endfor -%}
          </div>
          {%- if paginate.pages > 1 -%}
            <div>
              {{ paginate | default_pagination }}
            </div>
          {%- endif -%}
        {%- else -%}
          <p class="theme-page-subtitle">You haven't placed any orders yet.</p>
        {%- endif -%}
      {%- endpaginate -%}
    </div>

    <div>
      <h2 class="theme-page-title theme-page-title--md">Primary Address</h2>
      <div class="theme-card theme-card--soft theme-account-page__card">
        {%- if customer.default_address -%}
          {{ customer.default_address | format_address }}
        {%- else -%}
          <p class="theme-page-subtitle">No addresses saved.</p>
        {%- endif -%}
        <div class="theme-account-page__actions">
          <a href="{{ routes.addresses_url }}" class="theme-review-button">
            Manage Addresses
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Account Page",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
