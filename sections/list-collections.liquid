<div class="theme-container theme-page-spacing">
  <header class="text-center" style="margin-bottom: 4rem;">
    <h1 class="theme-page-title" style="font-family: var(--font-heading-family); font-size: 2.75rem; color: var(--theme-forest);">All Collections</h1>
  </header>

  <div class="collection-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2.5rem;">
    {%- for collection in collections -%}
      <article class="theme-review-card image-zoom-shell" style="border: 1px solid rgba(23, 55, 45, 0.08); border-radius: 12px; overflow: hidden; background: #fff; display: flex; flex-direction: column;">
        <a href="{{ collection.url }}" style="display: block; overflow: hidden; position: relative; padding-top: 66.67%;">
          {%- if collection.featured_image != blank -%}
            <img
              src="{{ collection.featured_image | image_url: width: 600 }}"
              alt="{{ collection.featured_image.alt | escape }}"
              class="image-zoom"
              style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);"
              loading="lazy"
            >
          {%- else -%}
            <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: #f7f3e9;"></div>
          {%- endif -%}
        </a>
        <div style="padding: 1.5rem; display: flex; flex-direction: column; flex-grow: 1; text-align: center;">
          <h3 style="font-family: var(--font-heading-family); font-size: 1.5rem; margin: 0 0 0.5rem; font-weight: 400;">
            <a href="{{ collection.url }}" style="color: var(--theme-forest); text-decoration: none;">{{ collection.title | escape }}</a>
          </h3>
          <p style="font-size: 0.875rem; color: rgba(23, 55, 45, 0.54); margin: 0 0 1.25rem;">{{ collection.all_products_count }} product(s)</p>
          <div style="margin-top: auto; padding-top: 0.5rem;">
            <a href="{{ collection.url }}" class="theme-review-button" style="display: inline-flex; width: 100%; padding: 0.875rem 1.5rem; font-size: 0.875rem; justify-content: center; box-sizing: border-box; text-decoration: none;">
              Shop Collection
            </a>
          </div>
        </div>
      </article>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection List",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
