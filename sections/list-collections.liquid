<div class="theme-container theme-page-spacing theme-list-page">
  <header class="theme-text-center">
    <h1 class="theme-page-title theme-page-title--xl">All Collections</h1>
  </header>

  <div class="collection-grid theme-grid--cards-320">
    {%- for collection in collections -%}
      <article class="theme-card theme-card--surface theme-review-card image-zoom-shell">
        <a href="{{ collection.url }}" class="theme-media-frame theme-media-frame--wide">
          {%- if collection.featured_image != blank -%}
            <img
              src="{{ collection.featured_image | image_url: width: 600 }}"
              alt="{{ collection.featured_image.alt | escape }}"
              class="theme-media-fill image-zoom"

              loading="lazy"
            >
          {%- else -%}
            <div class="theme-media-fill"></div>
          {%- endif -%}
        </a>
        <div class="theme-stack theme-stack--md">
          <h3 class="theme-page-title theme-page-title--md">
            <a href="{{ collection.url }}">{{ collection.title | escape }}</a>
          </h3>
          <p class="theme-page-subtitle">{{ collection.all_products_count }} product(s)</p>
          <div>
            <a href="{{ collection.url }}" class="theme-review-button">
              Shop Collection
            </a>
          </div>
        </div>
      </article>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection List",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
