<div class="neeli-container neeli-page-spacing">
  <header class="search-header text-center" style="margin-bottom: 3.5rem;">
    <h1 class="neeli-page-title" style="font-family: var(--font-heading-family); font-size: 2.75rem; color: var(--neeli-forest);">
      {%- if search.performed -%}
        Search Results
      {%- else -%}
        Search Our Store
      {%- endif -%}
    </h1>
    
    <form action="{{ routes.search_url }}" method="get" role="search" style="max-width: 480px; margin: 1.5rem auto 0; position: relative;">
      <input
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="Search for neeli, amla, bringaraj..."
        style="width: 100%; border: 1px solid rgba(23, 55, 45, 0.24); border-radius: 9999px; padding: 0.875rem 1.5rem; font-size: 1rem; color: var(--neeli-forest); outline: none; background: #fff;"
      >
      <button type="submit" style="position: absolute; right: 0.5rem; top: 50%; transform: translateY(-50%); background: #8f4f36; border: none; border-radius: 9999px; padding: 0.5rem 1.25rem; color: #fff; cursor: pointer; font-size: 0.875rem;">
        Search
      </button>
    </form>
  </header>

  {%- if search.performed -%}
    <p class="text-center" style="font-size: 1.125rem; color: rgba(23, 55, 45, 0.72); margin-bottom: 2.5rem;">
      Found {{ search.results_count }} result(s) for "{{ search.terms | escape }}"
    </p>

    {%- if search.results.size > 0 -%}
      <div class="collection-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2rem;">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            <article class="neeli-review-card image-zoom-shell" style="border: 1px solid rgba(23, 55, 45, 0.08); border-radius: 12px; overflow: hidden; background: #fff; display: flex; flex-direction: column;">
              <a href="{{ item.url }}" style="display: block; overflow: hidden; position: relative; padding-top: 100%;">
                {%- if item.featured_image != blank -%}
                  <img
                    src="{{ item.featured_image | image_url: width: 600 }}"
                    alt="{{ item.featured_image.alt | escape }}"
                    class="image-zoom"
                    style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);"
                    loading="lazy"
                  >
                {%- endif -%}
              </a>
              <div style="padding: 1.5rem; display: flex; flex-direction: column; flex-grow: 1; text-align: center;">
                <h3 style="font-family: var(--font-heading-family); font-size: 1.375rem; margin: 0; font-weight: 400;">
                  <a href="{{ item.url }}" style="color: var(--neeli-forest); text-decoration: none;">{{ item.title | escape }}</a>
                </h3>
                <div style="margin-top: 0.5rem; font-size: 1.125rem; font-weight: 600; color: #8f4f36;">
                  {{ item.price | money }}
                </div>
                <div style="margin-top: auto; padding-top: 1.25rem;">
                  <a href="{{ item.url }}" class="neeli-review-button" style="display: inline-flex; width: 100%; padding: 0.875rem 1.5rem; font-size: 0.875rem; justify-content: center; box-sizing: border-box; text-decoration: none;">
                    View Product
                  </a>
                </div>
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Search Page",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
