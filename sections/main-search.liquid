<div class="theme-container theme-page-spacing theme-search-page">
  <header class="search-header theme-text-center">
    <h1 class="theme-page-title theme-page-title--xl">
      {%- if search.performed -%}
        Search Results
      {%- else -%}
        Search Our Store
      {%- endif -%}
    </h1>

    <form action="{{ routes.search_url }}" method="get" role="search" class="theme-search-form">
      <input
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="Search for neeli, amla, bringaraj..."

      >
      <button type="submit">
        Search
      </button>
    </form>
  </header>

  {%- if search.performed -%}
    <p class="theme-text-center theme-page-subtitle">
      Found {{ search.results_count }} result(s) for "{{ search.terms | escape }}"
    </p>

    {%- if search.results.size > 0 -%}
      <div class="collection-grid theme-grid--cards-280">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            <article class="theme-card theme-card--surface theme-review-card image-zoom-shell">
              <a href="{{ item.url }}" class="theme-media-frame theme-media-frame--square">
                {%- if item.featured_image != blank -%}
                  <img
                    src="{{ item.featured_image | image_url: width: 600 }}"
                    alt="{{ item.featured_image.alt | escape }}"
                    class="theme-media-fill image-zoom"

                    loading="lazy"
                  >
                {%- else -%}
                  <div class="theme-media-fill"></div>
                {%- endif -%}
              </a>
              <div class="theme-stack theme-stack--md">
                <h3 class="theme-page-title theme-page-title--md">
                  <a href="{{ item.url }}">{{ item.title | escape }}</a>
                </h3>
                <div class="theme-page-subtitle">
                  {{ item.price | money }}
                </div>
                <div>
                  <a href="{{ item.url }}" class="theme-review-button">
                    View Product
                  </a>
                </div>
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Search Page",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
